@inject IConfiguration Configuration

<MudNavMenu Class="ruckr-nav">
    <MudText Typo="Typo.overline" Class="ruckr-nav-section">Game</MudText>
    <MudNavLink Href="map" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Map" OnClick="HandleNavigate" data-testid="nav-map">
        Map
    </MudNavLink>
    @if (ShowDebugMapLinks)
    {
        <MudNavLink Href="debug-map" Icon="@Icons.Material.Filled.LocationOn" OnClick="HandleNavigate" data-testid="nav-debug-map">
            Debug Map
        </MudNavLink>
        <MudNavLink Href="debug-layers" Icon="@Icons.Material.Filled.Layers" OnClick="HandleNavigate" data-testid="nav-debug-layers">
            Debug Layers
        </MudNavLink>
    }
    <MudNavLink Href="catalog" Icon="@Icons.Material.Filled.FormatListBulleted" OnClick="HandleNavigate" data-testid="nav-catalog">
        Catalog
    </MudNavLink>
    <MudNavLink Href="collection" Icon="@Icons.Material.Filled.Stars" OnClick="HandleNavigate" data-testid="nav-collection">
        Collection
    </MudNavLink>
    <MudNavLink Href="players/nearby" Icon="@Icons.Material.Filled.Groups" OnClick="HandleNavigate" data-testid="nav-nearby">
        Nearby Users
    </MudNavLink>
    <MudNavLink Href="battle" Icon="@Icons.Material.Filled.Bolt" OnClick="HandleNavigate" data-testid="nav-battles">
        Battles
    </MudNavLink>
    <MudNavLink Href="battles/history" Icon="@Icons.Material.Filled.History" OnClick="HandleNavigate" data-testid="nav-history">
        History
    </MudNavLink>
    <MudNavLink Href="pitches/create" Icon="@Icons.Material.Filled.AddLocationAlt" OnClick="HandleNavigate" data-testid="nav-create-pitch">
        Create Pitch
    </MudNavLink>

    <MudDivider Class="my-3" />
    <MudText Typo="Typo.overline" Class="ruckr-nav-section">Account</MudText>
    <AuthorizeView>
        <Authorized>
            <MudText Typo="Typo.body2" Class="ruckr-user-name">
                @context.User.Identity?.Name
            </MudText>
            <MudNavLink Href="/Identity/Account/LogOut" Target="_top" Icon="@Icons.Material.Filled.Logout" data-testid="nav-logout">
                Logout
            </MudNavLink>
        </Authorized>
        <NotAuthorized>
            <MudNavLink Href="/Identity/Account/Login" Target="_top" Icon="@Icons.Material.Filled.Login" data-testid="nav-login">
                Login
            </MudNavLink>
        </NotAuthorized>
    </AuthorizeView>
</MudNavMenu>

@code {
    [Parameter]
    public EventCallback OnNavigate { get; set; }

    private bool ShowDebugMapLinks =>
        bool.TryParse(Configuration["Map:ShowDebugNav"], out var showDebugNav) && showDebugNav;

    private Task HandleNavigate()
    {
        return OnNavigate.InvokeAsync();
    }
}
