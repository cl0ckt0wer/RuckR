@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="ruckr-shell">
    <MudAppBar Elevation="1" Dense="true" Class="ruckr-appbar" Style="z-index: 2000;">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer"
                       aria-label="Open navigation" />
        <MudText Typo="Typo.h6" Class="ruckr-brand navbar-brand">RuckR</MudText>
        <MudSpacer />
        <MudButton Href="https://docs.microsoft.com/aspnet/"
                   Target="_blank"
                   Color="Color.Inherit"
                   Variant="Variant.Text">
            About
        </MudButton>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Variant="DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Always"
               Elevation="1"
               Breakpoint="Breakpoint.Sm"
               Style="z-index: 1900;"
               Class="ruckr-drawer">
        <NavMenu OnNavigate="CloseDrawer" />
        <ConnectionStatus />
    </MudDrawer>

    <MudMainContent Class="ruckr-main" Style="min-height: calc(100dvh - 48px);">
        <article class="content">
            @Body
        </article>
    </MudMainContent>
</MudLayout>

<NotificationToast />

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0f766e",
            Secondary = "#1d4ed8",
            AppbarBackground = "#0f172a",
            AppbarText = "#ffffff",
            DrawerBackground = "#ffffff",
            DrawerText = "#1f2937",
            Surface = "#ffffff",
            Background = "#f8fafc"
        }
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void CloseDrawer()
    {
        _drawerOpen = false;
    }
}
