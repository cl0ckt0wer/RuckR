@using Fluxor
@using RuckR.Client.Pages
@using RuckR.Client.Services
@using RuckR.Client.Store.GameFeature
@using RuckR.Client.Store.LocationFeature
@using RuckR.Shared.Models
@implements IAsyncDisposable
@inject IConfiguration Configuration
@inject IJSRuntime JS
@inject IDispatcher Dispatcher
@inject IState<GameState> GameState
@inject IState<LocationState> LocationState
@inject SignalRClientService SignalRClient
@inject AuthenticationStateProvider AuthStateProvider

<div class="connection-status @StatusClass" data-testid="connection-status">
    <span class="status-dot @DotClass" data-testid="status-dot"></span>
    <span class="status-text" data-testid="status-text">@StatusText</span>
    <span class="status-detail status-detail--gps gps-status-inline gps-status-inline--@GpsStatus.CssClass"
          data-testid="gps-status-chip"
          role="status"
          title="@GpsStatus.Detail">
        <span class="gps-status-inline__dot" aria-hidden="true"></span>
        <span>@GpsStatus.Label</span>
        @if (GpsStatus.AccuracyText is not null)
        {
            <small>&nbsp;@GpsStatus.AccuracyText</small>
        }
    </span>
    <span class="status-detail" data-testid="online-status">@OnlineStatusText</span>
    <span class="status-detail" data-testid="quality-status">@QualityStatusText</span>
    @if (GameState.Value.PendingActionCount > 0)
    {
        <span class="status-detail" data-testid="queue-status">Queued @GameState.Value.PendingActionCount</span>
    }
    @if (_connectionStatus == ConnectionStatusEnum.Disconnected)
    {
        <button class="btn btn-sm btn-outline-light ms-2" data-testid="reconnect-btn" @onclick="ReconnectAsync">Reconnect</button>
    }
</div>

<style>
    .connection-status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        font-size: 0.85rem;
        flex-wrap: wrap;
    }
    .status-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .status-detail {
        opacity: 0.8;
        white-space: nowrap;
    }
    .gps-status-inline {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        opacity: 1;
        font-weight: 700;
    }
    .gps-status-inline__dot {
        width: 0.5rem;
        height: 0.5rem;
        flex: 0 0 auto;
        border-radius: 999px;
        background: #64748b;
        box-shadow: 0 0 0 2px rgba(100, 116, 139, 0.2);
    }
    .gps-status-inline small {
        font-size: 0.74rem;
        font-weight: 800;
        opacity: 0.75;
    }
    .gps-status-inline--ready .gps-status-inline__dot {
        background: #22c55e;
        box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.22);
    }
    .gps-status-inline--searching .gps-status-inline__dot {
        background: #60a5fa;
        box-shadow: 0 0 0 2px rgba(96, 165, 250, 0.22);
        animation: gps-inline-pulse 1.5s ease-in-out infinite;
    }
    .gps-status-inline--weak .gps-status-inline__dot {
        background: #f59e0b;
        box-shadow: 0 0 0 2px rgba(245, 158, 11, 0.22);
    }
    .gps-status-inline--blocked .gps-status-inline__dot,
    .gps-status-inline--offline .gps-status-inline__dot {
        background: #ef4444;
        box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.22);
    }
    .status-dot.connected {
        background-color: #28a745;
        box-shadow: 0 0 6px #28a745;
    }
    .status-dot.reconnecting {
        background-color: #ffc107;
        box-shadow: 0 0 6px #ffc107;
        animation: pulse 1.5s infinite;
    }
    .status-dot.disconnected {
        background-color: #dc3545;
    }
    @@media (max-width: 640px) {
        .connection-status {
            min-height: 2.25rem;
            padding: 0.3rem 0.65rem;
            gap: 0.4rem;
            flex-wrap: nowrap;
            overflow-x: auto;
            font-size: 0.78rem;
            background: rgba(58, 6, 71, 0.96);
            scrollbar-width: none;
        }
        .connection-status::-webkit-scrollbar {
            display: none;
        }
        .status-text,
        .status-detail {
            white-space: nowrap;
        }
        .status-detail:not(.status-detail--gps) {
            display: none;
        }
        .connection-status .btn {
            margin-left: 0 !important;
            padding: 0.2rem 0.55rem;
            font-size: 0.75rem;
            line-height: 1.2;
            white-space: nowrap;
        }
    }
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }
    @@keyframes gps-inline-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.45; }
    }
</style>

@code {
    private enum ConnectionStatusEnum { Connected, Reconnecting, Disconnected }
    private const double MaxActionAccuracyMeters = 50;

    private ConnectionStatusEnum _connectionStatus = ConnectionStatusEnum.Disconnected;
    private string _statusText = "Disconnected";
    private IJSObjectReference? _geoModule;
    private DotNetObjectReference<ConnectionStatus>? _dotNetRef;

    private string StatusClass => _connectionStatus switch
    {
        ConnectionStatusEnum.Connected => "text-success",
        ConnectionStatusEnum.Reconnecting => "text-warning",
        _ => "text-danger"
    };

    private string DotClass => _connectionStatus switch
    {
        ConnectionStatusEnum.Connected => "connected",
        ConnectionStatusEnum.Reconnecting => "reconnecting",
        _ => "disconnected"
    };

    private string StatusText => _statusText;
    private string OnlineStatusText => GameState.Value.IsBrowserOnline ? "Online" : "Offline";
    private bool HasMapApiKey => !GameMap.ShouldShowMapUnavailableFallback(Configuration["ArcGISApiKey"]);
    private GameMap.GpsStatusView GpsStatus => GameMap.BuildGpsStatus(
        HasMapApiKey,
        LocationState.Value.IsWatching,
        LocationState.Value.ErrorMessage,
        LastKnownPosition,
        MaxActionAccuracyMeters,
        LocationState.Value.SearchStartedAtUtc,
        LocationState.Value.LastErrorAtUtc);
    private GeoPosition? LastKnownPosition =>
        LocationState.Value.UserLatitude.HasValue && LocationState.Value.UserLongitude.HasValue
            ? new GeoPosition
            {
                Latitude = LocationState.Value.UserLatitude.Value,
                Longitude = LocationState.Value.UserLongitude.Value,
                Accuracy = LocationState.Value.AccuracyMeters
            }
            : null;
    private string QualityStatusText => GameState.Value.ConnectionLatencyMs switch
    {
        null when GameState.Value.IsSignalRConnected => "Quality unknown",
        null => "No signal",
        <= 150 => $"Good {GameState.Value.ConnectionLatencyMs}ms",
        <= 400 => $"Fair {GameState.Value.ConnectionLatencyMs}ms",
        _ => $"Poor {GameState.Value.ConnectionLatencyMs}ms"
    };

    protected override async Task OnInitializedAsync()
    {
        SignalRClient.ConnectionStateChanged += OnConnectionStateChanged;
        GameState.StateChanged += OnGameStateChanged;
        LocationState.StateChanged += OnLocationStateChanged;

        UpdateFromConnectionState(GameState.Value.IsSignalRConnected, GameState.Value.ConnectionError);

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            await ReconnectAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _geoModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/geolocation.module.js");
        _dotNetRef = DotNetObjectReference.Create(this);
        await _geoModule.InvokeVoidAsync("watchOnlineStatus", _dotNetRef);
    }

    [JSInvokable]
    public async Task OnBrowserOnlineStateChanged(bool isOnline)
    {
        Dispatcher.Dispatch(new SetBrowserOnlineStateAction(isOnline));

        if (isOnline)
        {
            await ReconnectAsync();
        }

        await InvokeAsync(StateHasChanged);
    }

    private void OnConnectionStateChanged(bool isConnected, string? error)
    {
        UpdateFromConnectionState(isConnected, error);
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnGameStateChanged(object? sender, EventArgs e)
    {
        var state = ((IState<GameState>)sender!).Value;
        UpdateFromConnectionState(state.IsSignalRConnected, state.ConnectionError);
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnLocationStateChanged(object? sender, EventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void UpdateFromConnectionState(bool isConnected, string? error)
    {
        if (!GameState.Value.IsBrowserOnline)
        {
            _connectionStatus = ConnectionStatusEnum.Disconnected;
            _statusText = "Disconnected";
        }
        else if (isConnected)
        {
            _connectionStatus = ConnectionStatusEnum.Connected;
            _statusText = "Connected";
        }
        else if (!string.IsNullOrEmpty(error) && error.Contains("Reconnect", StringComparison.OrdinalIgnoreCase))
        {
            _connectionStatus = ConnectionStatusEnum.Reconnecting;
            _statusText = "Reconnecting...";
        }
        else
        {
            _connectionStatus = ConnectionStatusEnum.Disconnected;
            _statusText = "Disconnected";
        }
    }

    private async Task ReconnectAsync()
    {
        _connectionStatus = ConnectionStatusEnum.Reconnecting;
        _statusText = "Reconnecting...";
        StateHasChanged();

        try
        {
            await SignalRClient.StartAsync();
        }
        catch
        {
            _connectionStatus = ConnectionStatusEnum.Disconnected;
            _statusText = "Disconnected";
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        SignalRClient.ConnectionStateChanged -= OnConnectionStateChanged;
        GameState.StateChanged -= OnGameStateChanged;
        LocationState.StateChanged -= OnLocationStateChanged;

        if (_geoModule is not null)
        {
            try
            {
                await _geoModule.InvokeVoidAsync("clearOnlineStatusWatch");
                await _geoModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        _dotNetRef?.Dispose();
    }
}
