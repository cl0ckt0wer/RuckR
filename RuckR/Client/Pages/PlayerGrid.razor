@page "/players/nearby"
@using RuckR.Shared.Models
@using RuckR.Client.Store.LocationFeature
@inject ApiClientService ApiClient
@inject IState<LocationState> LocationState
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject RuckR.Client.Services.IGeolocationService GeolocationService

<PageTitle>Closest Users</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="game-page nearby-page">
    @if (_requiresAuth)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2">Checking session...</MudText>
        </MudStack>
    }
    else if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8" data-testid="nearby-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2">Finding closest users...</MudText>
        </MudStack>
    }
    else if (_gpsDisabled)
    {
        <MudPaper Elevation="0" Class="game-panel empty-panel" data-testid="gps-disabled-state">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.MyLocation" Size="Size.Large" Color="Color.Warning" />
                <MudText Typo="Typo.h5">@GpsDisabledTitle</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@GpsDisabledBody</MudText>
                @if (IsLocationPermissionDenied)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" data-testid="gps-permission-help">
                        Allow Location for this site in your browser settings, then check again.
                    </MudAlert>
                }
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.GpsFixed" OnClick="EnableGpsAsync" data-testid="gps-enable-btn">
                    @(IsLocationSearchPending ? "Checking GPS" : IsLocationPermissionDenied ? "Check Again" : "Enable GPS")
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="game-page__header">
                <div>
                    <MudText Typo="Typo.overline">Challenge Targets</MudText>
                    <MudText Typo="Typo.h4">Closest Users</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_nearbyUsers.Count challengeable users within @_selectedRadiusKm km.
                    </MudText>
                </div>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudSelect T="int" Label="Radius" @bind-Value="_selectedRadiusKm" @bind-Value:after="OnRadiusChangedAsync" Variant="Variant.Outlined" Dense="true" Class="radius-select" data-testid="radius-selector">
                        @foreach (var radius in _radiusOptions)
                        {
                            <MudSelectItem T="int" Value="@radius">@radius km</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadNearbyUsersAsync" data-testid="nearby-retry-btn">
                        Refresh
                    </MudButton>
                </MudStack>
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" data-testid="nearby-error">@_errorMessage</MudAlert>
            }
            else if (_nearbyUsers.Count == 0)
            {
                <MudPaper Elevation="0" Class="game-panel empty-panel" data-testid="empty-state">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.h5">No challengeable users nearby</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Both players need recent GPS and at least one collected recruit.</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudGrid Spacing="3" data-testid="nearby-grid">
                    @foreach (var user in _sortedUsers)
                    {
                        <MudItem xs="12" md="6" xl="4">
                            <MudPaper Elevation="1" Class="game-panel user-card" data-testid="user-card">
                                <MudStack Spacing="2">
                                    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                                        <div>
                                            <MudText Typo="Typo.h6" data-testid="user-name">@user.Username</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatLastSeen(user.LastSeenSecondsAgo)</MudText>
                                        </div>
                                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" data-testid="distance-badge">
                                            @FormatDistanceBucket(user.DistanceBucket)
                                        </MudChip>
                                    </MudStack>

                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">@user.RecruitCount recruits available</MudText>
                                    </MudStack>

                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Bolt" OnClick="() => ChallengeUser(user)" data-testid="challenge-btn">
                                        Challenge
                                    </MudButton>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudStack>
    }
</MudContainer>

@code {
    private bool _requiresAuth = true;
    private bool _isLoading = true;
    private bool _gpsDisabled;
    private string? _errorMessage;
    private List<NearbyUserDto> _nearbyUsers = new();
    private int _selectedRadiusKm = 10;
    private static readonly int[] _radiusOptions = [1, 5, 10, 25, 50];

    private bool IsLocationSearchPending =>
        GameMap.ShouldMonitorLocationSearch(
            LocationState.Value.ErrorMessage,
            LocationState.Value.SearchStartedAtUtc,
            LocationState.Value.LastErrorAtUtc,
            DateTime.UtcNow);

    private bool IsLocationPermissionDenied =>
        !IsLocationSearchPending
        && (LocationState.Value.PermissionStatus == GeolocationPermissionStatus.Denied
            || GameMap.IsLocationPermissionDenied(LocationState.Value.ErrorMessage));

    private string GpsDisabledTitle => IsLocationSearchPending
        ? "Checking GPS"
        : IsLocationPermissionDenied
            ? "Location permission is off"
            : "Enable GPS to find closest users";

    private string GpsDisabledBody => IsLocationSearchPending
        ? "Waiting for the browser to finish location permission and GPS lock."
        : IsLocationPermissionDenied
            ? "Nearby users still need your browser to allow Location for this site."
            : "RuckR needs your location to list nearby users you can challenge.";

    private IEnumerable<NearbyUserDto> _sortedUsers =>
        _nearbyUsers
            .OrderBy(user => (int)user.DistanceBucket)
            .ThenBy(user => user.LastSeenSecondsAgo)
            .ThenBy(user => user.Username)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is null || !user.Identity.IsAuthenticated)
        {
            var returnUrl = Uri.EscapeDataString("/" + Navigation.ToBaseRelativePath(Navigation.Uri));
            Navigation.NavigateTo($"/Identity/Account/Login?returnUrl={returnUrl}", forceLoad: true);
            return;
        }

        _requiresAuth = false;

        if (!LocationState.Value.UserLatitude.HasValue || !LocationState.Value.UserLongitude.HasValue)
        {
            _gpsDisabled = true;
            _isLoading = false;
            return;
        }

        await LoadNearbyUsersAsync();
    }

    private async Task LoadNearbyUsersAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var lat = LocationState.Value.UserLatitude;
            var lng = LocationState.Value.UserLongitude;

            if (!lat.HasValue || !lng.HasValue)
            {
                _gpsDisabled = true;
                return;
            }

            _gpsDisabled = false;
            _nearbyUsers = await ApiClient.GetNearbyUsersAsync(lat.Value, lng.Value, _selectedRadiusKm * 1000);
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Failed to load nearby users: {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task EnableGpsAsync()
    {
        try
        {
            _gpsDisabled = false;
            _isLoading = true;
            await GeolocationService.StartWatchAsync();
            await Task.Delay(1500);
            await LoadNearbyUsersAsync();
        }
        catch
        {
            _gpsDisabled = true;
            _isLoading = false;
        }
        finally
        {
            if (!LocationState.Value.UserLatitude.HasValue || !LocationState.Value.UserLongitude.HasValue)
            {
                _gpsDisabled = true;
                _isLoading = false;
            }
        }
    }

    private void ChallengeUser(NearbyUserDto user)
    {
        Navigation.NavigateTo($"/battle?opponent={Uri.EscapeDataString(user.Username)}");
    }

    private async Task OnRadiusChangedAsync()
    {
        await LoadNearbyUsersAsync();
    }

    private static string FormatDistanceBucket(DistanceBucket bucket) => bucket switch
    {
        DistanceBucket.Within50m => "< 50m",
        DistanceBucket.Within100m => "< 100m",
        DistanceBucket.Within250m => "< 250m",
        DistanceBucket.Within500m => "< 500m",
        _ => "> 500m"
    };

    private static string FormatLastSeen(int secondsAgo)
    {
        if (secondsAgo < 5) return "online now";
        if (secondsAgo < 60) return $"{secondsAgo}s ago";
        return "stale";
    }
}

<style>
    .game-page {
        padding: 1rem;
    }

    .game-page__header {
        gap: 1rem;
        flex-wrap: wrap;
    }

    .game-panel {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 8px;
        padding: 1rem;
        background: #fff;
    }

    .empty-panel {
        min-height: 18rem;
        display: grid;
        place-items: center;
        text-align: center;
    }

    .user-card {
        min-height: 12rem;
    }

    .radius-select {
        width: 8.5rem;
    }

    @@media (max-width: 720px) {
        .game-page {
            padding: 0.75rem;
        }

        .game-panel {
            padding: 0.85rem;
        }
    }
</style>
