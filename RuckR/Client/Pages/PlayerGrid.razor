@page "/players/nearby"
@using RuckR.Shared.Models
@using RuckR.Client.Store.LocationFeature
@inject ApiClientService ApiClient
@inject IState<LocationState> LocationState
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject RuckR.Client.Services.IGeolocationService GeolocationService

<PageTitle>Nearby Players</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="game-page nearby-page">
    @if (_requiresAuth)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2">Checking session...</MudText>
        </MudStack>
    }
    else if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8" data-testid="nearby-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2">Scanning nearby players...</MudText>
        </MudStack>
    }
    else if (_gpsDisabled)
    {
        <MudPaper Elevation="0" Class="game-panel empty-panel" data-testid="gps-disabled-state">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.MyLocation" Size="Size.Large" Color="Color.Warning" />
                <MudText Typo="Typo.h5">Enable GPS to find nearby players</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">RuckR needs your location to list nearby wild and owned players.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.GpsFixed" OnClick="EnableGpsAsync" data-testid="gps-enable-btn">
                    Enable GPS
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="game-page__header">
                <div>
                    <MudText Typo="Typo.overline">Scouting</MudText>
                    <MudText Typo="Typo.h4">Nearby Players</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_nearbyPlayers.Count players found within @_selectedRadiusKm km.
                    </MudText>
                </div>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudSelect T="int" Label="Radius" @bind-Value="_selectedRadiusKm" @bind-Value:after="OnRadiusChangedAsync" Variant="Variant.Outlined" Dense="true" Class="radius-select" data-testid="radius-selector">
                        @foreach (var radius in _radiusOptions)
                        {
                            <MudSelectItem T="int" Value="@radius">@radius km</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadNearbyPlayersAsync" data-testid="nearby-retry-btn">
                        Refresh
                    </MudButton>
                </MudStack>
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" data-testid="nearby-error">@_errorMessage</MudAlert>
            }
            else if (_nearbyPlayers.Count == 0)
            {
                <MudPaper Elevation="0" Class="game-panel empty-panel" data-testid="empty-state">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Radar" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.h5">No players nearby</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Try a wider search radius or check the map for recruits.</MudText>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudGrid Spacing="3" data-testid="nearby-grid">
                    @foreach (var item in _sortedPlayers)
                    {
                        var isWild = string.IsNullOrWhiteSpace(item.OwnerUsername);
                        var isSelf = !isWild && string.Equals(item.OwnerUsername, _currentUsername, StringComparison.OrdinalIgnoreCase);

                        <MudItem xs="12" md="6" xl="4">
                            <MudPaper Elevation="1" Class="game-panel player-card" data-testid="player-card">
                                <MudStack Spacing="2">
                                    <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                                        <div>
                                            <MudText Typo="Typo.h6" data-testid="player-name">@item.Name</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatDistanceBucket(item.DistanceBucket)</MudText>
                                        </div>
                                        <MudChip T="string" Color="@OwnerColor(isWild, isSelf)" Variant="Variant.Filled" data-testid="owner-badge">
                                            @OwnerLabel(isWild, isSelf)
                                        </MudChip>
                                    </MudStack>

                                    <MudChipSet T="string">
                                        <MudChip T="string" Variant="Variant.Outlined" data-testid="position-badge">@item.Position</MudChip>
                                        <MudChip T="string" Color="@RarityColor(item.Rarity)" Variant="Variant.Filled" data-testid="rarity-badge">@item.Rarity</MudChip>
                                    </MudChipSet>

                                    <div class="distance-block" data-testid="distance-display">
                                        <MudText Typo="Typo.h5">@FormatDistanceBucket(item.DistanceBucket)</MudText>
                                    </div>

                                    @if (isWild)
                                    {
                                        <MudButton Variant="Variant.Outlined" Disabled="true" StartIcon="@Icons.Material.Filled.Search" data-testid="scout-btn">
                                            Scout Soon
                                        </MudButton>
                                    }
                                    else if (isSelf)
                                    {
                                        <MudAlert Severity="Severity.Info" Dense="true">This player is already yours.</MudAlert>
                                    }
                                    else
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Bolt" OnClick="() => ChallengePlayer(item)" data-testid="challenge-btn">
                                            Challenge Owner
                                        </MudButton>
                                    }
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudStack>
    }
</MudContainer>

@code {
    private bool _requiresAuth = true;
    private bool _isLoading = true;
    private bool _gpsDisabled;
    private string? _errorMessage;
    private string _currentUsername = string.Empty;
    private List<NearbyPlayerDto> _nearbyPlayers = new();
    private int _selectedRadiusKm = 10;
    private static readonly int[] _radiusOptions = [1, 5, 10, 25, 50];

    private IEnumerable<NearbyPlayerDto> _sortedPlayers =>
        _nearbyPlayers
            .OrderBy(p => (int)p.DistanceBucket)
            .ThenBy(p => p.Name)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is null || !user.Identity.IsAuthenticated)
        {
            var returnUrl = Uri.EscapeDataString("/" + Navigation.ToBaseRelativePath(Navigation.Uri));
            Navigation.NavigateTo($"/Identity/Account/Login?returnUrl={returnUrl}", forceLoad: true);
            return;
        }

        _requiresAuth = false;
        _currentUsername = user.Identity.Name ?? string.Empty;

        if (!LocationState.Value.UserLatitude.HasValue || !LocationState.Value.UserLongitude.HasValue)
        {
            _gpsDisabled = true;
            _isLoading = false;
            return;
        }

        await LoadNearbyPlayersAsync();
    }

    private async Task LoadNearbyPlayersAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var lat = LocationState.Value.UserLatitude;
            var lng = LocationState.Value.UserLongitude;

            if (!lat.HasValue || !lng.HasValue)
            {
                _gpsDisabled = true;
                return;
            }

            _gpsDisabled = false;
            _nearbyPlayers = await ApiClient.GetNearbyPlayersAsync(lat.Value, lng.Value, _selectedRadiusKm * 1000);
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Failed to load nearby players: {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task EnableGpsAsync()
    {
        try
        {
            _gpsDisabled = false;
            _isLoading = true;
            await GeolocationService.StartWatchAsync();
            await Task.Delay(1500);
            await LoadNearbyPlayersAsync();
        }
        catch
        {
            _gpsDisabled = true;
            _isLoading = false;
        }
    }

    private void ChallengePlayer(NearbyPlayerDto player)
    {
        if (!string.IsNullOrWhiteSpace(player.OwnerUsername))
        {
            Navigation.NavigateTo($"/battle?opponent={Uri.EscapeDataString(player.OwnerUsername)}");
        }
    }

    private async Task OnRadiusChangedAsync()
    {
        await LoadNearbyPlayersAsync();
    }

    private static string FormatDistanceBucket(DistanceBucket bucket) => bucket switch
    {
        DistanceBucket.Within50m => "< 50m",
        DistanceBucket.Within100m => "< 100m",
        DistanceBucket.Within250m => "< 250m",
        DistanceBucket.Within500m => "< 500m",
        _ => "> 500m"
    };

    private static string OwnerLabel(bool isWild, bool isSelf)
    {
        if (isWild) return "Wild";
        if (isSelf) return "You";
        return "Owned";
    }

    private static Color OwnerColor(bool isWild, bool isSelf)
    {
        if (isWild) return Color.Secondary;
        if (isSelf) return Color.Info;
        return Color.Primary;
    }

    private static Color RarityColor(string rarity) => rarity switch
    {
        "Common" => Color.Secondary,
        "Uncommon" => Color.Success,
        "Rare" => Color.Primary,
        "Epic" => Color.Tertiary,
        "Legendary" => Color.Warning,
        _ => Color.Default
    };
}

<style>
    .game-page {
        padding: 1rem;
    }

    .game-page__header {
        gap: 1rem;
        flex-wrap: wrap;
    }

    .game-panel {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 8px;
        padding: 1rem;
        background: #fff;
    }

    .empty-panel {
        min-height: 18rem;
        display: grid;
        place-items: center;
        text-align: center;
    }

    .player-card {
        min-height: 17rem;
    }

    .radius-select {
        width: 8.5rem;
    }

    .distance-block {
        display: grid;
        place-items: center;
        min-height: 4rem;
        border-radius: 8px;
        background: #f1f5f9;
    }

    @@media (max-width: 720px) {
        .game-page {
            padding: 0.75rem;
        }

        .game-panel {
            padding: 0.85rem;
        }
    }
</style>
