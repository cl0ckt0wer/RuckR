@page "/pitches/create"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject NavigationManager Navigation

<PageTitle>Create Pitch Disabled</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="pitch-create-disabled-page">
    <MudPaper Elevation="0" Class="pitch-create-disabled-panel" data-testid="pitch-create-disabled">
        <MudStack AlignItems="AlignItems.Center" Spacing="3">
            <MudIcon Icon="@Icons.Material.Filled.LocationOff" Size="Size.Large" Color="Color.Secondary" />
            <MudText Typo="Typo.h5">Manual pitch creation is disabled</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                RuckR now promotes approved ArcGIS Places into Pitch Hubs automatically.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Map" OnClick="GoToMap" data-testid="pitch-create-map-btn">
                Open map
            </MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private void GoToMap()
    {
        Navigation.NavigateTo("/map");
    }
}

<style>
    .pitch-create-disabled-page {
        padding: 1rem;
    }

    .pitch-create-disabled-panel {
        min-height: 18rem;
        display: grid;
        place-items: center;
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 8px;
        padding: 1.25rem;
        text-align: center;
        background: #fff;
    }
</style>
