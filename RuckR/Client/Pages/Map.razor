@page "/map"
@page "/"
@using dymaptic.GeoBlazor.Core.Components
@using dymaptic.GeoBlazor.Core.Components.Geometries
@using dymaptic.GeoBlazor.Core.Components.Symbols
@using dymaptic.GeoBlazor.Core.Components.Views
@using dymaptic.GeoBlazor.Core.Components.Widgets
@using dymaptic.GeoBlazor.Core.Enums
@using dymaptic.GeoBlazor.Core.Events
@using dymaptic.GeoBlazor.Core.Model
@using Fluxor
@using RuckR.Client.Services
@using RuckR.Client.Store.MapFeature
@using RuckR.Client.Store.LocationFeature
@using RuckR.Shared.Models
@inject IConfiguration Configuration
@inject ILogger<Map> Logger
@inject IGeolocationService GeolocationService
@inject ApiClientService ApiClient
@inject SignalRClientService SignalRClient
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject IDispatcher Dispatcher
@inject IState<MapState> MapState
@inject IState<LocationState> LocationState
@implements IAsyncDisposable

<div class="map-shell" data-testid="map-container">
    @if (!_hasApiKey)
    {
        <div class="map-unavailable-shell">
            <div class="map-unavailable-panel">
                <p class="mb-1 fw-bold">Map unavailable</p>
                <p class="small text-muted mb-0">
                    ArcGIS API key is not configured. Set the <code>ARC_GIS_API_KEY</code> environment variable.
                </p>
            </div>
        </div>
    }

    <div data-testid="map-loading" class="map-loading" style="@(_viewReady || !_hasApiKey ? "display:none" : "")">
        <div class="spinner-border text-light" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    @if (_hasApiKey)
    {
        <MapView @ref="_mapView"
                 Latitude="@_latitude"
                 Longitude="@_longitude"
                 Zoom="@_zoom"
                 OnClick="HandleMapClick"
                 OnViewInitialized="OnViewInitializedAsync"
                 ShowZoomWidget="true"
                 style="width:100%; height:100%;">
            <dymaptic.GeoBlazor.Core.Components.Map>
                <Basemap>
                    <BasemapStyle Name="@BasemapStyleName.ArcgisNavigation" ApiKey="@_apiKey" />
                </Basemap>
            </dymaptic.GeoBlazor.Core.Components.Map>
            <HomeWidget Position="OverlayPosition.TopLeft" />
            <CompassWidget Position="OverlayPosition.TopLeft" />
            <LocateWidget Position="OverlayPosition.TopLeft" />
            <ScaleBarWidget Position="OverlayPosition.BottomLeft" />
        </MapView>
        <div class="map-fab-group">
            <button class="btn btn-sm btn-outline-light map-fab"
                    data-testid="nearest-stadium-btn"
                    @onclick="() => CenterOnNearestPitchByTypeAsync(PitchType.Stadium)"
                    disabled="@(!_pitchGraphics.Any(p => MapState.Value.VisiblePitches.FirstOrDefault(v => v.Id == p.Key)?.Type == PitchType.Stadium))"
                    title="Nearest stadium">
                &#x1F3DF;
            </button>
            <button class="btn btn-sm btn-outline-light map-fab"
                    data-testid="nearest-standard-btn"
                    @onclick="() => CenterOnNearestPitchByTypeAsync(PitchType.Standard)"
                    disabled="@(!_pitchGraphics.Any(p => MapState.Value.VisiblePitches.FirstOrDefault(v => v.Id == p.Key)?.Type == PitchType.Standard))"
                    title="Nearest pitch">
                &#x26BD;
            </button>
            <button class="btn btn-sm btn-outline-light map-fab"
                    data-testid="nearest-training-btn"
                    @onclick="() => CenterOnNearestPitchByTypeAsync(PitchType.Training)"
                    disabled="@(!_pitchGraphics.Any(p => MapState.Value.VisiblePitches.FirstOrDefault(v => v.Id == p.Key)?.Type == PitchType.Training))"
                    title="Nearest training ground">
                &#x1F4A1;
            </button>
        </div>
        <div class="pitch-legend" data-testid="pitch-legend">
            <div class="pitch-legend__title">Pitches</div>
            <div class="pitch-legend__row">
                <span class="pitch-legend__marker pitch-legend__marker--stadium"></span>
                <span>Stadium</span>
                <strong>@PitchCount(PitchType.Stadium)</strong>
            </div>
            <div class="pitch-legend__row">
                <span class="pitch-legend__marker pitch-legend__marker--standard"></span>
                <span>Standard</span>
                <strong>@PitchCount(PitchType.Standard)</strong>
            </div>
            <div class="pitch-legend__row">
                <span class="pitch-legend__marker pitch-legend__marker--training"></span>
                <span>Training</span>
                <strong>@PitchCount(PitchType.Training)</strong>
            </div>
        </div>

        @if (ShouldShowGpsNotice)
        {
            <div class="gps-readiness" data-testid="gps-readiness">
                <div>
                    <div class="gps-readiness__title">@GpsNoticeTitle</div>
                    <p>@GpsNoticeBody</p>
                </div>
                <button class="btn btn-sm btn-outline-light"
                        type="button"
                        data-testid="gps-retry-btn"
                        @onclick="EnableGpsAsync">
                    Retry GPS
                </button>
            </div>
        }

        @if (_isAuthenticated && _selectedEncounter is null && MapState.Value.VisibleEncounters.Count > 0)
        {
            <div class="encounter-radar" data-testid="encounter-radar">
                <div class="encounter-radar__header">
                    <span>Recruit board</span>
                    <strong>@MapState.Value.VisibleEncounters.Count</strong>
                </div>
                @if (NearestEncounter is not null)
                {
                    <button class="encounter-radar__target"
                            data-testid="nearest-encounter-btn"
                            type="button"
                            @onclick="() => SelectEncounterAsync(NearestEncounter)">
                        <span>
                            <strong>@NearestEncounter.Name</strong>
                            <small>@EncounterParkName(NearestEncounter)</small>
                        </span>
                        <span>@EncounterDistanceText(NearestEncounter)</span>
                    </button>
                }
            </div>
        }
    }
</div>

@if (_showOnboarding)
{
    <div class="onboarding-banner" data-testid="onboarding-banner">
        <span class="onboarding-text">Welcome to RuckR! Explore the map to find pitches and recruit players.</span>
        <button class="btn-close btn-close-white" data-testid="onboarding-close" @onclick="DismissOnboarding" aria-label="Dismiss"></button>
    </div>
}

@if (_selectedPitch is not null)
{
    <div class="map-overlay pitch-card pitch-card--@PitchTypeCssClass(_selectedPitch.Type)" data-testid="pitch-overlay">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <div class="pitch-card__eyebrow">@PitchTypeDisplayName(_selectedPitch.Type)</div>
                <h5 class="mb-0" data-testid="pitch-name">@_selectedPitch.Name</h5>
            </div>
            <button type="button" class="btn-close" data-testid="pitch-close" @onclick="ClearSelection" aria-label="Close"></button>
        </div>
        <div class="pitch-card__meta mb-2">
            <span class="pitch-card__pill">@PitchTypeDescription(_selectedPitch.Type)</span>
            <span class="pitch-card__distance">@PitchDistanceText(_selectedPitch)</span>
        </div>
        <p class="small text-white-50 mb-0">
            @_selectedPitch.Latitude.ToString("F4"), @_selectedPitch.Longitude.ToString("F4")
        </p>
    </div>
}

@if (_selectedEncounter is not null)
{
    <div class="map-overlay map-overlay--encounter" data-testid="encounter-overlay">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <div class="encounter-card__eyebrow">@EncounterParkName(_selectedEncounter)</div>
                <h5 class="mb-0" data-testid="encounter-name">@_selectedEncounter.Name</h5>
            </div>
            <button type="button" class="btn-close" data-testid="encounter-close" @onclick="ClearEncounterSelection" aria-label="Close"></button>
        </div>
        <div class="mb-2 d-flex gap-2 flex-wrap">
            <span class="badge bg-@EncounterRarityBadgeClass(_selectedEncounter.Rarity) me-2">@_selectedEncounter.Rarity</span>
            <span class="badge bg-secondary">Level @_selectedEncounter.Level</span>
            <span class="badge bg-dark">@_selectedEncounter.Position</span>
            <span class="badge bg-info text-dark">@EncounterExpiresText(_selectedEncounter)</span>
        </div>
        <div class="encounter-card__route mb-2">
            <span>@EncounterDistanceText(_selectedEncounter)</span>
            <strong>@EncounterRouteInstruction(_selectedEncounter)</strong>
        </div>
        <div class="encounter-card__chance mb-3"
             role="progressbar"
             aria-label="Recruitment success chance"
             aria-valuemin="0"
             aria-valuemax="100"
             aria-valuenow="@_selectedEncounter.SuccessChancePercent">
            <div style="width:@_selectedEncounter.SuccessChancePercent%"></div>
            <span>@_selectedEncounter.SuccessChancePercent% chance</span>
        </div>
        <button class="btn btn-sm btn-@RecruitButtonClass()"
                data-testid="recruit-btn"
                disabled="@(!_canRecruit)"
                title="@_recruitBlockedReason"
                @onclick="AttemptRecruitment">
            @if (_isRecruiting)
            {
                <span class="spinner-border spinner-border-sm" role="status"></span>
            }
            else
            {
                @:Recruit @_selectedEncounter.Name
            }
        </button>
        @if (!_canRecruit)
        {
            <p class="small mt-2 mb-0 text-warning">@_recruitBlockedReason</p>
        }
        @if (_recruitMessage is not null)
        {
            <p class="small mt-2 mb-0 text-@_recruitMessageClass">@_recruitMessage</p>
        }
    </div>
}

@if (_recruitToastMessage is not null)
{
    <div class="recruit-toast recruit-toast--@_recruitToastClass" data-testid="recruit-toast">
        @_recruitToastMessage
        <button type="button" class="btn-close btn-close-white" @onclick="DismissRecruitToast" aria-label="Dismiss"></button>
    </div>
}

@if (_gameProgress is not null)
{
    <div class="game-progress-chip" title="Level @_gameProgress.Level — @_gameProgress.Experience / @_gameProgress.NextLevelExperience XP">
        <span class="fw-bold">@_gameProgress.Level</span>
        <div class="progress flex-grow-1 ms-2">
            <div class="progress-bar"
                 role="progressbar"
                 style="width:@ProgressPercent%; min-width: 8px;"
                 aria-valuenow="@_gameProgress.Experience - _prevLevelXp"
                 aria-valuemin="0"
                 aria-valuemax="@_gameProgress.NextLevelExperience - _prevLevelXp">
            </div>
        </div>
    </div>
}

<div class="map-info-bar">
    <span class="text-muted small">
        @if (_statusMessage is not null)
        {
            @_statusMessage
        }
        else if (_pitchGraphics.Count > 0 || _encounterGraphics.Count > 0)
        {
            <text>@_pitchGraphics.Count pitches, @_encounterGraphics.Count encounters visible. Tap a marker to see details.</text>
        }
        else
        {
            <text>Loading...</text>
        }
    </span>
</div>

<style>
     .map-fab-group {
         position: absolute;
         bottom: 3.5rem;
         right: 0.5rem;
         z-index: 10;
         display: flex;
         flex-direction: column;
         gap: 0.25rem;
     }
     .map-fab {
         width: 2.5rem;
         height: 2.5rem;
         padding: 0;
         display: flex;
         align-items: center;
         justify-content: center;
         font-size: 1.1rem;
         border-radius: 0.375rem;
         background: rgba(33,37,41,0.85);
         border: 1px solid rgba(255,255,255,0.15);
     }
     .map-fab:hover:not(:disabled) {
         background: rgba(52,58,64,0.95);
     }
     .map-fab:disabled {
         opacity: 0.4;
     }
     .onboarding-banner {
         position: fixed;
         top: 0.75rem;
         left: 50%;
         z-index: 1500;
         display: flex;
         align-items: center;
         justify-content: space-between;
         gap: 0.75rem;
         width: min(640px, calc(100vw - 1.5rem));
         transform: translateX(-50%);
         border: 1px solid rgba(255,255,255,0.16);
         border-radius: 0.5rem;
         padding: 0.65rem 0.8rem;
         background: rgba(15,23,42,0.94);
         color: #fff;
         box-shadow: 0 16px 40px rgba(0,0,0,0.28);
     }
     .onboarding-text {
         min-width: 0;
         font-size: 0.9rem;
         line-height: 1.35;
     }
     .pitch-legend {
         position: absolute;
         top: 0.75rem;
         left: 0.75rem;
         z-index: 10;
         min-width: 148px;
         padding: 0.6rem 0.7rem;
         border: 1px solid rgba(255,255,255,0.14);
         border-radius: 0.75rem;
         background: linear-gradient(145deg, rgba(9, 24, 30, 0.88), rgba(17, 24, 39, 0.8));
         color: #f8fafc;
         box-shadow: 0 14px 34px rgba(0,0,0,0.28);
         backdrop-filter: blur(8px);
     }
     .pitch-legend__title {
         margin-bottom: 0.35rem;
         font-size: 0.72rem;
         font-weight: 800;
         letter-spacing: 0.08em;
         text-transform: uppercase;
         color: rgba(226,232,240,0.78);
     }
     .pitch-legend__row {
         display: grid;
         grid-template-columns: 18px 1fr auto;
         align-items: center;
         gap: 0.4rem;
         font-size: 0.78rem;
         line-height: 1.45;
     }
     .pitch-legend__row strong {
         font-size: 0.78rem;
         color: #fff;
     }
     .pitch-legend__marker {
         display: inline-block;
         width: 12px;
         height: 12px;
         border: 2px solid #f8fafc;
         box-shadow: 0 0 0 2px rgba(15,23,42,0.5);
     }
     .pitch-legend__marker--stadium {
         transform: rotate(45deg);
         background: #f59e0b;
     }
     .pitch-legend__marker--standard {
         border-radius: 0.15rem;
         background: #22c55e;
     }
     .pitch-legend__marker--training {
         width: 0;
         height: 0;
         border-left: 7px solid transparent;
         border-right: 7px solid transparent;
         border-bottom: 13px solid #38bdf8;
         border-top: 0;
         background: transparent;
         box-shadow: none;
     }
     .gps-readiness {
         position: absolute;
         top: 0.75rem;
         right: 0.75rem;
         z-index: 11;
         display: grid;
         grid-template-columns: minmax(0, 1fr) auto;
         align-items: center;
         gap: 0.75rem;
         width: min(420px, calc(100vw - 1.5rem));
         border: 1px solid rgba(250,204,21,0.32);
         border-radius: 0.5rem;
         padding: 0.7rem 0.8rem;
         background: rgba(24, 21, 12, 0.92);
         color: #fff;
         box-shadow: 0 16px 40px rgba(0,0,0,0.3);
         backdrop-filter: blur(8px);
     }
     .gps-readiness__title {
         margin-bottom: 0.15rem;
         font-size: 0.78rem;
         font-weight: 800;
         letter-spacing: 0.08em;
         text-transform: uppercase;
         color: #fde68a;
     }
     .gps-readiness p {
         margin: 0;
         font-size: 0.82rem;
         line-height: 1.35;
         color: rgba(248,250,252,0.86);
     }
     .gps-readiness .btn {
         white-space: nowrap;
     }
     .encounter-radar {
         position: absolute;
         top: 9rem;
         left: 0.75rem;
         z-index: 10;
         width: min(260px, calc(100vw - 1.5rem));
         padding: 0.6rem;
         border: 1px solid rgba(74,222,128,0.22);
         border-radius: 0.5rem;
         background: rgba(12, 20, 18, 0.9);
         color: #f8fafc;
         box-shadow: 0 16px 36px rgba(0,0,0,0.28);
         backdrop-filter: blur(8px);
     }
     .encounter-radar__header {
         display: flex;
         justify-content: space-between;
         align-items: center;
         margin-bottom: 0.45rem;
         font-size: 0.72rem;
         font-weight: 800;
         letter-spacing: 0.08em;
         text-transform: uppercase;
         color: rgba(226,232,240,0.78);
     }
     .encounter-radar__header strong {
         display: inline-flex;
         align-items: center;
         justify-content: center;
         min-width: 1.45rem;
         height: 1.45rem;
         border-radius: 999px;
         background: rgba(34,197,94,0.22);
         color: #bbf7d0;
     }
     .encounter-radar__target {
         display: grid;
         grid-template-columns: minmax(0, 1fr) auto;
         align-items: center;
         gap: 0.6rem;
         width: 100%;
         border: 1px solid rgba(255,255,255,0.1);
         border-radius: 0.4rem;
         padding: 0.5rem 0.55rem;
         background: rgba(255,255,255,0.06);
         color: inherit;
         text-align: left;
     }
     .encounter-radar__target:hover {
         background: rgba(34,197,94,0.14);
     }
     .encounter-radar__target strong,
     .encounter-radar__target small {
         display: block;
         overflow: hidden;
         text-overflow: ellipsis;
         white-space: nowrap;
     }
     .encounter-radar__target small,
     .encounter-radar__target > span:last-child {
         font-size: 0.76rem;
         color: rgba(226,232,240,0.72);
     }

     .map-overlay {
         position: absolute;
         bottom: 1rem;
         left: 0.5rem;
         right: 0.5rem;
         max-width: 380px;
         margin: 0 auto;
         background: rgba(33,37,41,0.92);
         border: 1px solid rgba(255,255,255,0.15);
         border-radius: 0.5rem;
         padding: 0.75rem 1rem;
         color: #fff;
         z-index: 10;
     }
     .map-overlay--encounter {
         border-color: rgba(74,222,128,0.4);
     }
     .encounter-card__eyebrow {
         margin-bottom: 0.15rem;
         font-size: 0.72rem;
         font-weight: 800;
         letter-spacing: 0.08em;
         text-transform: uppercase;
         color: rgba(187,247,208,0.8);
     }
     .encounter-card__route {
         display: grid;
         grid-template-columns: auto 1fr;
         align-items: center;
         gap: 0.6rem;
         border-radius: 0.45rem;
         padding: 0.5rem 0.6rem;
         background: rgba(34,197,94,0.1);
     }
     .encounter-card__route span {
         color: #bbf7d0;
         font-weight: 700;
     }
     .encounter-card__route strong {
         min-width: 0;
         font-size: 0.82rem;
         color: rgba(248,250,252,0.9);
     }
     .encounter-card__chance {
         position: relative;
         height: 1.35rem;
         overflow: hidden;
         border-radius: 999px;
         background: rgba(15,23,42,0.55);
         border: 1px solid rgba(255,255,255,0.1);
     }
     .encounter-card__chance div {
         height: 100%;
         border-radius: inherit;
         background: linear-gradient(90deg, #22c55e, #facc15);
     }
     .encounter-card__chance span {
         position: absolute;
         inset: 0;
         display: flex;
         align-items: center;
         justify-content: center;
         font-size: 0.75rem;
         font-weight: 800;
         color: #fff;
         text-shadow: 0 1px 2px rgba(0,0,0,0.45);
     }
     .pitch-card {
         overflow: hidden;
         border-width: 1px 1px 1px 5px;
         box-shadow: 0 16px 40px rgba(0,0,0,0.32);
     }
     .pitch-card--stadium {
         border-left-color: #f59e0b;
     }
     .pitch-card--standard {
         border-left-color: #22c55e;
     }
     .pitch-card--training {
         border-left-color: #38bdf8;
     }
     .pitch-card__eyebrow {
         margin-bottom: 0.15rem;
         font-size: 0.72rem;
         font-weight: 800;
         letter-spacing: 0.08em;
         text-transform: uppercase;
         color: rgba(226,232,240,0.72);
     }
     .pitch-card__meta {
         display: flex;
         flex-wrap: wrap;
         gap: 0.4rem;
     }
     .pitch-card__pill,
     .pitch-card__distance {
         display: inline-flex;
         align-items: center;
         border-radius: 999px;
         padding: 0.2rem 0.55rem;
         font-size: 0.75rem;
         background: rgba(255,255,255,0.1);
         color: #f8fafc;
     }
     .pitch-card__distance {
         background: rgba(15,23,42,0.42);
         color: rgba(226,232,240,0.86);
     }
     .map-info-bar {
         position: absolute;
         bottom: 0;
         left: 0;
         right: 0;
         padding: 0.25rem 0.5rem;
         background: rgba(0,0,0,0.5);
         color: #ccc;
         font-size: 0.75rem;
         text-align: center;
         z-index: 5;
     }

     .game-progress-chip {
         position: absolute;
         top: 0.75rem;
         right: 0.75rem;
         display: flex;
         align-items: center;
         gap: 0.25rem;
         background: rgba(33,37,41,0.85);
         border: 1px solid rgba(255,255,255,0.15);
         border-radius: 1.5rem;
         padding: 0.35rem 0.65rem;
         font-size: 0.8rem;
         color: #fff;
         z-index: 10;
         min-width: 80px;
         justify-content: center;
     }
     .game-progress-chip .progress {
         height: 6px;
         width: 60px;
     }
     .recruit-toast {
         position: absolute;
         left: 50%;
         bottom: 3.2rem;
         z-index: 12;
         display: flex;
         align-items: center;
         gap: 0.65rem;
         width: min(360px, calc(100vw - 1rem));
         transform: translateX(-50%);
         border: 1px solid rgba(255,255,255,0.14);
         border-radius: 0.5rem;
         padding: 0.65rem 0.8rem;
         color: #fff;
         box-shadow: 0 18px 42px rgba(0,0,0,0.34);
     }
     .recruit-toast--success {
         background: rgba(21,128,61,0.94);
     }
     .recruit-toast--danger {
         background: rgba(185,28,28,0.94);
     }

     @@media (max-width: 640px) {
         .gps-readiness {
             top: 4.25rem;
             left: 0.75rem;
             right: 0.75rem;
             grid-template-columns: 1fr;
             width: auto;
         }
         .encounter-radar {
             top: auto;
             bottom: 2.35rem;
         }
         .map-overlay--encounter + .recruit-toast,
         .recruit-toast {
             bottom: 4rem;
         }
     }
 </style>

@code {
    private MapView? _mapView;
    private string _apiKey = string.Empty;
    private bool _hasApiKey;
    private double _latitude = 51.5074;
    private double _longitude = -0.1278;
    private int _zoom = 13;
    private string? _statusMessage;
    private bool _viewReady;
    private bool _subscriptionsActive;
    private bool _initialCenterPerformed;
    private GeoPosition? _lastKnownPosition;
    private GeoPosition? _lastPitchFetchPosition;
    private DateTime _lastPitchFetchAtUtc = DateTime.MinValue;

    private const double EncounterBrowseRadiusMeters = 5000.0;
    private const double RecruitDistanceMeters = 75.0;
    private const double MaxRecruitAccuracyMeters = 50.0;

    private const double BrowseRadiusMeters = 5000.0;
    private const double MinPitchRefreshDistanceMeters = 50.0;
    private static readonly TimeSpan PitchRefreshInterval = TimeSpan.FromSeconds(30);

    private readonly Dictionary<int, Graphic> _pitchGraphics = new();
    private readonly Dictionary<Guid, Graphic> _encounterGraphics = new();
    private PitchModel? _selectedPitch;
    private int _lastSelectedPitchId = -1;
    private PlayerEncounterDto? _selectedEncounter;
    private GameProgressDto? _gameProgress;
    private int _prevLevelXp;
    private bool _canRecruit;
    private bool _isRecruiting;
    private bool _isAuthenticated;
    private string _recruitBlockedReason = "Go to the park to recruit.";
    private string? _recruitMessage;
    private string _recruitMessageClass = "success";
    private string? _recruitToastMessage;
    private string _recruitToastClass = "success";
    private bool _showOnboarding = true;

    protected override void OnInitialized()
    {
        _apiKey = Configuration["ArcGISApiKey"] ?? string.Empty;
        _hasApiKey = !string.IsNullOrWhiteSpace(_apiKey);
        _viewReady = !_hasApiKey;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadOnboardingPreferenceAsync();

            GeolocationService.PositionChanged += OnPositionChanged;
            MapState.StateChanged += OnMapStateChanged;
            _subscriptionsActive = true;

            try
            {
                await GeolocationService.StartWatchAsync();
            }
            catch
            {
                _statusMessage = "GPS unavailable. Showing pitches near London.";
                StateHasChanged();
            }
        }
    }

    private async Task OnViewInitializedAsync()
    {
        _viewReady = true;
        Logger.LogInformation("MapView initialized, loading pitches near London");

        await RefreshAuthenticationStateAsync();
        await LoadPitchMarkersAsync(_latitude, _longitude);
        await RefreshGameProgress();
    }

    private async void OnPositionChanged(GeoPosition pos)
    {
        try
        {
            _lastKnownPosition = pos;
            if (_statusMessage is not null
                && (_statusMessage.StartsWith("GPS", StringComparison.OrdinalIgnoreCase)
                    || _statusMessage.StartsWith("Waiting for GPS", StringComparison.OrdinalIgnoreCase)))
            {
                _statusMessage = null;
            }

            if (!_initialCenterPerformed)
            {
                _initialCenterPerformed = true;
                _latitude = pos.Latitude;
                _longitude = pos.Longitude;
            }

            if (ShouldRefreshPitches(pos))
            {
                await LoadPitchMarkersAsync(pos.Latitude, pos.Longitude);
            }

            if (_isAuthenticated)
            {
                await SignalRClient.UpdateLocationAsync(pos.Latitude, pos.Longitude);
            }

            UpdateRecruitEligibility();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in position change handler");
        }
    }

    private void OnMapStateChanged(object? sender, EventArgs e)
    {
        var state = ((IState<MapState>)sender!).Value;
        if (state.SelectedPitchId.HasValue && state.SelectedPitchId.Value != _lastSelectedPitchId)
        {
            _lastSelectedPitchId = state.SelectedPitchId.Value;
            _selectedPitch = state.VisiblePitches.FirstOrDefault(p => p.Id == state.SelectedPitchId.Value);
            _ = InvokeAsync(StateHasChanged);
        }
        else if (!state.SelectedPitchId.HasValue && _selectedPitch is not null)
        {
            _lastSelectedPitchId = -1;
            _selectedPitch = null;
            _ = InvokeAsync(StateHasChanged);
        }

        if (state.SelectedEncounterId.HasValue)
        {
            _selectedEncounter = state.VisibleEncounters.FirstOrDefault(e => e.EncounterId == state.SelectedEncounterId.Value);
            UpdateRecruitEligibility();
        }
        else if (_selectedEncounter is not null)
        {
            _selectedEncounter = null;
            _canRecruit = false;
            _recruitBlockedReason = "Select a recruitable player.";
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadPitchMarkersAsync(double lat, double lng)
    {
        if (!_viewReady || _mapView is null)
            return;

        try
        {
            var pitches = await ApiClient.GetNearbyPitchesAsync(lat, lng, BrowseRadiusMeters);
            Dispatcher.Dispatch(new SetPitchesAction(pitches.AsReadOnly()));
            await UpdatePitchGraphicsAsync(pitches);

            var encounters = new List<PlayerEncounterDto>();
            if (_isAuthenticated)
            {
                encounters = await ApiClient.GetEncountersAsync(lat, lng, EncounterBrowseRadiusMeters);
                _statusMessage = encounters.Count == 0
                    ? "No recruitable players nearby. Head to a real-world park to find players."
                    : null;
            }
            else
            {
                _statusMessage = "Log in to discover recruitable players at nearby real-world parks.";
            }

            Dispatcher.Dispatch(new SetEncountersAction(encounters.AsReadOnly()));
            await UpdateEncounterGraphicsAsync(encounters);

            _lastPitchFetchPosition = new GeoPosition { Latitude = lat, Longitude = lng };
            _lastPitchFetchAtUtc = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load pitch markers");
            _statusMessage = "Failed to load pitches. Map is still usable.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task UpdatePitchGraphicsAsync(List<PitchModel> pitches)
    {
        if (_mapView is null) return;

        foreach (var old in _pitchGraphics.Values)
        {
            try { await _mapView.RemoveGraphic(old); }
            catch (Exception ex) { Logger.LogDebug(ex, "Failed to remove old graphic"); }
        }
        _pitchGraphics.Clear();

        foreach (var pitch in pitches)
        {
            var graphic = new Graphic(
                geometry: new Point(longitude: pitch.Longitude, latitude: pitch.Latitude),
                symbol: GetPitchSymbol(pitch.Type),
                attributes: new AttributesDictionary(new Dictionary<string, object?>
                {
                    ["_ruckrType"] = "pitch",
                    ["_ruckrId"] = pitch.Id,
                    ["name"] = pitch.Name,
                    ["pitchType"] = PitchTypeDisplayName(pitch.Type),
                    ["pitchRole"] = PitchTypeDescription(pitch.Type)
                })
            );

            try
            {
                await _mapView.AddGraphic(graphic);
                _pitchGraphics[pitch.Id] = graphic;
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to add graphic for pitch {PitchId}", pitch.Id);
            }
        }
    }

    private async Task UpdateEncounterGraphicsAsync(IReadOnlyList<PlayerEncounterDto> encounters)
    {
        if (_mapView is null) return;

        foreach (var old in _encounterGraphics.Values)
        {
            try { await _mapView.RemoveGraphic(old); }
            catch (Exception ex) { Logger.LogDebug(ex, "Failed to remove old encounter graphic"); }
        }
        _encounterGraphics.Clear();

        foreach (var encounter in encounters)
        {
            var symbol = new SimpleMarkerSymbol(
                outline: new Outline(color: new MapColor("#FFFFFF"), width: new Dimension(2)),
                color: EncounterRarityColor(encounter.Rarity),
                size: new Dimension(14),
                style: SimpleMarkerSymbolStyle.Circle);

            var graphic = new Graphic(
                geometry: new Point(longitude: encounter.Longitude, latitude: encounter.Latitude),
                symbol: symbol,
                attributes: new AttributesDictionary(new Dictionary<string, object?>
                {
                    ["_ruckrType"] = "encounter",
                    ["_ruckrEncounterId"] = encounter.EncounterId.ToString(),
                    ["name"] = encounter.Name,
                    ["rarity"] = encounter.Rarity,
                    ["level"] = encounter.Level,
                    ["parkName"] = encounter.ParkName
                })
            );

            try
            {
                await _mapView.AddGraphic(graphic);
                _encounterGraphics[encounter.EncounterId] = graphic;
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to add graphic for encounter {EncounterId}", encounter.EncounterId);
            }
        }
    }

    private static MapColor EncounterRarityColor(string rarity) => rarity switch
    {
        "Uncommon" => new MapColor(47, 133, 90),
        "Rare" => new MapColor(37, 99, 235),
        "Epic" => new MapColor(217, 119, 6),
        "Legendary" => new MapColor(200, 30, 30),
        _ => new MapColor(107, 114, 128)
    };

    private async Task HandleMapClick(ClickEvent clickEvent)
    {
        if (clickEvent?.MapPoint is null || _mapView is null)
            return;

        try
        {
            var hitResult = await _mapView.HitTest(clickEvent);
            foreach (var hit in hitResult.Results)
            {
                if (hit is GraphicHit graphicHit)
                {
                    var attrs = graphicHit.Graphic.Attributes;
                    if (attrs.TryGetValue("_ruckrType", out var type))
                    {
                        if (type?.ToString() == "pitch")
                        {
                            if (attrs.TryGetValue("_ruckrId", out var idObj) && idObj is int pitchId)
                            {
                                Dispatcher.Dispatch(new SelectPitchAction(pitchId));
                                return;
                            }
                        }
                        else if (type?.ToString() == "encounter")
                        {
                            if (attrs.TryGetValue("_ruckrEncounterId", out var encIdObj) && Guid.TryParse(encIdObj?.ToString(), out var encounterId))
                            {
                                var encounter = MapState.Value.VisibleEncounters.FirstOrDefault(e => e.EncounterId == encounterId);
                                if (encounter is not null)
                                {
                                    _selectedEncounter = encounter;
                                    UpdateRecruitEligibility();
                                    _recruitMessage = null;
                                    Dispatcher.Dispatch(new SelectEncounterAction(encounterId));
                                    return;
                                }
                            }
                        }
                    }
                }
            }

            Dispatcher.Dispatch(new ClearSelectionAction());
            _statusMessage = $"Clicked: {clickEvent.MapPoint.Latitude:F5}, {clickEvent.MapPoint.Longitude:F5}";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Map click hit-test failed");
            _statusMessage = $"Clicked: {clickEvent.MapPoint.Latitude:F5}, {clickEvent.MapPoint.Longitude:F5}";
            StateHasChanged();
        }
    }

    private void ClearSelection()
    {
        Dispatcher.Dispatch(new ClearSelectionAction());
    }

    private void DismissOnboarding()
    {
        _showOnboarding = false;
        _ = PersistOnboardingDismissalAsync();
    }

    private async Task LoadOnboardingPreferenceAsync()
    {
        try
        {
            var onboarded = await JS.InvokeAsync<string?>("localStorage.getItem", "ruckr_onboarded");
            _showOnboarding = onboarded != "true";
        }
        catch
        {
            _showOnboarding = true;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task PersistOnboardingDismissalAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "ruckr_onboarded", "true");
        }
        catch
        {
            // Browser storage can be unavailable in private or test contexts.
        }
    }

    private void ClearEncounterSelection()
    {
        _selectedEncounter = null;
        Dispatcher.Dispatch(new ClearSelectionAction());
    }

    private void DismissRecruitToast()
    {
        _recruitToastMessage = null;
    }

    private bool ShouldShowGpsNotice =>
        _hasApiKey
        && (_lastKnownPosition is null || _lastKnownPosition.Accuracy is > MaxRecruitAccuracyMeters);

    private string GpsNoticeTitle =>
        _lastKnownPosition is null
            ? "GPS needed"
            : "GPS accuracy low";

    private string GpsNoticeBody
    {
        get
        {
            if (_lastKnownPosition is null)
            {
                return "The map is visible, but encounters, distance checks, and recruiting unlock after location access starts.";
            }

            return $"Recruiting needs GPS accuracy within {MaxRecruitAccuracyMeters:0} m. Current accuracy is about {_lastKnownPosition.Accuracy!.Value:0} m.";
        }
    }

    private async Task EnableGpsAsync()
    {
        try
        {
            _statusMessage = "Waiting for GPS...";
            await GeolocationService.StartWatchAsync();
        }
        catch
        {
            _statusMessage = "GPS is blocked or unavailable. Enable location permission in your browser to recruit players.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private static string EncounterRarityBadgeClass(string rarity) => rarity switch
    {
        "Common" => "secondary",
        "Uncommon" => "success",
        "Rare" => "primary",
        "Epic" => "warning",
        "Legendary" => "danger",
        _ => "secondary"
    };

    private string DistanceBucketFromPosition(double lat, double lng)
    {
        if (_lastKnownPosition is null) return "unknown";
        var d = GeoPosition.HaversineDistance(_lastKnownPosition!, new GeoPosition { Latitude = lat, Longitude = lng });
        return d < 50 ? "<50m" : d < 100 ? "<100m" : d < 250 ? "<250m" : d < 500 ? "<500m" : ">500m";
    }

    private PlayerEncounterDto? NearestEncounter => MapState.Value.VisibleEncounters
        .OrderBy(e => EncounterDistanceMeters(e) ?? double.MaxValue)
        .ThenBy(e => e.ExpiresAtUtc)
        .FirstOrDefault();

    private async Task SelectEncounterAsync(PlayerEncounterDto? encounter)
    {
        if (encounter is null)
        {
            return;
        }

        _selectedEncounter = encounter;
        _recruitMessage = null;
        UpdateRecruitEligibility();
        Dispatcher.Dispatch(new SelectEncounterAction(encounter.EncounterId));

        if (_mapView is not null)
        {
            try
            {
                await _mapView.SetCenter(new Point(longitude: encounter.Longitude, latitude: encounter.Latitude));
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Failed to center on selected encounter");
            }
        }
    }

    private double? EncounterDistanceMeters(PlayerEncounterDto encounter)
    {
        if (_lastKnownPosition is null)
        {
            return null;
        }

        return GeoPosition.HaversineDistance(
            _lastKnownPosition,
            new GeoPosition { Latitude = encounter.Latitude, Longitude = encounter.Longitude });
    }

    private string EncounterDistanceText(PlayerEncounterDto encounter)
    {
        var distance = EncounterDistanceMeters(encounter);
        return distance.HasValue ? FormatDistance(distance.Value) : "GPS pending";
    }

    private string EncounterRouteInstruction(PlayerEncounterDto encounter)
    {
        var distance = EncounterDistanceMeters(encounter);
        if (!distance.HasValue)
        {
            return $"Enable GPS and head to {EncounterParkName(encounter)}.";
        }

        if (_lastKnownPosition?.Accuracy is > MaxRecruitAccuracyMeters)
        {
            return $"Hold for better GPS accuracy. Current: {_lastKnownPosition.Accuracy.Value:0} m.";
        }

        return distance.Value <= RecruitDistanceMeters
            ? "In range. Make the recruit attempt."
            : $"Move within {RecruitDistanceMeters:0} m of the park.";
    }

    private static string EncounterExpiresText(PlayerEncounterDto encounter)
    {
        var remaining = encounter.ExpiresAtUtc - DateTime.UtcNow;
        if (remaining <= TimeSpan.Zero)
        {
            return "Expired";
        }

        if (remaining.TotalMinutes < 1)
        {
            return "<1 min left";
        }

        return remaining.TotalHours >= 1
            ? $"{(int)remaining.TotalHours}h {remaining.Minutes}m left"
            : $"{(int)Math.Ceiling(remaining.TotalMinutes)}m left";
    }

    private void UpdateRecruitEligibility()
    {
        _canRecruit = false;

        if (_selectedEncounter is null)
        {
            _recruitBlockedReason = "Select a recruitable player.";
            return;
        }

        var parkName = EncounterParkName(_selectedEncounter);
        if (_lastKnownPosition is null)
        {
            _recruitBlockedReason = $"Waiting for GPS. Go to {parkName} to recruit.";
            return;
        }

        var distanceMeters = GeoPosition.HaversineDistance(
            _lastKnownPosition,
            new GeoPosition { Latitude = _selectedEncounter.Latitude, Longitude = _selectedEncounter.Longitude });

        if (_lastKnownPosition.Accuracy.HasValue && _lastKnownPosition.Accuracy.Value > MaxRecruitAccuracyMeters)
        {
            _recruitBlockedReason =
                $"Improve GPS accuracy to {MaxRecruitAccuracyMeters:0}m or better. Current accuracy: {_lastKnownPosition.Accuracy.Value:0}m.";
            return;
        }

        if (distanceMeters > RecruitDistanceMeters)
        {
            _recruitBlockedReason = $"Go to {parkName} to recruit. You are about {FormatDistance(distanceMeters)} away.";
            return;
        }

        _canRecruit = true;
        _recruitBlockedReason = $"Ready to recruit at {parkName}.";
    }

    private string RecruitButtonClass()
    {
        if (!_canRecruit) return "secondary";
        return "success";
    }

    private static string FormatDistance(double distanceMeters)
    {
        return distanceMeters < 1000
            ? $"{Math.Round(distanceMeters)} m"
            : $"{distanceMeters / 1000:0.0} km";
    }

    private static string EncounterParkName(PlayerEncounterDto encounter)
    {
        return string.IsNullOrWhiteSpace(encounter.ParkName)
            ? "this park"
            : encounter.ParkName;
    }

    private async Task AttemptRecruitment()
    {
        if (_selectedEncounter is null || _isRecruiting) return;

        _isRecruiting = true;
        _recruitMessage = null;
        StateHasChanged();

        try
        {
            var result = await ApiClient.AttemptRecruitmentAsync(_selectedEncounter.EncounterId, _selectedEncounter.PlayerId);
            if (result is null)
            {
                _recruitMessage = "Recruitment failed. Please try again.";
                _recruitMessageClass = "danger";
            }
            else if (result.Success)
            {
                _recruitMessage = result.Message;
                _recruitMessageClass = "success";
                _recruitToastMessage = $"{result.Message} +25 XP";
                _recruitToastClass = "success";
                await RefreshGameProgress();
                await LoadPitchMarkersAsync(_lastKnownPosition?.Latitude ?? _latitude, _lastKnownPosition?.Longitude ?? _longitude);
                Dispatcher.Dispatch(new ClearSelectionAction());
            }
            else
            {
                _recruitMessage = result.Message;
                _recruitMessageClass = "danger";
                _recruitToastMessage = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Recruitment attempt failed");
            _recruitMessage = "Recruitment failed. Please try again.";
            _recruitMessageClass = "danger";
            _recruitToastMessage = "Recruitment failed. Please try again.";
            _recruitToastClass = "danger";
        }
        finally
        {
            _isRecruiting = false;
            StateHasChanged();
        }
    }

    private double ProgressPercent => _gameProgress is null || _prevLevelXp >= _gameProgress.NextLevelExperience
        ? 0
        : Math.Clamp((double)(_gameProgress.Experience - _prevLevelXp) / (_gameProgress.NextLevelExperience - _prevLevelXp) * 100, 0, 100);

    private async Task RefreshGameProgress()
    {
        await RefreshAuthenticationStateAsync();
        _gameProgress = _isAuthenticated
            ? await ApiClient.GetGameProgressAsync()
            : null;
        _prevLevelXp = _gameProgress is null ? 0 : _gameProgress.Level <= 1 ? 0 : (_gameProgress.Level - 1) * 100;
    }

    private async Task RefreshAuthenticationStateAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
    }

    private int LevelForXp(int xp) => Math.Clamp(1 + (xp / 100), 1, 100);

    private async Task CenterOnNearestPitchByTypeAsync(PitchType? filterType = null)
    {
        if (_mapView is null || _pitchGraphics.Count == 0)
            return;

        var currentLat = _lastKnownPosition?.Latitude ?? _latitude;
        var currentLng = _lastKnownPosition?.Longitude ?? _longitude;

        var candidates = filterType.HasValue
            ? MapState.Value.VisiblePitches.Where(p => p.Type == filterType.Value)
            : MapState.Value.VisiblePitches;

        var nearest = candidates
            .OrderBy(p => GeoPosition.HaversineDistance(
                new GeoPosition { Latitude = currentLat, Longitude = currentLng },
                new GeoPosition { Latitude = p.Latitude, Longitude = p.Longitude }))
            .FirstOrDefault();

        if (nearest is null)
            return;

        try
        {
            await _mapView.SetCenter(new Point(longitude: nearest.Longitude, latitude: nearest.Latitude));
            Dispatcher.Dispatch(new SelectPitchAction(nearest.Id));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to center on nearest pitch");
        }
    }

    private bool ShouldRefreshPitches(GeoPosition current)
    {
        if (_lastPitchFetchPosition is null) return true;
        if ((DateTime.UtcNow - _lastPitchFetchAtUtc) >= PitchRefreshInterval) return true;

        var moved = GeoPosition.HaversineDistance(_lastPitchFetchPosition, current);
        return moved >= MinPitchRefreshDistanceMeters;
    }

    private int PitchCount(PitchType type)
    {
        return MapState.Value.VisiblePitches.Count(p => p.Type == type);
    }

    private string PitchDistanceText(PitchModel pitch)
    {
        if (_lastKnownPosition is null)
        {
            return "Distance unknown";
        }

        var distanceMeters = GeoPosition.HaversineDistance(
            _lastKnownPosition,
            new GeoPosition { Latitude = pitch.Latitude, Longitude = pitch.Longitude });

        return distanceMeters < 1000
            ? $"{Math.Round(distanceMeters)} m away"
            : $"{distanceMeters / 1000:0.0} km away";
    }

    private static string PitchTypeDisplayName(PitchType type) => type switch
    {
        PitchType.Stadium => "Stadium",
        PitchType.Standard => "Standard pitch",
        PitchType.Training => "Training pitch",
        _ => "Pitch"
    };

    private static string PitchTypeDescription(PitchType type) => type switch
    {
        PitchType.Stadium => "Major venue",
        PitchType.Standard => "Match-ready",
        PitchType.Training => "Practice ground",
        _ => "Rugby location"
    };

    private static string PitchTypeCssClass(PitchType type) => type switch
    {
        PitchType.Stadium => "stadium",
        PitchType.Standard => "standard",
        PitchType.Training => "training",
        _ => "standard"
    };

