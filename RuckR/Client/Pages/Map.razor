@code {
    private MapView? _mapView;
    private string _apiKey = string.Empty;
    private bool _hasApiKey;
    private double _latitude = 51.5074;
    private double _longitude = -0.1278;
    private int _zoom = 13;
    private string? _statusMessage;
    private bool _viewReady;
    private bool _subscriptionsActive;
    private bool _initialCenterPerformed;
    private GeoPosition? _lastKnownPosition;
    private GeoPosition? _lastPitchFetchPosition;
    private DateTime _lastPitchFetchAtUtc = DateTime.MinValue;

    private const double EncounterBrowseRadiusMeters = 5000.0;
    private const double RecruitDistanceMeters = 75.0;
    private const double MaxRecruitAccuracyMeters = 50.0;

    private const double BrowseRadiusMeters = 5000.0;
    private const double MinPitchRefreshDistanceMeters = 50.0;
    private static readonly TimeSpan PitchRefreshInterval = TimeSpan.FromSeconds(30);

    private readonly Dictionary<int, Graphic> _pitchGraphics = new();
    private readonly Dictionary<Guid, Graphic> _encounterGraphics = new();
    private PitchModel? _selectedPitch;
    private int _lastSelectedPitchId = -1;
    private PlayerEncounterDto? _selectedEncounter;
    private GameProgressDto? _gameProgress;
    private int _prevLevelXp;
    private bool _canRecruit;
    private bool _isRecruiting;
    private bool _isAuthenticated;
    private string _recruitBlockedReason = "Go to the park to recruit.";
    private string? _recruitMessage;
    private string _recruitMessageClass = "success";
    private bool _showOnboarding = true;

    protected override void OnInitialized()
    {
        _apiKey = Configuration["ArcGISApiKey"] ?? string.Empty;
        _hasApiKey = !string.IsNullOrWhiteSpace(_apiKey);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            GeolocationService.PositionChanged += OnPositionChanged;
            MapState.StateChanged += OnMapStateChanged;
            _subscriptionsActive = true;

            try
            {
                await GeolocationService.StartWatchAsync();
            }
            catch
            {
                _statusMessage = "GPS unavailable. Showing pitches near London.";
                StateHasChanged();
            }
        }
    }

    private async Task OnViewInitializedAsync()
    {
        _viewReady = true;
        Logger.LogInformation("MapView initialized, loading pitches near London");

        await RefreshAuthenticationStateAsync();
        await LoadPitchMarkersAsync(_latitude, _longitude);
        await RefreshGameProgress();
    }

    private async void OnPositionChanged(GeoPosition pos)
    {
        try
        {
            _lastKnownPosition = pos;

            if (!_initialCenterPerformed)
            {
                _initialCenterPerformed = true;
                _latitude = pos.Latitude;
                _longitude = pos.Longitude;
            }

            if (ShouldRefreshPitches(pos))
            {
                await LoadPitchMarkersAsync(pos.Latitude, pos.Longitude);
            }

            UpdateRecruitEligibility();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in position change handler");
        }
    }

    private void OnMapStateChanged(object? sender, EventArgs e)
    {
        var state = ((IState<MapState>)sender!).Value;
        if (state.SelectedPitchId.HasValue && state.SelectedPitchId.Value != _lastSelectedPitchId)
        {
            _lastSelectedPitchId = state.SelectedPitchId.Value;
            _selectedPitch = state.VisiblePitches.FirstOrDefault(p => p.Id == state.SelectedPitchId.Value);
            _ = InvokeAsync(StateHasChanged);
        }
        else if (!state.SelectedPitchId.HasValue && _selectedPitch is not null)
        {
            _lastSelectedPitchId = -1;
            _selectedPitch = null;
            _ = InvokeAsync(StateHasChanged);
        }

        if (state.SelectedEncounterId.HasValue)
        {
            _selectedEncounter = state.VisibleEncounters.FirstOrDefault(e => e.EncounterId == state.SelectedEncounterId.Value);
            UpdateRecruitEligibility();
        }
        else if (_selectedEncounter is not null)
        {
            _selectedEncounter = null;
            _canRecruit = false;
            _recruitBlockedReason = "Select a recruitable player.";
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadPitchMarkersAsync(double lat, double lng)
    {
        if (!_viewReady || _mapView is null)
            return;

        try
        {
            var pitches = await ApiClient.GetNearbyPitchesAsync(lat, lng, BrowseRadiusMeters);
            Dispatcher.Dispatch(new SetPitchesAction(pitches.AsReadOnly()));
            await UpdatePitchGraphicsAsync(pitches);

            var encounters = new List<PlayerEncounterDto>();
            if (_isAuthenticated)
            {
                encounters = await ApiClient.GetEncountersAsync(lat, lng, EncounterBrowseRadiusMeters);
                _statusMessage = encounters.Count == 0
                    ? "No recruitable players nearby. Head to a real-world park to find players."
                    : null;
            }
            else
            {
                _statusMessage = "Log in to discover recruitable players at nearby real-world parks.";
            }

            Dispatcher.Dispatch(new SetEncountersAction(encounters.AsReadOnly()));
            await UpdateEncounterGraphicsAsync(encounters);

            _lastPitchFetchPosition = new GeoPosition { Latitude = lat, Longitude = lng };
            _lastPitchFetchAtUtc = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load pitch markers");
            _statusMessage = "Failed to load pitches. Map is still usable.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task UpdatePitchGraphicsAsync(List<PitchModel> pitches)
    {
        if (_mapView is null) return;

        foreach (var old in _pitchGraphics.Values)
        {
            try { await _mapView.RemoveGraphic(old); }
            catch (Exception ex) { Logger.LogDebug(ex, "Failed to remove old graphic"); }
        }
        _pitchGraphics.Clear();

        foreach (var pitch in pitches)
        {
            var graphic = new Graphic(
                geometry: new Point(longitude: pitch.Longitude, latitude: pitch.Latitude),
                symbol: GetPitchSymbol(pitch.Type),
                attributes: new AttributesDictionary(new Dictionary<string, object?>
                {
                    ["_ruckrType"] = "pitch",
                    ["_ruckrId"] = pitch.Id,
                    ["name"] = pitch.Name,
                    ["pitchType"] = PitchTypeDisplayName(pitch.Type),
                    ["pitchRole"] = PitchTypeDescription(pitch.Type)
                })
            );

            try
            {
                await _mapView.AddGraphic(graphic);
                _pitchGraphics[pitch.Id] = graphic;
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to add graphic for pitch {PitchId}", pitch.Id);
            }
        }
    }

    private async Task UpdateEncounterGraphicsAsync(IReadOnlyList<PlayerEncounterDto> encounters)
    {
        if (_mapView is null) return;

        foreach (var old in _encounterGraphics.Values)
        {
            try { await _mapView.RemoveGraphic(old); }
            catch (Exception ex) { Logger.LogDebug(ex, "Failed to remove old encounter graphic"); }
        }
        _encounterGraphics.Clear();

        foreach (var encounter in encounters)
        {
            var symbol = new SimpleMarkerSymbol(
                outline: new Outline(color: new MapColor("#FFFFFF"), width: new Dimension(2)),
                color: EncounterRarityColor(encounter.Rarity),
                size: new Dimension(14),
                style: SimpleMarkerSymbolStyle.Circle);

            var graphic = new Graphic(
                geometry: new Point(longitude: encounter.Longitude, latitude: encounter.Latitude),
                symbol: symbol,
                attributes: new AttributesDictionary(new Dictionary<string, object?>
                {
                    ["_ruckrType"] = "encounter",
                    ["_ruckrEncounterId"] = encounter.EncounterId.ToString(),
                    ["name"] = encounter.Name,
                    ["rarity"] = encounter.Rarity,
                    ["level"] = encounter.Level,
                    ["parkName"] = encounter.ParkName
                })
            );

            try
            {
                await _mapView.AddGraphic(graphic);
                _encounterGraphics[encounter.EncounterId] = graphic;
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to add graphic for encounter {EncounterId}", encounter.EncounterId);
            }
        }
    }

    private static MapColor EncounterRarityColor(string rarity) => rarity switch
    {
        "Uncommon" => new MapColor(47, 133, 90),
        "Rare" => new MapColor(37, 99, 235),
        "Epic" => new MapColor(217, 119, 6),
        "Legendary" => new MapColor(200, 30, 30),
        _ => new MapColor(107, 114, 128)
    };

    private async Task HandleMapClick(ClickEvent clickEvent)
    {
        if (clickEvent?.MapPoint is null || _mapView is null)
            return;

        try
        {
            var hitResult = await _mapView.HitTest(clickEvent);
            foreach (var hit in hitResult.Results)
            {
                if (hit is GraphicHit graphicHit)
                {
                    var attrs = graphicHit.Graphic.Attributes;
                    if (attrs.TryGetValue("_ruckrType", out var type))
                    {
                        if (type?.ToString() == "pitch")
                        {
                            if (attrs.TryGetValue("_ruckrId", out var idObj) && idObj is int pitchId)
                            {
                                Dispatcher.Dispatch(new SelectPitchAction(pitchId));
                                return;
                            }
                        }
                        else if (type?.ToString() == "encounter")
                        {
                            if (attrs.TryGetValue("_ruckrEncounterId", out var encIdObj) && Guid.TryParse(encIdObj?.ToString(), out var encounterId))
                            {
                                var encounter = MapState.Value.VisibleEncounters.FirstOrDefault(e => e.EncounterId == encounterId);
                                if (encounter is not null)
                                {
                                    _selectedEncounter = encounter;
                                    UpdateRecruitEligibility();
                                    _recruitMessage = null;
                                    Dispatcher.Dispatch(new SelectEncounterAction(encounterId));
                                    return;
                                }
                            }
                        }
                    }
                }
            }

            Dispatcher.Dispatch(new ClearSelectionAction());
            _statusMessage = $"Clicked: {clickEvent.MapPoint.Latitude:F5}, {clickEvent.MapPoint.Longitude:F5}";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Map click hit-test failed");
            _statusMessage = $"Clicked: {clickEvent.MapPoint.Latitude:F5}, {clickEvent.MapPoint.Longitude:F5}";
            StateHasChanged();
        }
    }

    private void ClearSelection()
    {
        Dispatcher.Dispatch(new ClearSelectionAction());
    }

    private void DismissOnboarding()
    {
        _showOnboarding = false;
    }

    private void ClearEncounterSelection()
    {
        _selectedEncounter = null;
        Dispatcher.Dispatch(new ClearSelectionAction());
    }

    private static string EncounterRarityBadgeClass(string rarity) => rarity switch
    {
        "Common" => "secondary",
        "Uncommon" => "success",
        "Rare" => "primary",
        "Epic" => "warning",
        "Legendary" => "danger",
        _ => "secondary"
    };

    private string DistanceBucketFromPosition(double lat, double lng)
    {
        if (_lastKnownPosition is null) return "unknown";
        var d = GeoPosition.HaversineDistance(_lastKnownPosition!, new GeoPosition { Latitude = lat, Longitude = lng });
        return d < 50 ? "<50m" : d < 100 ? "<100m" : d < 250 ? "<250m" : d < 500 ? "<500m" : ">500m";
    }

    private void UpdateRecruitEligibility()
    {
        _canRecruit = false;

        if (_selectedEncounter is null)
        {
            _recruitBlockedReason = "Select a recruitable player.";
            return;
        }

        var parkName = EncounterParkName(_selectedEncounter);
        if (_lastKnownPosition is null)
        {
            _recruitBlockedReason = $"Waiting for GPS. Go to {parkName} to recruit.";
            return;
        }

        var distanceMeters = GeoPosition.HaversineDistance(
            _lastKnownPosition,
            new GeoPosition { Latitude = _selectedEncounter.Latitude, Longitude = _selectedEncounter.Longitude });

        if (_lastKnownPosition.Accuracy.HasValue && _lastKnownPosition.Accuracy.Value > MaxRecruitAccuracyMeters)
        {
            _recruitBlockedReason =
                $"Improve GPS accuracy to {MaxRecruitAccuracyMeters:0}m or better. Current accuracy: {_lastKnownPosition.Accuracy.Value:0}m.";
            return;
        }

        if (distanceMeters > RecruitDistanceMeters)
        {
            _recruitBlockedReason = $"Go to {parkName} to recruit. You are about {FormatDistance(distanceMeters)} away.";
            return;
        }

        _canRecruit = true;
        _recruitBlockedReason = $"Ready to recruit at {parkName}.";
    }

    private string RecruitButtonClass()
    {
        if (!_canRecruit) return "secondary";
        return "success";
    }

    private static string FormatDistance(double distanceMeters)
    {
        return distanceMeters < 1000
            ? $"{Math.Round(distanceMeters)} m"
            : $"{distanceMeters / 1000:0.0} km";
    }

    private static string EncounterParkName(PlayerEncounterDto encounter)
    {
        return string.IsNullOrWhiteSpace(encounter.ParkName)
            ? "this park"
            : encounter.ParkName;
    }

    private async Task AttemptRecruitment()
    {
        if (_selectedEncounter is null || _isRecruiting) return;

        _isRecruiting = true;
        _recruitMessage = null;
        StateHasChanged();

        try
        {
            var result = await ApiClient.AttemptRecruitmentAsync(_selectedEncounter.EncounterId, _selectedEncounter.PlayerId);
            if (result is null)
            {
                _recruitMessage = "Recruitment failed. Please try again.";
                _recruitMessageClass = "danger";
            }
            else if (result.Success)
            {
                _recruitMessage = result.Message;
                _recruitMessageClass = "success";
                await RefreshGameProgress();
                await LoadPitchMarkersAsync(_lastKnownPosition?.Latitude ?? _latitude, _lastKnownPosition?.Longitude ?? _longitude);
            }
            else
            {
                _recruitMessage = result.Message;
                _recruitMessageClass = "danger";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Recruitment attempt failed");
            _recruitMessage = "Recruitment failed. Please try again.";
            _recruitMessageClass = "danger";
        }
        finally
        {
            _isRecruiting = false;
            StateHasChanged();
        }
    }

    private double ProgressPercent => _gameProgress is null || _prevLevelXp >= _gameProgress.NextLevelExperience
        ? 0
        : Math.Clamp((double)(_gameProgress.Experience - _prevLevelXp) / (_gameProgress.NextLevelExperience - _prevLevelXp) * 100, 0, 100);

    private async Task RefreshGameProgress()
    {
        await RefreshAuthenticationStateAsync();
        _gameProgress = _isAuthenticated
            ? await ApiClient.GetGameProgressAsync()
            : null;
        _prevLevelXp = _gameProgress is null ? 0 : _gameProgress.Level <= 1 ? 0 : (_gameProgress.Level - 1) * 100;
    }

    private async Task RefreshAuthenticationStateAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
    }

    private int LevelForXp(int xp) => Math.Clamp(1 + (xp / 100), 1, 100);

    private async Task CenterOnNearestPitchByTypeAsync(PitchType? filterType = null)
    {
        if (_mapView is null || _pitchGraphics.Count == 0)
            return;

        var currentLat = _lastKnownPosition?.Latitude ?? _latitude;
        var currentLng = _lastKnownPosition?.Longitude ?? _longitude;

        var candidates = filterType.HasValue
            ? MapState.Value.VisiblePitches.Where(p => p.Type == filterType.Value)
            : MapState.Value.VisiblePitches;

        var nearest = candidates
            .OrderBy(p => GeoPosition.HaversineDistance(
                new GeoPosition { Latitude = currentLat, Longitude = currentLng },
                new GeoPosition { Latitude = p.Latitude, Longitude = p.Longitude }))
            .FirstOrDefault();

        if (nearest is null)
            return;

        try
        {
            await _mapView.SetCenter(new Point(longitude: nearest.Longitude, latitude: nearest.Latitude));
            Dispatcher.Dispatch(new SelectPitchAction(nearest.Id));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to center on nearest pitch");
        }
    }

    private bool ShouldRefreshPitches(GeoPosition current)
    {
        if (_lastPitchFetchPosition is null) return true;
        if ((DateTime.UtcNow - _lastPitchFetchAtUtc) >= PitchRefreshInterval) return true;

        var moved = GeoPosition.HaversineDistance(_lastPitchFetchPosition, current);
        return moved >= MinPitchRefreshDistanceMeters;
    }

    private int PitchCount(PitchType type)
    {
        return MapState.Value.VisiblePitches.Count(p => p.Type == type);
    }

    private string PitchDistanceText(PitchModel pitch)
    {
        if (_lastKnownPosition is null)
        {
            return "Distance unknown";
        }

        var distanceMeters = GeoPosition.HaversineDistance(
            _lastKnownPosition,
            new GeoPosition { Latitude = pitch.Latitude, Longitude = pitch.Longitude });

        return distanceMeters < 1000
            ? $"{Math.Round(distanceMeters)} m away"
            : $"{distanceMeters / 1000:0.0} km away";
    }

