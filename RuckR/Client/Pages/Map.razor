@page "/map"
@page "/"
@using dymaptic.GeoBlazor.Core.Components
@using dymaptic.GeoBlazor.Core.Components.Geometries
@using dymaptic.GeoBlazor.Core.Components.Symbols
@using dymaptic.GeoBlazor.Core.Components.Views
@using dymaptic.GeoBlazor.Core.Components.Widgets
@using dymaptic.GeoBlazor.Core.Enums
@using dymaptic.GeoBlazor.Core.Events
@using dymaptic.GeoBlazor.Core.Model
@using Fluxor
@using RuckR.Client.Services
@using RuckR.Client.Store.MapFeature
@using RuckR.Client.Store.LocationFeature
@using RuckR.Shared.Models
@inject IConfiguration Configuration
@inject ILogger<Map> Logger
@inject IGeolocationService GeolocationService
@inject ApiClientService ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject IDispatcher Dispatcher
@inject IState<MapState> MapState
@inject IState<LocationState> LocationState
@implements IAsyncDisposable

<div class="map-shell" data-testid="map-container">
    @if (!_hasApiKey)
    {
        <div class="map-unavailable-shell">
            <div class="map-unavailable-panel">
                <p class="mb-1 fw-bold">Map unavailable</p>
                <p class="small text-muted mb-0">
                    ArcGIS API key is not configured. Set the <code>ARC_GIS_API_KEY</code> environment variable.
                </p>
            </div>
        </div>
    }

    <div data-testid="map-loading" class="map-loading" style="@(_viewReady ? "display:none" : "")">
        <div class="spinner-border text-light" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    @if (_hasApiKey)
    {
        <MapView @ref="_mapView"
                 Latitude="@_latitude"
                 Longitude="@_longitude"
                 Zoom="@_zoom"
                 OnClick="HandleMapClick"
                 OnViewInitialized="OnViewInitializedAsync"
                 ShowZoomWidget="true"
                 style="width:100%; height:100%;">
            <dymaptic.GeoBlazor.Core.Components.Map>
                <Basemap>
                    <BasemapStyle Name="@BasemapStyleName.ArcgisNavigation" ApiKey="@_apiKey" />
                </Basemap>
            </dymaptic.GeoBlazor.Core.Components.Map>
            <HomeWidget Position="OverlayPosition.TopLeft" />
            <CompassWidget Position="OverlayPosition.TopLeft" />
            <LocateWidget Position="OverlayPosition.TopLeft" />
            <ScaleBarWidget Position="OverlayPosition.BottomLeft" />
        </MapView>
        <div class="map-fab-group">
            <button class="btn btn-sm btn-outline-light map-fab"
                    data-testid="nearest-stadium-btn"
                    @onclick="() => CenterOnNearestPitchByTypeAsync(PitchType.Stadium)"
                    disabled="@(!_pitchGraphics.Any(p => MapState.Value.VisiblePitches.FirstOrDefault(v => v.Id == p.Key)?.Type == PitchType.Stadium))"
                    title="Nearest stadium">
                &#x1F3DF;
            </button>
            <button class="btn btn-sm btn-outline-light map-fab"
                    data-testid="nearest-standard-btn"
                    @onclick="() => CenterOnNearestPitchByTypeAsync(PitchType.Standard)"
                    disabled="@(!_pitchGraphics.Any(p => MapState.Value.VisiblePitches.FirstOrDefault(v => v.Id == p.Key)?.Type == PitchType.Standard))"
                    title="Nearest pitch">
                &#x26BD;
            </button>
            <button class="btn btn-sm btn-outline-light map-fab"
                    data-testid="nearest-training-btn"
                    @onclick="() => CenterOnNearestPitchByTypeAsync(PitchType.Training)"
                    disabled="@(!_pitchGraphics.Any(p => MapState.Value.VisiblePitches.FirstOrDefault(v => v.Id == p.Key)?.Type == PitchType.Training))"
                    title="Nearest training ground">
                &#x1F4A1;
            </button>
        </div>
        <div class="pitch-legend" data-testid="pitch-legend">
            <div class="pitch-legend__title">Pitches</div>
            <div class="pitch-legend__row">
                <span class="pitch-legend__marker pitch-legend__marker--stadium"></span>
                <span>Stadium</span>
                <strong>@PitchCount(PitchType.Stadium)</strong>
            </div>
            <div class="pitch-legend__row">
                <span class="pitch-legend__marker pitch-legend__marker--standard"></span>
                <span>Standard</span>
                <strong>@PitchCount(PitchType.Standard)</strong>
            </div>
            <div class="pitch-legend__row">
                <span class="pitch-legend__marker pitch-legend__marker--training"></span>
                <span>Training</span>
                <strong>@PitchCount(PitchType.Training)</strong>
            </div>
        </div>
    }
</div>

@if (_showOnboarding && _hasApiKey)
{
    <div class="onboarding-banner" data-testid="onboarding-banner">
        <span class="onboarding-text">Welcome to RuckR! Explore the map to find pitches and recruit players.</span>
        <button class="btn-close btn-close-white" data-testid="onboarding-close" @onclick="DismissOnboarding" aria-label="Dismiss"></button>
    </div>
}

@if (_selectedPitch is not null)

@if (_selectedPitch is not null)
{
    <div class="map-overlay pitch-card pitch-card--@PitchTypeCssClass(_selectedPitch.Type)" data-testid="pitch-overlay">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <div class="pitch-card__eyebrow">@PitchTypeDisplayName(_selectedPitch.Type)</div>
                <h5 class="mb-0" data-testid="pitch-name">@_selectedPitch.Name</h5>
            </div>
            <button type="button" class="btn-close" data-testid="pitch-close" @onclick="ClearSelection" aria-label="Close"></button>
        </div>
        <div class="pitch-card__meta mb-2">
            <span class="pitch-card__pill">@PitchTypeDescription(_selectedPitch.Type)</span>
            <span class="pitch-card__distance">@PitchDistanceText(_selectedPitch)</span>
        </div>
        <p class="small text-white-50 mb-0">
            @_selectedPitch.Latitude.ToString("F4"), @_selectedPitch.Longitude.ToString("F4")
        </p>
    </div>
}

@if (_selectedEncounter is not null)
{
    <div class="map-overlay map-overlay--encounter" data-testid="encounter-overlay">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h5 class="mb-0" data-testid="encounter-name">@_selectedEncounter.Name</h5>
            <button type="button" class="btn-close" data-testid="encounter-close" @onclick="ClearEncounterSelection" aria-label="Close"></button>
        </div>
        <div class="mb-2">
            <span class="badge bg-@EncounterRarityBadgeClass(_selectedEncounter.Rarity) me-2">@_selectedEncounter.Rarity</span>
            <span class="badge bg-secondary">Level @_selectedEncounter.Level</span>
        </div>
        <p class="small text-success mb-1">
            Recruit at @EncounterParkName(_selectedEncounter)
        </p>
        <p class="small text-muted mb-1">
            Distance: @DistanceBucketFromPosition(_selectedEncounter.Latitude, _selectedEncounter.Longitude)
        </p>
        <p class="small text-muted mb-2">
            Success chance: @_selectedEncounter.SuccessChancePercent%
        </p>
        <button class="btn btn-sm btn-@RecruitButtonClass()"
                data-testid="recruit-btn"
                disabled="@(!_canRecruit)"
                title="@_recruitBlockedReason"
                @onclick="AttemptRecruitment">
            @if (_isRecruiting)
            {
                <span class="spinner-border spinner-border-sm" role="status"></span>
            }
            else
            {
                @:Recruit @_selectedEncounter.Name
            }
        </button>
        @if (!_canRecruit)
        {
            <p class="small mt-2 mb-0 text-warning">@_recruitBlockedReason</p>
        }
        @if (_recruitMessage is not null)
        {
            <p class="small mt-2 mb-0 text-@_recruitMessageClass">@_recruitMessage</p>
        }
    </div>
}

@if (_gameProgress is not null)
{
    <div class="game-progress-chip" title="Level @_gameProgress.Level — @_gameProgress.Experience / @_gameProgress.NextLevelExperience XP">
        <span class="fw-bold">@_gameProgress.Level</span>
        <div class="progress flex-grow-1 ms-2">
            <div class="progress-bar"
                 role="progressbar"
                 style="width:@ProgressPercent%; min-width: 8px;"
                 aria-valuenow="@_gameProgress.Experience - _prevLevelXp"
                 aria-valuemin="0"
                 aria-valuemax="@_gameProgress.NextLevelExperience - _prevLevelXp">
            </div>
        </div>
    </div>
}

<div class="map-info-bar">
    <span class="text-muted small">
        @if (_statusMessage is not null)
        {
            @_statusMessage
        }
        else if (_pitchGraphics.Count > 0 || _encounterGraphics.Count > 0)
        {
            <text>@_pitchGraphics.Count pitches, @_encounterGraphics.Count encounters visible. Tap a marker to see details.</text>
        }
        else
        {
            <text>Loading...</text>
        }
    </span>
</div>

