@page "/map"
@page "/"
@using dymaptic.GeoBlazor.Core.Components
@using dymaptic.GeoBlazor.Core.Components.Geometries
@using dymaptic.GeoBlazor.Core.Components.Symbols
@using dymaptic.GeoBlazor.Core.Components.Views
@using dymaptic.GeoBlazor.Core.Components.Widgets
@using dymaptic.GeoBlazor.Core.Enums
@using dymaptic.GeoBlazor.Core.Events
@using dymaptic.GeoBlazor.Core.Model
@using Fluxor
@using RuckR.Client.Services
@using RuckR.Client.Store.MapFeature
@using RuckR.Client.Store.LocationFeature
@using RuckR.Shared.Models
@inject IConfiguration Configuration
@inject ILogger<Map> Logger
@inject IGeolocationService GeolocationService
@inject ApiClientService ApiClient
@inject IDispatcher Dispatcher
@inject IState<MapState> MapState
@inject IState<LocationState> LocationState
@implements IAsyncDisposable

<div class="map-shell">
    @if (_hasApiKey)
    {
        <MapView @ref="_mapView"
                 Latitude="@_latitude"
                 Longitude="@_longitude"
                 Zoom="@_zoom"
                 OnClick="HandleMapClick"
                 OnViewInitialized="OnViewInitializedAsync"
                 ShowZoomWidget="true"
                 style="width:100%; height:100%;">
            <dymaptic.GeoBlazor.Core.Components.Map>
                <Basemap>
                    <BasemapStyle Name="@BasemapStyleName.ArcgisNavigation" ApiKey="@_apiKey" />
                </Basemap>
            </dymaptic.GeoBlazor.Core.Components.Map>
            <HomeWidget Position="OverlayPosition.TopLeft" />
            <CompassWidget Position="OverlayPosition.TopLeft" />
            <LocateWidget Position="OverlayPosition.TopLeft" />
            <ScaleBarWidget Position="OverlayPosition.BottomLeft" />
        </MapView>
        <div class="map-fab-group">
            <button class="btn btn-sm btn-outline-light map-fab"
                    data-testid="nearest-stadium-btn"
                    @onclick="() => CenterOnNearestPitchByTypeAsync(PitchType.Stadium)"
                    disabled="@(!_pitchGraphics.Any(p => MapState.Value.VisiblePitches.FirstOrDefault(v => v.Id == p.Key)?.Type == PitchType.Stadium))"
                    title="Nearest stadium">
                &#x1F3DF;
            </button>
            <button class="btn btn-sm btn-outline-light map-fab"
                    data-testid="nearest-standard-btn"
                    @onclick="() => CenterOnNearestPitchByTypeAsync(PitchType.Standard)"
                    disabled="@(!_pitchGraphics.Any(p => MapState.Value.VisiblePitches.FirstOrDefault(v => v.Id == p.Key)?.Type == PitchType.Standard))"
                    title="Nearest pitch">
                &#x26BD;
            </button>
            <button class="btn btn-sm btn-outline-light map-fab"
                    data-testid="nearest-training-btn"
                    @onclick="() => CenterOnNearestPitchByTypeAsync(PitchType.Training)"
                    disabled="@(!_pitchGraphics.Any(p => MapState.Value.VisiblePitches.FirstOrDefault(v => v.Id == p.Key)?.Type == PitchType.Training))"
                    title="Nearest training ground">
                &#x1F4A1;
            </button>
        </div>
    }
    else
    {
        <div class="map-unavailable-shell">
            <div class="map-unavailable-panel">
                <p class="mb-1 fw-bold">Map unavailable</p>
                <p class="small text-muted mb-0">
                    ArcGIS API key is not configured. Set the <code>ARC_GIS_API_KEY</code> environment variable.
                </p>
            </div>
        </div>
    }
</div>

@if (_selectedPitch is not null)
{
    <div class="map-overlay" data-testid="pitch-overlay">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h5 class="mb-0" data-testid="pitch-name">@_selectedPitch.Name</h5>
            <button type="button" class="btn-close" data-testid="pitch-close" @onclick="ClearSelection" aria-label="Close"></button>
        </div>
        <div class="mb-2">
            <span class="badge bg-@PitchTypeBadgeClass(_selectedPitch.Type) me-2">@_selectedPitch.Type</span>
        </div>
        <p class="small text-muted mb-0">
            Lat @_selectedPitch.Latitude.ToString("F4"), Lng @_selectedPitch.Longitude.ToString("F4")
        </p>
    </div>
}

<div class="map-info-bar">
    <span class="text-muted small">
        @if (_statusMessage is not null)
        {
            @_statusMessage
        }
        else if (_pitchGraphics.Count > 0)
        {
            <text>@_pitchGraphics.Count pitches visible on map. Tap a marker to see details.</text>
        }
        else
        {
            <text>Loading pitches...</text>
        }
    </span>
</div>

<style>
    .map-fab-group {
        position: absolute;
        bottom: 3.5rem;
        right: 0.5rem;
        z-index: 10;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    .map-fab {
        width: 2.5rem;
        height: 2.5rem;
        padding: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        border-radius: 0.375rem;
        background: rgba(33,37,41,0.85);
        border: 1px solid rgba(255,255,255,0.15);
    }
    .map-fab:hover:not(:disabled) {
        background: rgba(52,58,64,0.95);
    }
    .map-fab:disabled {
        opacity: 0.4;
    }
</style>

@code {
    private MapView? _mapView;
    private string _apiKey = string.Empty;
    private bool _hasApiKey;
    private double _latitude = 51.5074;
    private double _longitude = -0.1278;
    private int _zoom = 13;
    private string? _statusMessage;
    private bool _viewReady;
    private bool _subscriptionsActive;
    private bool _initialCenterPerformed;
    private GeoPosition? _lastKnownPosition;
    private GeoPosition? _lastPitchFetchPosition;
    private DateTime _lastPitchFetchAtUtc = DateTime.MinValue;

    private const double BrowseRadiusMeters = 5000.0;
    private const double MinPitchRefreshDistanceMeters = 50.0;
    private static readonly TimeSpan PitchRefreshInterval = TimeSpan.FromSeconds(30);

    private readonly Dictionary<int, Graphic> _pitchGraphics = new();
    private PitchModel? _selectedPitch;
    private int _lastSelectedPitchId = -1;

    protected override void OnInitialized()
    {
        _apiKey = Configuration["ArcGISApiKey"] ?? string.Empty;
        _hasApiKey = !string.IsNullOrWhiteSpace(_apiKey);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            GeolocationService.PositionChanged += OnPositionChanged;
            MapState.StateChanged += OnMapStateChanged;
            _subscriptionsActive = true;

            try
            {
                await GeolocationService.StartWatchAsync();
            }
            catch
            {
                _statusMessage = "GPS unavailable. Showing pitches near London.";
                StateHasChanged();
            }
        }
    }

    private async Task OnViewInitializedAsync()
    {
        _viewReady = true;
        Logger.LogInformation("MapView initialized, loading pitches near London");

        await LoadPitchMarkersAsync(_latitude, _longitude);
    }

    private async void OnPositionChanged(GeoPosition pos)
    {
        try
        {
            _lastKnownPosition = pos;

            if (!_initialCenterPerformed)
            {
                _initialCenterPerformed = true;
                _latitude = pos.Latitude;
                _longitude = pos.Longitude;
            }

            if (ShouldRefreshPitches(pos))
            {
                await LoadPitchMarkersAsync(pos.Latitude, pos.Longitude);
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in position change handler");
        }
    }

    private void OnMapStateChanged(object? sender, EventArgs e)
    {
        var state = ((IState<MapState>)sender!).Value;
        if (state.SelectedPitchId.HasValue && state.SelectedPitchId.Value != _lastSelectedPitchId)
        {
            _lastSelectedPitchId = state.SelectedPitchId.Value;
            _selectedPitch = state.VisiblePitches.FirstOrDefault(p => p.Id == state.SelectedPitchId.Value);
            _ = InvokeAsync(StateHasChanged);
        }
        else if (!state.SelectedPitchId.HasValue && _selectedPitch is not null)
        {
            _lastSelectedPitchId = -1;
            _selectedPitch = null;
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadPitchMarkersAsync(double lat, double lng)
    {
        if (!_viewReady || _mapView is null)
            return;

        try
        {
            var pitches = await ApiClient.GetNearbyPitchesAsync(lat, lng, BrowseRadiusMeters);
            Dispatcher.Dispatch(new SetPitchesAction(pitches.AsReadOnly()));
            await UpdatePitchGraphicsAsync(pitches);

            _lastPitchFetchPosition = new GeoPosition { Latitude = lat, Longitude = lng };
            _lastPitchFetchAtUtc = DateTime.UtcNow;

            _statusMessage = null;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load pitch markers");
            _statusMessage = "Failed to load pitches. Map is still usable.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task UpdatePitchGraphicsAsync(List<PitchModel> pitches)
    {
        if (_mapView is null) return;

        foreach (var old in _pitchGraphics.Values)
        {
            try { await _mapView.RemoveGraphic(old); }
            catch (Exception ex) { Logger.LogDebug(ex, "Failed to remove old graphic"); }
        }
        _pitchGraphics.Clear();

        foreach (var pitch in pitches)
        {
            var graphic = new Graphic(
                geometry: new Point(longitude: pitch.Longitude, latitude: pitch.Latitude),
                symbol: GetPitchSymbol(pitch.Type),
                attributes: new AttributesDictionary(new Dictionary<string, object?>
                {
                    ["_ruckrType"] = "pitch",
                    ["_ruckrId"] = pitch.Id,
                    ["name"] = pitch.Name,
                    ["pitchType"] = pitch.Type.ToString()
                })
            );

            try
            {
                await _mapView.AddGraphic(graphic);
                _pitchGraphics[pitch.Id] = graphic;
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to add graphic for pitch {PitchId}", pitch.Id);
            }
        }
    }

    private async Task HandleMapClick(ClickEvent clickEvent)
    {
        if (clickEvent?.MapPoint is null || _mapView is null)
            return;

        try
        {
            var hitResult = await _mapView.HitTest(clickEvent);
            foreach (var hit in hitResult.Results)
            {
                if (hit is GraphicHit graphicHit)
                {
                    var attrs = graphicHit.Graphic.Attributes;
                    if (attrs.TryGetValue("_ruckrType", out var type) && type?.ToString() == "pitch")
                    {
                        if (attrs.TryGetValue("_ruckrId", out var idObj) && idObj is int pitchId)
                        {
                            Dispatcher.Dispatch(new SelectPitchAction(pitchId));
                            return;
                        }
                    }
                }
            }

            Dispatcher.Dispatch(new ClearSelectionAction());
            _statusMessage = $"Clicked: {clickEvent.MapPoint.Latitude:F5}, {clickEvent.MapPoint.Longitude:F5}";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Map click hit-test failed");
            _statusMessage = $"Clicked: {clickEvent.MapPoint.Latitude:F5}, {clickEvent.MapPoint.Longitude:F5}";
            StateHasChanged();
        }
    }

    private void ClearSelection()
    {
        Dispatcher.Dispatch(new ClearSelectionAction());
    }

    private async Task CenterOnNearestPitchByTypeAsync(PitchType? filterType = null)
    {
        if (_mapView is null || _pitchGraphics.Count == 0)
            return;

        var currentLat = _lastKnownPosition?.Latitude ?? _latitude;
        var currentLng = _lastKnownPosition?.Longitude ?? _longitude;

        var candidates = filterType.HasValue
            ? MapState.Value.VisiblePitches.Where(p => p.Type == filterType.Value)
            : MapState.Value.VisiblePitches;

        var nearest = candidates
            .OrderBy(p => GeoPosition.HaversineDistance(
                new GeoPosition { Latitude = currentLat, Longitude = currentLng },
                new GeoPosition { Latitude = p.Latitude, Longitude = p.Longitude }))
            .FirstOrDefault();

        if (nearest is null)
            return;

        try
        {
            await _mapView.SetCenter(new Point(longitude: nearest.Longitude, latitude: nearest.Latitude));
            Dispatcher.Dispatch(new SelectPitchAction(nearest.Id));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to center on nearest pitch");
        }
    }

    private bool ShouldRefreshPitches(GeoPosition current)
    {
        if (_lastPitchFetchPosition is null) return true;
        if ((DateTime.UtcNow - _lastPitchFetchAtUtc) >= PitchRefreshInterval) return true;

        var moved = GeoPosition.HaversineDistance(_lastPitchFetchPosition, current);
        return moved >= MinPitchRefreshDistanceMeters;
    }

    private static SimpleMarkerSymbol GetPitchSymbol(PitchType type) => type switch
    {
        PitchType.Standard => new SimpleMarkerSymbol(
            outline: new Outline(color: new MapColor("#FFFFFF"), width: new Dimension(2)),
            color: new MapColor(47, 127, 79),
            size: new Dimension(14),
            style: SimpleMarkerSymbolStyle.Circle),
        PitchType.Training => new SimpleMarkerSymbol(
            outline: new Outline(color: new MapColor("#FFFFFF"), width: new Dimension(2)),
            color: new MapColor(62, 163, 109),
            size: new Dimension(14),
            style: SimpleMarkerSymbolStyle.Circle),
        PitchType.Stadium => new SimpleMarkerSymbol(
            outline: new Outline(color: new MapColor("#FFFFFF"), width: new Dimension(2)),
            color: new MapColor(196, 147, 18),
            size: new Dimension(16),
            style: SimpleMarkerSymbolStyle.Diamond),
        _ => new SimpleMarkerSymbol(
            outline: new Outline(color: new MapColor("#FFFFFF"), width: new Dimension(2)),
            color: new MapColor(107, 114, 128),
            size: new Dimension(12),
            style: SimpleMarkerSymbolStyle.Circle)
    };

    private static string PitchTypeBadgeClass(PitchType type) => type switch
    {
        PitchType.Standard => "primary",
        PitchType.Training => "success",
        PitchType.Stadium => "warning",
        _ => "secondary"
    };

    public async ValueTask DisposeAsync()
    {
        if (_subscriptionsActive)
        {
            GeolocationService.PositionChanged -= OnPositionChanged;
            MapState.StateChanged -= OnMapStateChanged;
            _subscriptionsActive = false;
        }
        GeolocationService.StopWatch();

        if (_mapView is not null)
        {
            try { await _mapView.ClearGraphics(); } catch { }
        }
        _pitchGraphics.Clear();
    }
}
