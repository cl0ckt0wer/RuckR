@page "/map"
@page "/"
@using Fluxor
@using RuckR.Client.Store.LocationFeature
@using RuckR.Client.Store.MapFeature
@using RuckR.Client.Services
@using RuckR.Shared.Models
@inject RuckR.Client.Services.IGeolocationService GeolocationService
@inject IMapService MapService
@inject ApiClientService ApiClient
@inject SignalRClientService SignalRClient
@inject IDispatcher Dispatcher
@inject IState<LocationState> LocationState
@inject IState<MapState> MapState
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IAsyncDisposable

@* Onboarding Banner *@
@if (_showOnboarding)
{
    <div class="alert alert-info alert-dismissible fade show position-fixed top-0 start-0 end-0 m-3" style="z-index: 2000;" role="alert" data-testid="onboarding-banner">
        Welcome to RuckR! 🏉
        1️⃣ Explore the map to find rugby pitches
        2️⃣ Get close to capture players
        3️⃣ Challenge nearby players to PVP battles!
        <button type="button" class="btn-close" data-testid="onboarding-close" @onclick="DismissOnboarding" aria-label="Close"></button>
    </div>
}

@* Loading State *@
@if (_isLoading)
{
    <div class="d-flex justify-content-center align-items-center position-absolute top-0 start-0 end-0 bottom-0" style="z-index: 10;" data-testid="map-loading">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading map...</span>
        </div>
    </div>
}

@* Error State *@
@if (_hasError)
{
    <div class="d-flex flex-column justify-content-center align-items-center position-absolute top-0 start-0 end-0 bottom-0" style="z-index: 10;" data-testid="map-error">
        <div class="alert alert-danger text-center">
            <p class="mb-1 fw-bold">Failed to load map</p>
            <p class="small text-muted mb-2">@_errorMessage</p>
            <button class="btn btn-outline-danger" data-testid="map-retry-btn" @onclick="RetryAsync">Retry</button>
        </div>
    </div>
}

@* GPS Disabled Banner *@
@if (_gpsDisabled && !_isLoading && !_hasError)
{
    <div class="alert alert-warning alert-dismissible fade show position-fixed top-0 start-0 end-0 m-3" style="z-index: 1500;" role="alert" data-testid="gps-disabled-banner">
        Enable GPS for the full experience
        <button class="btn btn-outline-warning btn-sm ms-3" data-testid="gps-enable-btn" @onclick="EnableGpsAsync">Enable</button>
    </div>
}

@* Map container — always present for Leaflet init, hidden when error/loading replaces it *@
<div id="ruckr-map" class="@(_isLoading || _hasError ? "invisible" : "")" data-testid="map-container"></div>

@if (_lastKnownPosition is not null && !_isLoading && !_hasError)
{
    <button class="btn btn-light map-locate-btn"
            type="button"
            data-testid="map-locate-btn"
            @onclick="CenterOnUserAsync">
        Locate me
    </button>
}

@* Pitch Selection Overlay *@
@if (_selectedPitch is not null)
{
    <div class="map-overlay" data-testid="pitch-overlay">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h5 class="mb-0" data-testid="pitch-name">@_selectedPitch.Name</h5>
            <button type="button" class="btn-close" data-testid="pitch-close" @onclick="ClearSelection" aria-label="Close"></button>
        </div>
        <div class="mb-2">
            <span class="badge bg-@PitchTypeBadgeClass(_selectedPitch.Type) me-2">@_selectedPitch.Type</span>
            <span class="badge bg-secondary">@_selectedPitchDistanceBucket</span>
        </div>
        <p class="mb-2">
            Available Players:
            @if (_isLoadingEligibility)
            {
                <span class="spinner-border spinner-border-sm text-secondary" role="status"></span>
            }
            else
            {
                @_nearbyPlayerCount
            }
            <span class="text-muted ms-1">(players at this pitch)</span>
        </p>
        <p class="small text-muted mb-3" data-testid="capture-status">@CaptureStatusText</p>
        <div class="d-grid gap-2 d-sm-flex">
            <button class="btn btn-primary"
                    data-testid="capture-players-btn"
                    disabled="@(!CanCaptureSelectedPitch)"
                    @onclick="NavigateToCapture">
                Capture Players
            </button>
            @if (_nearbyPlayerCount > 0)
            {
                <button class="btn btn-outline-primary" data-testid="challenge-nearby-btn" @onclick="NavigateToChallenge">Challenge Nearby Player</button>
            }
        </div>
    </div>
}

@code {
    private bool _isLoading = true;
    private bool _hasError;
    private string _errorMessage = string.Empty;
    private bool _gpsDisabled;
    private bool _showOnboarding;
    private PitchModel? _selectedPitch;
    private string _selectedPitchDistanceBucket = string.Empty;
    private int _nearbyPlayerCount;
    private bool _isLoadingEligibility;
    private int _lastSelectedPitchId = -1;
    private bool _subscriptionsActive;
    private bool _initialCenterPerformed;
    private int _eligibilityRequestPitchId = -1;
    private GeoPosition? _lastKnownPosition;
    private GeoPosition? _lastPitchFetchPosition;
    private DateTime _lastPitchFetchAtUtc = DateTime.MinValue;

    private const double BrowseThresholdMeters = 500.0;
    private const double MinPitchRefreshDistanceMeters = 50.0;
    private static readonly TimeSpan PitchRefreshInterval = TimeSpan.FromSeconds(30);

    private CaptureEligibilityDto? _captureEligibility;

    private bool CanCaptureSelectedPitch => _captureEligibility?.CanCapture == true;

    private string CaptureStatusText
    {
        get
        {
            if (_selectedPitch is null)
                return string.Empty;

            if (_isLoadingEligibility)
                return "Checking capture range...";

            if (_captureEligibility is null)
                return "Unable to verify capture right now. Try again.";

            return _captureEligibility.Reason switch
            {
                "ELIGIBLE" => "In range. You can capture players from this pitch.",
                "GPS_REQUIRED" => "Enable GPS to capture players from this pitch.",
                "GPS_INACCURATE" => "Improve GPS accuracy (<= 50m) to capture players.",
                "TOO_FAR" => "Move closer. Capture unlocks within 100m.",
                "NO_PLAYERS" => "No available players at this pitch right now.",
                _ => "Capture is currently unavailable."
            };
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeAsync();
        }
    }

    private async Task InitializeAsync()
    {
        // Clean up previous subscriptions if retrying
        RemoveSubscriptions();
        GeolocationService.StopWatch();

        _isLoading = true;
        _hasError = false;
        _gpsDisabled = false;
        _showOnboarding = false;
        _errorMessage = string.Empty;
        _selectedPitch = null;
        _lastSelectedPitchId = -1;
        _captureEligibility = null;
        _isLoadingEligibility = false;
        _lastKnownPosition = null;
        _lastPitchFetchPosition = null;
        _lastPitchFetchAtUtc = DateTime.MinValue;
        StateHasChanged();

        try
        {
            var lat = LocationState.Value.UserLatitude ?? 51.5074;
            var lng = LocationState.Value.UserLongitude ?? -0.1278;

            await MapService.InitMapAsync("ruckr-map", lat, lng, 15);

            // Onboarding check via localStorage
            try
            {
                var onboarded = await JS.InvokeAsync<string>("localStorage.getItem", "ruckr_onboarded");
                _showOnboarding = string.IsNullOrEmpty(onboarded);
            }
            catch
            {
                // localStorage unavailable — skip onboarding
            }

            // Subscribe to state changes and events before starting GPS
            MapState.StateChanged += OnMapStateChanged;
            LocationState.StateChanged += OnLocationStateChanged;
            GeolocationService.PositionChanged += OnPositionChanged;
            _subscriptionsActive = true;

            // Start GPS watch (non-critical — map works without GPS)
            try
            {
                await GeolocationService.StartWatchAsync();
            }
            catch
            {
                _gpsDisabled = true;
            }

            _isLoading = false;

            if (LocationState.Value.UserLatitude is double knownLat && LocationState.Value.UserLongitude is double knownLng)
            {
                _lastKnownPosition = new GeoPosition
                {
                    Latitude = knownLat,
                    Longitude = knownLng,
                    Accuracy = LocationState.Value.AccuracyMeters,
                    Timestamp = DateTime.UtcNow
                };
            }
        }
        catch (Exception ex)
        {
            _hasError = true;
            _errorMessage = ex.Message;
            _isLoading = false;
        }

        StateHasChanged();
    }

    private async void OnPositionChanged(GeoPosition pos)
    {
        try
        {
            _lastKnownPosition = pos;

            if (!_initialCenterPerformed)
            {
                _initialCenterPerformed = true;
                await MapService.CenterOnAsync(pos.Latitude, pos.Longitude);
            }

            await MapService.AddUserMarkerAsync(pos.Latitude, pos.Longitude);
            await SignalRClient.UpdateLocationAsync(pos.Latitude, pos.Longitude);

            if (ShouldRefreshPitches(pos))
            {
                var pitches = await ApiClient.GetNearbyPitchesAsync(pos.Latitude, pos.Longitude, BrowseThresholdMeters);
                await MapService.AddPitchMarkersAsync(pitches, pos);
                Dispatcher.Dispatch(new SetPitchesAction(pitches.AsReadOnly()));
                _lastPitchFetchPosition = pos;
                _lastPitchFetchAtUtc = DateTime.UtcNow;
            }

            if (_selectedPitch is not null)
            {
                UpdateSelectedPitchDistance(pos, _selectedPitch);
                _ = RefreshCaptureEligibilityAsync(_selectedPitch.Id);
            }

            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Transient map/API errors; wait for next position update
        }
    }

    private async void OnMapStateChanged(object? sender, EventArgs e)
    {
        var state = ((IState<MapState>)sender!).Value;
        if (state.SelectedPitchId.HasValue && state.SelectedPitchId.Value != _lastSelectedPitchId)
        {
            _lastSelectedPitchId = state.SelectedPitchId.Value;
            _selectedPitch = state.VisiblePitches.FirstOrDefault(p => p.Id == state.SelectedPitchId.Value);

            if (_selectedPitch is not null)
            {
                // Calculate distance bucket from user's current position
                if (_lastKnownPosition is not null)
                    UpdateSelectedPitchDistance(_lastKnownPosition, _selectedPitch);

                // Load server-validated capture eligibility for the selected pitch
                _ = RefreshCaptureEligibilityAsync(_selectedPitch.Id);
            }

            await InvokeAsync(StateHasChanged);
        }
        else if (!state.SelectedPitchId.HasValue && _selectedPitch is not null)
        {
            _lastSelectedPitchId = -1;
            _selectedPitch = null;
            _nearbyPlayerCount = 0;
            _selectedPitchDistanceBucket = string.Empty;
            _captureEligibility = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnLocationStateChanged(object? sender, EventArgs e)
    {
        var state = ((IState<LocationState>)sender!).Value;
        if (!string.IsNullOrEmpty(state.ErrorMessage))
        {
            _gpsDisabled = true;
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshCaptureEligibilityAsync(int pitchId)
    {
        if (_isLoadingEligibility && _eligibilityRequestPitchId == pitchId)
            return;

        _eligibilityRequestPitchId = pitchId;
        _isLoadingEligibility = true;
        try
        {
            var eligibility = await ApiClient.GetCaptureEligibilityAsync(pitchId);
            _captureEligibility = eligibility;
            _nearbyPlayerCount = eligibility?.AvailablePlayerCount ?? 0;

            if (!string.IsNullOrWhiteSpace(eligibility?.DistanceBucket)
                && Enum.TryParse<DistanceBucket>(eligibility.DistanceBucket, out var bucket))
            {
                _selectedPitchDistanceBucket = FormatDistanceBucket(bucket);
            }
        }
        catch
        {
            _captureEligibility = null;
            _nearbyPlayerCount = 0;
        }
        _isLoadingEligibility = false;
        _eligibilityRequestPitchId = -1;
        await InvokeAsync(StateHasChanged);
    }

    private async Task DismissOnboarding()
    {
        _showOnboarding = false;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "ruckr_onboarded", "true");
        }
        catch
        {
            // localStorage unavailable
        }
    }

    private async Task RetryAsync()
    {
        await InitializeAsync();
    }

    private async Task EnableGpsAsync()
    {
        try
        {
            await GeolocationService.StartWatchAsync();
            _gpsDisabled = false;
            StateHasChanged();
        }
        catch
        {
            _gpsDisabled = true;
        }
    }

    private async Task CenterOnUserAsync()
    {
        if (_lastKnownPosition is null)
            return;

        await MapService.CenterOnAsync(_lastKnownPosition.Latitude, _lastKnownPosition.Longitude);
    }

    private void ClearSelection()
    {
        Dispatcher.Dispatch(new ClearSelectionAction());
    }

    private void NavigateToCapture()
    {
        if (!CanCaptureSelectedPitch || _selectedPitch is null)
            return;

        Navigation.NavigateTo($"/players/nearby?pitchId={_selectedPitch.Id}");
    }

    private void NavigateToChallenge()
    {
        Navigation.NavigateTo("/battles/new");
    }

    private void RemoveSubscriptions()
    {
        if (!_subscriptionsActive)
            return;

        GeolocationService.PositionChanged -= OnPositionChanged;
        MapState.StateChanged -= OnMapStateChanged;
        LocationState.StateChanged -= OnLocationStateChanged;
        _subscriptionsActive = false;
    }

    private static string FormatDistanceBucket(DistanceBucket bucket) => bucket switch
    {
        DistanceBucket.Within50m => "< 50m",
        DistanceBucket.Within100m => "< 100m",
        DistanceBucket.Within250m => "< 250m",
        DistanceBucket.Within500m => "< 500m",
        DistanceBucket.Beyond => "> 500m",
        _ => "Unknown"
    };

    private static string PitchTypeBadgeClass(PitchType type) => type switch
    {
        PitchType.Standard => "primary",
        PitchType.Training => "success",
        PitchType.Stadium => "warning",
        _ => "secondary"
    };

    private bool ShouldRefreshPitches(GeoPosition currentPosition)
    {
        if (_lastPitchFetchPosition is null)
            return true;

        if ((DateTime.UtcNow - _lastPitchFetchAtUtc) >= PitchRefreshInterval)
            return true;

        var movedMeters = GeoPosition.HaversineDistance(_lastPitchFetchPosition, currentPosition);
        return movedMeters >= MinPitchRefreshDistanceMeters;
    }

    private void UpdateSelectedPitchDistance(GeoPosition userPos, PitchModel pitch)
    {
        var pitchPos = new GeoPosition
        {
            Latitude = pitch.Location.Y,
            Longitude = pitch.Location.X
        };

        var dist = GeoPosition.HaversineDistance(userPos, pitchPos);
        _selectedPitchDistanceBucket = FormatDistanceBucket(GeoPosition.GetDistanceBucket(dist));
    }

    public async ValueTask DisposeAsync()
    {
        RemoveSubscriptions();
        GeolocationService.StopWatch();
        await MapService.DisposeAsync();
    }
}
