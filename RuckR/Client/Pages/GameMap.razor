    private async Task HandleMapClick(ClickEvent clickEvent)
    {
        if (clickEvent?.MapPoint is null || _mapView is null)
            return;

        try
        {
            var hitResult = await _mapView.HitTest(clickEvent);
            foreach (var hit in hitResult.Results)
            {
                if (hit is GraphicHit graphicHit && TryApplyGraphicHitSelection(graphicHit.Graphic))
                {
                    return;
                }
            }

            if (clickEvent.MapPoint.Latitude.HasValue
                && clickEvent.MapPoint.Longitude.HasValue
                && TryApplyNearestMapSelection(clickEvent.MapPoint.Latitude.Value, clickEvent.MapPoint.Longitude.Value))
            {
                return;
            }

            Dispatcher.Dispatch(new ClearSelectionAction());
            _statusMessage = $"Clicked: {clickEvent.MapPoint.Latitude:F5}, {clickEvent.MapPoint.Longitude:F5}";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Map click hit-test failed");
            _statusMessage = $"Clicked: {clickEvent.MapPoint.Latitude:F5}, {clickEvent.MapPoint.Longitude:F5}";
            StateHasChanged();
        }
    }

    private bool TryApplyGraphicHitSelection(Graphic graphic)
    {
        var selection = MapGraphicSelection.FromGraphic(graphic);
        if (selection is null)
        {
            return false;
        }

        return selection.Kind switch
        {
            MapSelectionKind.Pitch => TrySelectPitchGraphic(selection.PitchId),
            MapSelectionKind.Encounter => TrySelectEncounterGraphic(selection.EncounterId),
            MapSelectionKind.CandidatePlace => TrySelectCandidatePlaceGraphic(selection),
            _ => false
        };
    }

    private bool TryApplyNearestMapSelection(double latitude, double longitude)
    {
        var clickedPosition = new GeoPosition { Latitude = latitude, Longitude = longitude };

        var nearestEncounter = MapState.Value.VisibleEncounters
            .Select(encounter => new
            {
                Encounter = encounter,
                DistanceMeters = DistanceMeters(clickedPosition, encounter.Latitude, encounter.Longitude)
            })
            .Where(item => item.DistanceMeters <= MapTapSelectionRadiusMeters)
            .OrderBy(item => item.DistanceMeters)
            .FirstOrDefault();
        if (nearestEncounter is not null)
        {
            return TrySelectEncounterGraphic(nearestEncounter.Encounter.EncounterId);
        }

        var nearestCandidate = _candidatePlaces
            .Select(candidate => new
            {
                Candidate = candidate,
                DistanceMeters = DistanceMeters(clickedPosition, candidate.Latitude, candidate.Longitude)
            })
            .Where(item => item.DistanceMeters <= MapTapSelectionRadiusMeters)
            .OrderBy(item => item.DistanceMeters)
            .FirstOrDefault();
        if (nearestCandidate is not null)
        {
            return TrySelectCandidatePlaceGraphic(MapSelection.CandidatePlace(
                nearestCandidate.Candidate.PlaceId,
                nearestCandidate.Candidate.Name,
                nearestCandidate.Candidate.RecommendedPitchType,
                nearestCandidate.Candidate.Confidence.ToString(System.Globalization.CultureInfo.InvariantCulture),
                nearestCandidate.Candidate.MatchReason,
                nearestCandidate.Candidate.CategoryLabel));
        }

        var nearestPitch = MapState.Value.VisiblePitches
            .Select(pitch => new
            {
                Pitch = pitch,
                DistanceMeters = DistanceMeters(clickedPosition, pitch.Latitude, pitch.Longitude)
            })
            .Where(item => item.DistanceMeters <= MapTapSelectionRadiusMeters)
            .OrderBy(item => item.DistanceMeters)
            .FirstOrDefault();
        if (nearestPitch is not null)
        {
            return TrySelectPitchGraphic(nearestPitch.Pitch.Id);
        }

        return false;
    }

    private static double DistanceMeters(GeoPosition origin, double latitude, double longitude) =>
        GeoPosition.HaversineDistance(origin, new GeoPosition { Latitude = latitude, Longitude = longitude });

