@code {
    public const string MapUnavailableTitle = "The nearby pitch map is not ready.";
    public const string MapUnavailableBody =
        "You can still browse players and check your collection while map services are being restored.";

    public enum GpsStatusKind
    {
        Offline,
        Searching,
        Ready,
        Weak,
        Blocked
    }

    public readonly record struct GpsStatusView(
        GpsStatusKind Kind,
        string Label,
        string Detail,
        string CssClass,
        string? AccuracyText);

    public enum MapBasemapMode
    {
        Styled,
        Empty
    }

    public readonly record struct MapReductionOptions(
        MapBasemapMode BasemapMode,
        bool EnableArcGisWidgets,
        bool EnableMapDiagnostics,
        bool EnableGameGraphics,
        bool EnableAutoGpsWatch);

    private MapView? _mapView;
    private GraphicsLayer? _stadiumPitchLayer;
    private GraphicsLayer? _standardPitchLayer;
    private GraphicsLayer? _trainingPitchLayer;
    private GraphicsLayer? _encounterLayer;
    private GraphicsLayer? _candidatePlaceLayer;
    private GraphicsLayer? _playerLocationLayer;
    private string _apiKey = string.Empty;
    private bool _hasApiKey;
    private double _latitude = 51.5074;
    private double _longitude = -0.1278;
    private int _zoom = 13;
    private string? _statusMessage;
    private bool _viewReady;
    private bool _subscriptionsActive;
    private bool _initialCenterPerformed;
    private double _homeLatitude = 51.5074;
    private double _homeLongitude = -0.1278;
    private GeoPosition? _lastKnownPosition;
    private GeoPosition? _lastPitchFetchPosition;
    private DateTime _lastPitchFetchAtUtc = DateTime.MinValue;

    private const double EncounterBrowseRadiusMeters = 5000.0;
    private const double RecruitDistanceMeters = 75.0;
    private const double MaxRecruitAccuracyMeters = 50.0;

    private const double BrowseRadiusMeters = 5000.0;
    private const double MinPitchRefreshDistanceMeters = 50.0;
    private const int MaxGpsNoticeRetryAttempts = 5;
    private static readonly TimeSpan PitchRefreshInterval = TimeSpan.FromSeconds(30);

    private readonly Dictionary<int, Graphic> _pitchGraphics = new();
    private readonly Dictionary<Guid, Graphic> _encounterGraphics = new();
    private readonly Dictionary<string, Graphic> _candidatePlaceGraphics = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<PitchCandidatePlaceDto> _candidatePlaces = Array.Empty<PitchCandidatePlaceDto>();
    private IJSObjectReference? _mapDiagnosticsModule;
    private PitchModel? _selectedPitch;
    private int _lastSelectedPitchId = -1;
    private CaptureEligibilityDto? _captureEligibility;
    private bool _isLoadingEligibility;
    private int _eligibilityRequestPitchId = -1;
    private int _nearbyPlayerCount;
    private PlayerEncounterDto? _selectedEncounter;
    private PitchCandidatePlaceDto? _selectedCandidatePlace;
    private string _candidatePitchName = string.Empty;
    private string _candidatePitchType = PitchType.Standard.ToString();
    private bool _isCreatingCandidatePitch;
    private string? _candidateCreateMessage;
    private string _candidateCreateMessageClass = "success";
    private GameProgressDto? _gameProgress;
    private int _prevLevelXp;
    private bool _canRecruit;
    private bool _isRecruiting;
    private bool _isAuthenticated;
    private string _recruitBlockedReason = "Go to the park to recruit.";
    private string? _recruitMessage;
    private string _recruitMessageClass = "success";
    private string? _recruitToastMessage;
    private string _recruitToastClass = "success";
    private bool _showOnboarding = true;
    private int _gpsRetryAttempts;
    private bool _gpsNoticeDismissed;
    private bool _showCandidatePlaces = true;
    private bool _enableArcGisWidgets;
    private bool _enableMapDiagnostics;
    private bool _enableGameGraphics;
    private bool _enableAutoGpsWatch;
    private MapBasemapMode _basemapMode = MapBasemapMode.Styled;

    protected override void OnInitialized()
    {
        _apiKey = Configuration["ArcGISApiKey"] ?? string.Empty;
        _hasApiKey = !ShouldShowMapUnavailableFallback(_apiKey);
        _viewReady = !_hasApiKey;
        var reductionOptions = ResolveMapReductionOptions(Configuration, Navigation.Uri);
        _basemapMode = reductionOptions.BasemapMode;
        _enableArcGisWidgets = reductionOptions.EnableArcGisWidgets;
        _enableMapDiagnostics = reductionOptions.EnableMapDiagnostics;
        _enableGameGraphics = reductionOptions.EnableGameGraphics;
        _enableAutoGpsWatch = reductionOptions.EnableAutoGpsWatch;
    }

    public static MapReductionOptions ResolveMapReductionOptions(IConfiguration configuration, string currentUri)
    {
        var uri = new Uri(currentUri, UriKind.Absolute);

        return new MapReductionOptions(
            BasemapMode: ResolveBasemapMode(configuration, uri),
            EnableArcGisWidgets: ResolveMapFeatureFlag(configuration, uri, "EnableArcGisWidgets", "arcGisWidgets", defaultValue: false),
            EnableMapDiagnostics: ResolveMapFeatureFlag(configuration, uri, "EnableMapDiagnostics", "mapDiagnostics", defaultValue: true),
            EnableGameGraphics: ResolveMapFeatureFlag(configuration, uri, "EnableGameGraphics", "mapGraphics", defaultValue: true),
            EnableAutoGpsWatch: ResolveMapFeatureFlag(configuration, uri, "EnableAutoGpsWatch", "autoGps", defaultValue: true));
    }

    private static MapBasemapMode ResolveBasemapMode(IConfiguration configuration, Uri uri)
    {
        var value = configuration["Map:BasemapMode"];
        var mode = ParseBasemapMode(value) ?? MapBasemapMode.Styled;

        var query = uri.Query.TrimStart('?');
        if (string.IsNullOrWhiteSpace(query))
        {
            return mode;
        }

        foreach (var pair in query.Split('&', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var parts = pair.Split('=', 2);
            var key = Uri.UnescapeDataString(parts[0]);
            if (!string.Equals(key, "basemap", StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            if (parts.Length == 1)
            {
                return MapBasemapMode.Empty;
            }

            return ParseBasemapMode(Uri.UnescapeDataString(parts[1])) ?? mode;
        }

        return mode;
    }

    public static MapBasemapMode? ParseBasemapMode(string? value) => value?.Trim().ToLowerInvariant() switch
    {
        "styled" => MapBasemapMode.Styled,
        "empty" => MapBasemapMode.Empty,
        _ => null
    };

    private static bool ResolveMapFeatureFlag(
        IConfiguration configuration,
        Uri uri,
        string configKey,
        string queryKey,
        bool defaultValue)
    {
        var value = configuration[$"Map:{configKey}"];
        var enabled = bool.TryParse(value, out var configValue) ? configValue : defaultValue;

        var query = uri.Query.TrimStart('?');
        if (string.IsNullOrWhiteSpace(query))
        {
            return enabled;
        }

        foreach (var pair in query.Split('&', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var parts = pair.Split('=', 2);
            var key = Uri.UnescapeDataString(parts[0]);
            if (!string.Equals(key, queryKey, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            if (parts.Length == 1)
            {
                return true;
            }

            var rawQueryValue = Uri.UnescapeDataString(parts[1]);
            if (bool.TryParse(rawQueryValue, out var queryValue))
            {
                return queryValue;
            }
        }

        return enabled;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadOnboardingPreferenceAsync();
            if (_enableMapDiagnostics)
            {
                _mapDiagnosticsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/map-diagnostics.module.js");
                await _mapDiagnosticsModule.InvokeVoidAsync("startMapDiagnosticsCapture");
            }

            GeolocationService.PositionChanged += OnPositionChanged;
            MapState.StateChanged += OnMapStateChanged;
            LocationState.StateChanged += OnLocationStateChanged;
            _subscriptionsActive = true;

            if (_enableAutoGpsWatch)
            {
                try
                {
                    await GeolocationService.StartWatchAsync();
                }
                catch
                {
                    _statusMessage = "GPS unavailable. Showing pitches near London.";
                    StateHasChanged();
                }
            }

            _ = DismissStaleLoadingIndicatorAsync();
            _ = CaptureMapDiagnosticsAfterDelayAsync("first-render", TimeSpan.FromSeconds(2));
            _ = CaptureMapDiagnosticsAfterDelayAsync("settled-10s", TimeSpan.FromSeconds(10));
            _ = CaptureMapDiagnosticsAfterDelayAsync("settled-30s", TimeSpan.FromSeconds(30));
        }
    }

    private async Task DismissStaleLoadingIndicatorAsync()
    {
        await Task.Delay(TimeSpan.FromSeconds(8));
        if (!_viewReady && _hasApiKey)
        {
            _viewReady = true;
            _statusMessage ??= "Map is available, but some map services are still settling.";
            _ = CaptureMapDiagnosticsAsync("stale-loading-dismissed");
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnLocationStateChanged(object? sender, EventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task OnViewInitializedAsync()
    {
        _viewReady = true;
        Logger.LogInformation("MapView initialized, loading pitches near London");
        _ = CaptureMapDiagnosticsAfterDelayAsync("view-initialized", TimeSpan.FromSeconds(1));

        await RefreshAuthenticationStateAsync();
        if (_enableGameGraphics && _lastKnownPosition is not null)
        {
            await UpdatePlayerLocationGraphicAsync(_lastKnownPosition);
        }
        if (_enableGameGraphics)
        {
            await LoadPitchMarkersAsync(_latitude, _longitude);
        }
        await RefreshGameProgress();
    }

    private async Task CaptureMapDiagnosticsAfterDelayAsync(string reason, TimeSpan delay)
    {
        await Task.Delay(delay);
        await CaptureMapDiagnosticsAsync(reason);
    }

    private async Task CaptureMapDiagnosticsAsync(string reason)
    {
        if (!_enableMapDiagnostics || _mapDiagnosticsModule is null)
        {
            return;
        }

        try
        {
            var diagnosticsJson = await _mapDiagnosticsModule.InvokeAsync<string>("collectMapDiagnostics", reason);
            Logger.LogWarning("MapDiagnostics {Reason}: {DiagnosticsJson}", reason, diagnosticsJson);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "MapDiagnostics failed for {Reason}", reason);
        }
    }

    private async void OnPositionChanged(GeoPosition pos)
    {
        try
        {
            _lastKnownPosition = pos;
            if (_enableGameGraphics)
            {
                await UpdatePlayerLocationGraphicAsync(pos);
            }
            if (_statusMessage is not null
                && (_statusMessage.StartsWith("GPS", StringComparison.OrdinalIgnoreCase)
                    || _statusMessage.StartsWith("Waiting for GPS", StringComparison.OrdinalIgnoreCase)))
            {
                _statusMessage = null;
            }

            if (!_initialCenterPerformed)
            {
                _initialCenterPerformed = true;
                _latitude = pos.Latitude;
                _longitude = pos.Longitude;
                _homeLatitude = pos.Latitude;
                _homeLongitude = pos.Longitude;
            }

            if (_enableGameGraphics && ShouldRefreshPitches(pos))
            {
                await LoadPitchMarkersAsync(pos.Latitude, pos.Longitude);
            }

            if (_isAuthenticated)
            {
                await SignalRClient.UpdateLocationAsync(pos.Latitude, pos.Longitude);
            }

            UpdateRecruitEligibility();
            if (_selectedPitch is not null)
            {
                _ = RefreshCaptureEligibilityAsync(_selectedPitch.Id);
            }
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error in position change handler");
        }
    }

    private void OnMapStateChanged(object? sender, EventArgs e)
    {
        var state = ((IState<MapState>)sender!).Value;
        if (state.SelectedPitchId.HasValue && state.SelectedPitchId.Value != _lastSelectedPitchId)
        {
            _lastSelectedPitchId = state.SelectedPitchId.Value;
            _selectedPitch = state.VisiblePitches.FirstOrDefault(p => p.Id == state.SelectedPitchId.Value);
            _captureEligibility = null;
            _nearbyPlayerCount = 0;
            if (_selectedPitch is not null)
            {
                _ = RefreshCaptureEligibilityAsync(_selectedPitch.Id);
            }
            _ = InvokeAsync(StateHasChanged);
        }
        else if (!state.SelectedPitchId.HasValue && _selectedPitch is not null)
        {
            _lastSelectedPitchId = -1;
            _selectedPitch = null;
            _captureEligibility = null;
            _nearbyPlayerCount = 0;
            _ = InvokeAsync(StateHasChanged);
        }

        if (state.SelectedEncounterId.HasValue)
        {
            _selectedEncounter = state.VisibleEncounters.FirstOrDefault(e => e.EncounterId == state.SelectedEncounterId.Value);
            UpdateRecruitEligibility();
        }
        else if (_selectedEncounter is not null)
        {
            _selectedEncounter = null;
            _canRecruit = false;
            _recruitBlockedReason = "Select a recruitable player.";
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadPitchMarkersAsync(double lat, double lng)
    {
        if (!_enableGameGraphics || !_viewReady || _mapView is null)
            return;

        try
        {
            var pitches = await ApiClient.GetNearbyPitchesAsync(lat, lng, BrowseRadiusMeters);
            Dispatcher.Dispatch(new SetPitchesAction(pitches.AsReadOnly()));
            await UpdatePitchGraphicsAsync(pitches);

            if (_showCandidatePlaces)
            {
                _candidatePlaces = await ApiClient.GetPitchCandidatePlacesAsync(lat, lng, BrowseRadiusMeters);
                await UpdateCandidatePlaceGraphicsAsync(_candidatePlaces);
            }
            else
            {
                _candidatePlaces = Array.Empty<PitchCandidatePlaceDto>();
                _candidatePlaceGraphics.Clear();
                await SetCandidatePlaceLayerVisibleAsync(false);
            }

            var encounters = new List<PlayerEncounterDto>();
            if (_isAuthenticated)
            {
                encounters = await ApiClient.GetEncountersAsync(lat, lng, EncounterBrowseRadiusMeters);
                _statusMessage = encounters.Count == 0
                    ? "No recruitable players nearby. Head to a real-world park to find players."
                    : null;
            }
            else
            {
                _statusMessage = "Log in to discover recruitable players at nearby real-world parks.";
            }

            Dispatcher.Dispatch(new SetEncountersAction(encounters.AsReadOnly()));
            await UpdateEncounterGraphicsAsync(encounters);

            _lastPitchFetchPosition = new GeoPosition { Latitude = lat, Longitude = lng };
            _lastPitchFetchAtUtc = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load pitch markers");
            _statusMessage = "Failed to load pitches. Map is still usable.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task UpdatePitchGraphicsAsync(List<PitchModel> pitches)
    {
        if (_stadiumPitchLayer is null || _standardPitchLayer is null || _trainingPitchLayer is null) return;

        await ClearPitchLayersAsync();
        _pitchGraphics.Clear();

        var graphics = new List<KeyValuePair<int, Graphic>>(pitches.Count);
        foreach (var pitch in pitches)
        {
            graphics.Add(new KeyValuePair<int, Graphic>(
                pitch.Id,
                new Graphic(
                geometry: new Point(longitude: pitch.Longitude, latitude: pitch.Latitude),
                symbol: GetPitchSymbol(pitch.Type),
                popupTemplate: CreatePitchPopupTemplate(),
                attributes: new AttributesDictionary(new Dictionary<string, object?>
                {
                    ["_ruckrType"] = "pitch",
                    ["_ruckrId"] = pitch.Id,
                    ["name"] = pitch.Name,
                    ["pitchType"] = PitchTypeDisplayName(pitch.Type),
                    ["pitchRole"] = PitchTypeDescription(pitch.Type)
                })
            )));
        }

        try
        {
            await AddPitchGraphicsByTypeAsync(pitches, graphics);
            foreach (var (pitchId, graphic) in graphics)
            {
                _pitchGraphics[pitchId] = graphic;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to add pitch graphics");
        }
    }

    private async Task ClearPitchLayersAsync()
    {
        if (_stadiumPitchLayer is not null)
        {
            await _stadiumPitchLayer.Clear();
        }

        if (_standardPitchLayer is not null)
        {
            await _standardPitchLayer.Clear();
        }

        if (_trainingPitchLayer is not null)
        {
            await _trainingPitchLayer.Clear();
        }
    }

    private async Task AddPitchGraphicsByTypeAsync(
        IReadOnlyList<PitchModel> pitches,
        IReadOnlyList<KeyValuePair<int, Graphic>> graphics)
    {
        var pitchById = pitches.ToDictionary(p => p.Id);

        var stadiumGraphics = graphics
            .Where(g => pitchById.TryGetValue(g.Key, out var pitch) && pitch.Type == PitchType.Stadium)
            .Select(g => g.Value)
            .ToArray();
        var standardGraphics = graphics
            .Where(g => pitchById.TryGetValue(g.Key, out var pitch) && pitch.Type == PitchType.Standard)
            .Select(g => g.Value)
            .ToArray();
        var trainingGraphics = graphics
            .Where(g => pitchById.TryGetValue(g.Key, out var pitch) && pitch.Type == PitchType.Training)
            .Select(g => g.Value)
            .ToArray();

        if (stadiumGraphics.Length > 0 && _stadiumPitchLayer is not null)
        {
            await _stadiumPitchLayer.AddMany(stadiumGraphics);
        }

        if (standardGraphics.Length > 0 && _standardPitchLayer is not null)
        {
            await _standardPitchLayer.AddMany(standardGraphics);
        }

        if (trainingGraphics.Length > 0 && _trainingPitchLayer is not null)
        {
            await _trainingPitchLayer.AddMany(trainingGraphics);
        }
    }

    private async Task UpdateEncounterGraphicsAsync(IReadOnlyList<PlayerEncounterDto> encounters)
    {
        if (_encounterLayer is null) return;

        await _encounterLayer.Clear();
        _encounterGraphics.Clear();

        var graphics = new List<KeyValuePair<Guid, Graphic>>(encounters.Count);
        foreach (var encounter in encounters)
        {
            var symbol = new SimpleMarkerSymbol(
                outline: new Outline(color: new MapColor("#FFFFFF"), width: new Dimension(2)),
                color: EncounterRarityColor(encounter.Rarity),
                size: new Dimension(14),
                style: SimpleMarkerSymbolStyle.Circle);

            graphics.Add(new KeyValuePair<Guid, Graphic>(
                encounter.EncounterId,
                new Graphic(
                    geometry: new Point(longitude: encounter.Longitude, latitude: encounter.Latitude),
                    symbol: symbol,
                    popupTemplate: CreateEncounterPopupTemplate(),
                    attributes: new AttributesDictionary(new Dictionary<string, object?>
                    {
                        ["_ruckrType"] = "encounter",
                        ["_ruckrEncounterId"] = encounter.EncounterId.ToString(),
                        ["name"] = encounter.Name,
                        ["rarity"] = encounter.Rarity,
                        ["level"] = encounter.Level,
                        ["parkName"] = encounter.ParkName
                    })
                )));
        }

        try
        {
            await _encounterLayer.AddMany(graphics.Select(g => g.Value).ToArray());
            foreach (var (encounterId, graphic) in graphics)
            {
                _encounterGraphics[encounterId] = graphic;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to add encounter graphics");
        }
    }

    private async Task UpdateCandidatePlaceGraphicsAsync(IReadOnlyList<PitchCandidatePlaceDto> candidates)
    {
        if (_candidatePlaceLayer is null) return;

        await ClearCandidatePlaceGraphicsAsync();

        var graphics = new List<KeyValuePair<string, Graphic>>(candidates.Count);
        foreach (var candidate in candidates)
        {
            graphics.Add(new KeyValuePair<string, Graphic>(
                candidate.PlaceId,
                new Graphic(
                geometry: new Point(longitude: candidate.Longitude, latitude: candidate.Latitude),
                symbol: GetCandidatePlaceSymbol(candidate.RecommendedPitchType),
                popupTemplate: CreateCandidatePlacePopupTemplate(),
                attributes: new AttributesDictionary(new Dictionary<string, object?>
                {
                    ["_ruckrType"] = "candidate-place",
                    ["_ruckrPlaceId"] = candidate.PlaceId,
                    ["name"] = candidate.Name,
                    ["recommendedPitchType"] = candidate.RecommendedPitchType,
                    ["confidence"] = candidate.Confidence,
                    ["categoryLabel"] = candidate.CategoryLabel,
                    ["matchReason"] = candidate.MatchReason
                })
            )));
        }

        try
        {
            await _candidatePlaceLayer.AddMany(graphics.Select(g => g.Value).ToArray());
            await SetCandidatePlaceLayerVisibleAsync(true);
            foreach (var (placeId, graphic) in graphics)
            {
                _candidatePlaceGraphics[placeId] = graphic;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to add pitch candidate place graphics");
        }
    }

    private async Task ClearCandidatePlaceGraphicsAsync()
    {
        if (_candidatePlaceLayer is null) return;

        await _candidatePlaceLayer.Clear();
        _candidatePlaceGraphics.Clear();
