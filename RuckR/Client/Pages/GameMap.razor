    private bool HasRecruitUi =>
        _selectedEncounter is not null
        || (_isAuthenticated && MapState.Value.VisibleEncounters.Count > 0);

    protected override void OnInitialized()
    {
        _apiKey = Configuration["ArcGISApiKey"] ?? string.Empty;
        _hasApiKey = !ShouldShowMapUnavailableFallback(_apiKey);
        _viewReady = !_hasApiKey;
        var reductionOptions = ResolveMapReductionOptions(Configuration, Navigation.Uri);
        _basemapMode = reductionOptions.BasemapMode;
        _enableArcGisWidgets = reductionOptions.EnableArcGisWidgets;
        _enableMapDiagnostics = reductionOptions.EnableMapDiagnostics;
        _enableGameGraphics = reductionOptions.EnableGameGraphics;
        _enableAutoGpsWatch = reductionOptions.EnableAutoGpsWatch;
        _enableVerboseMapDiagnostics = ResolveMapFeatureFlag(Configuration, new Uri(Navigation.Uri, UriKind.Absolute), "EnableVerboseMapDiagnostics", "mapDiagnosticsVerbose", defaultValue: false);
        _ = RunSpotlightClockAsync(_spotlightClockCts.Token);
    }

    public static MapReductionOptions ResolveMapReductionOptions(IConfiguration configuration, string currentUri)
    {
        var uri = new Uri(currentUri, UriKind.Absolute);

        return new MapReductionOptions(
            BasemapMode: ResolveBasemapMode(configuration, uri),
            EnableArcGisWidgets: ResolveMapFeatureFlag(configuration, uri, "EnableArcGisWidgets", "arcGisWidgets", defaultValue: true),
            EnableMapDiagnostics: ResolveMapFeatureFlag(configuration, uri, "EnableMapDiagnostics", "mapDiagnostics", defaultValue: true),
            EnableGameGraphics: ResolveMapFeatureFlag(configuration, uri, "EnableGameGraphics", "mapGraphics", defaultValue: true),
            EnableAutoGpsWatch: ResolveMapFeatureFlag(configuration, uri, "EnableAutoGpsWatch", "autoGps", defaultValue: true));
    }

    private static MapBasemapMode ResolveBasemapMode(IConfiguration configuration, Uri uri)
    {
        var value = configuration["Map:BasemapMode"];
        var mode = ParseBasemapMode(value) ?? MapBasemapMode.Styled;

        var query = uri.Query.TrimStart('?');
        if (string.IsNullOrWhiteSpace(query))
        {
            return mode;
        }

        foreach (var pair in query.Split('&', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var parts = pair.Split('=', 2);
            var key = Uri.UnescapeDataString(parts[0]);
            if (!string.Equals(key, "basemap", StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            if (parts.Length == 1)
            {
                return MapBasemapMode.Empty;
            }

            return ParseBasemapMode(Uri.UnescapeDataString(parts[1])) ?? mode;
        }

        return mode;
    }

    public static MapBasemapMode? ParseBasemapMode(string? value) => value?.Trim().ToLowerInvariant() switch
    {
        "styled" => MapBasemapMode.Styled,
        "empty" => MapBasemapMode.Empty,
        _ => null
    };

    private static bool ResolveMapFeatureFlag(
        IConfiguration configuration,
        Uri uri,
        string configKey,
        string queryKey,
        bool defaultValue)
    {
        var value = configuration[$"Map:{configKey}"];
        var enabled = bool.TryParse(value, out var configValue) ? configValue : defaultValue;

        var query = uri.Query.TrimStart('?');
        if (string.IsNullOrWhiteSpace(query))
        {
            return enabled;
        }

        foreach (var pair in query.Split('&', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var parts = pair.Split('=', 2);
            var key = Uri.UnescapeDataString(parts[0]);
            if (!string.Equals(key, queryKey, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            if (parts.Length == 1)
            {
                return true;
            }

            var rawQueryValue = Uri.UnescapeDataString(parts[1]);
            if (bool.TryParse(rawQueryValue, out var queryValue))
            {
                return queryValue;
            }
        }

        return enabled;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadOnboardingPreferenceAsync();
            if (_enableMapDiagnostics)
            {
                _mapDiagnosticsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/map-diagnostics.module.js");
                await _mapDiagnosticsModule.InvokeVoidAsync("startMapDiagnosticsCapture");
            }

            GeolocationService.PositionChanged += OnPositionChanged;
            MapState.StateChanged += OnMapStateChanged;
            LocationState.StateChanged += OnLocationStateChanged;
            _subscriptionsActive = true;

            if (_enableAutoGpsWatch)
            {
                try
                {
                    await GeolocationService.StartWatchAsync();
                }
                catch
                {
                    _statusMessage = "GPS unavailable. Showing pitches near London.";
                    StateHasChanged();
                }
            }

            _ = DismissStaleLoadingIndicatorAsync();
            _ = CaptureMapDiagnosticsAfterDelayAsync("settled-10s", TimeSpan.FromSeconds(10));
            if (_enableVerboseMapDiagnostics)
            {
                _ = CaptureMapDiagnosticsAfterDelayAsync("first-render", TimeSpan.FromSeconds(2));
                _ = CaptureMapDiagnosticsAfterDelayAsync("settled-30s", TimeSpan.FromSeconds(30));
            }
        }
    }

    private async Task DismissStaleLoadingIndicatorAsync()
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(8), _diagnosticsCts.Token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        if (_isDisposing)
        {
            return;
        }

        if (!_viewReady && _hasApiKey)
        {
            _viewReady = true;
            _statusMessage ??= "Map is available, but some map services are still settling.";
            _ = CaptureMapDiagnosticsAsync("stale-loading-dismissed");
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnLocationStateChanged(object? sender, EventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task OnViewInitializedAsync()
    {
        _viewReady = true;
        Logger.LogInformation("MapView initialized");
        _ = CaptureMapDiagnosticsAfterDelayAsync("view-initialized", TimeSpan.FromSeconds(1));

        await RefreshAuthenticationStateAsync();
        await RefreshGameProgress();
    }

    private async Task OnViewRenderedAsync()
    {
        if (_isDisposing)
        {
            return;
        }

        _viewReady = true;
        _viewRendered = true;

        if (_initialLayerSyncStarted)
        {
            return;
        }

        _initialLayerSyncStarted = true;
        Logger.LogInformation("MapView rendered, syncing initial graphics layers");
        _ = CaptureMapDiagnosticsAfterDelayAsync("view-rendered", TimeSpan.FromSeconds(1));

        await RefreshAuthenticationStateAsync();
        if (_enableGameGraphics && _lastKnownPosition is not null)
        {
            await UpdatePlayerLocationGraphicAsync(_lastKnownPosition);
        }
        if (_enableGameGraphics)
        {
            await LoadPitchMarkersAsync(_latitude, _longitude);
        }
    }

    private async Task CaptureMapDiagnosticsAfterDelayAsync(string reason, TimeSpan delay)
    {
        try
        {
            await Task.Delay(delay, _diagnosticsCts.Token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        await CaptureMapDiagnosticsAsync(reason);
    }

    private async Task CaptureMapDiagnosticsAsync(string reason)
    {
        if (_isDisposing || !_enableMapDiagnostics || _mapDiagnosticsModule is null)
        {
            return;
        }

        try
        {
            var diagnosticsJson = await _mapDiagnosticsModule.InvokeAsync<string>("collectMapDiagnostics", reason);
            Logger.LogWarning("MapDiagnostics {Reason}: {DiagnosticsJson}", reason, diagnosticsJson);
        }
        catch (Exception ex)
        {
            if (IsExpectedMapDiagnosticsDisposal(ex))
            {
                return;
            }

            Logger.LogWarning(ex, "MapDiagnostics failed for {Reason}", reason);
        }
    }

    private async void OnPositionChanged(GeoPosition pos)
    {
        if (_isDisposing)
        {
            return;
        }

        try
        {
            _lastKnownPosition = pos;
            if (_enableGameGraphics)
            {
                await UpdatePlayerLocationGraphicAsync(pos);
            }
            if (_statusMessage is not null
                && (_statusMessage.StartsWith("GPS", StringComparison.OrdinalIgnoreCase)
                    || _statusMessage.StartsWith("Waiting for GPS", StringComparison.OrdinalIgnoreCase)))
            {
                _statusMessage = null;
            }

            if (!_initialCenterPerformed)
            {
                _initialCenterPerformed = true;
                _latitude = pos.Latitude;
                _longitude = pos.Longitude;
                _homeLatitude = pos.Latitude;
                _homeLongitude = pos.Longitude;
            }

            if (_enableGameGraphics && ShouldRefreshPitches(pos))
            {
                await LoadPitchMarkersAsync(pos.Latitude, pos.Longitude);
            }

            if (_isAuthenticated)
            {
                await SignalRClient.UpdateLocationAsync(pos.Latitude, pos.Longitude);
            }

            UpdateRecruitEligibility();
            if (_selectedPitch is not null)
            {
                _ = RefreshCaptureEligibilityAsync(_selectedPitch.Id);
            }
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            if (IsExpectedGeoBlazorCancellation(ex))
            {
                Logger.LogDebug(ex, "Position change handler cancelled during map lifecycle transition");
                return;
            }

            Logger.LogError(ex, "Error in position change handler");
        }
    }

    private void OnMapStateChanged(object? sender, EventArgs e)
    {
        var state = ((IState<MapState>)sender!).Value;
        if (state.SelectedPitchId.HasValue && state.SelectedPitchId.Value != _lastSelectedPitchId)
        {
            _lastSelectedPitchId = state.SelectedPitchId.Value;
            _selectedPitch = state.VisiblePitches.FirstOrDefault(p => p.Id == state.SelectedPitchId.Value);
            _captureEligibility = null;
            _nearbyPlayerCount = 0;
            if (_selectedPitch is not null)
            {
                _ = RefreshCaptureEligibilityAsync(_selectedPitch.Id);
            }
            _ = InvokeAsync(StateHasChanged);
        }
        else if (!state.SelectedPitchId.HasValue && _selectedPitch is not null)
        {
            _lastSelectedPitchId = -1;
            _selectedPitch = null;
            _captureEligibility = null;
            _nearbyPlayerCount = 0;
            _ = InvokeAsync(StateHasChanged);
        }

        if (state.SelectedEncounterId.HasValue)
        {
            _selectedEncounter = state.VisibleEncounters.FirstOrDefault(e => e.EncounterId == state.SelectedEncounterId.Value);
            UpdateRecruitEligibility();
        }
        else if (_selectedEncounter is not null)
        {
            _selectedEncounter = null;
            _canRecruit = false;
            _recruitBlockedReason = "Select a recruitable player.";
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadPitchMarkersAsync(double lat, double lng)
    {
        if (_isDisposing || !_enableGameGraphics || !_viewRendered || _mapView is null)
            return;

        try
        {
            var pitches = await ApiClient.GetNearbyPitchesAsync(lat, lng, BrowseRadiusMeters);
            if (_isDisposing) return;

            Dispatcher.Dispatch(new SetPitchesAction(pitches.AsReadOnly()));
            await UpdatePitchGraphicsAsync(pitches);
            if (_isDisposing) return;

            if (_showCandidatePlaces)
            {
                _candidatePlaces = await ApiClient.GetPitchCandidatePlacesAsync(lat, lng, BrowseRadiusMeters);
                if (_isDisposing) return;

                await UpdateCandidatePlaceGraphicsAsync(_candidatePlaces);
            }
            else
            {
                _candidatePlaces = Array.Empty<PitchCandidatePlaceDto>();
                _candidatePlaceGraphics.Clear();
                await SetCandidatePlaceLayerVisibleAsync(false);
            }

            var encounters = new List<PlayerEncounterDto>();
            if (_isAuthenticated)
            {
                encounters = await ApiClient.GetEncountersAsync(lat, lng, EncounterBrowseRadiusMeters);
                if (_isDisposing) return;

                Logger.LogInformation(
                    "Map encounters loaded: count={EncounterCount}, authenticated={Authenticated}, lat={Latitude}, lng={Longitude}, radiusMeters={RadiusMeters}",
                    encounters.Count,
                    _isAuthenticated,
                    lat,
                    lng,
                    EncounterBrowseRadiusMeters);

                _statusMessage = encounters.Count == 0
                    ? "No recruitable players nearby. Head to a real-world park to find players."
                    : null;
            }
            else
            {
                Logger.LogInformation(
                    "Map encounters skipped: authenticated={Authenticated}, lat={Latitude}, lng={Longitude}, radiusMeters={RadiusMeters}",
                    _isAuthenticated,
                    lat,
                    lng,
                    EncounterBrowseRadiusMeters);
                _statusMessage = "Log in to discover recruitable players at nearby real-world parks.";
            }

            Dispatcher.Dispatch(new SetEncountersAction(encounters.AsReadOnly()));
            await UpdateEncounterGraphicsAsync(encounters);

            _lastPitchFetchPosition = new GeoPosition { Latitude = lat, Longitude = lng };
            _lastPitchFetchAtUtc = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            if (IsExpectedGeoBlazorCancellation(ex))
            {
                Logger.LogDebug(ex, "Pitch marker load cancelled during map lifecycle transition");
                return;
            }

            Logger.LogError(ex, "Failed to load pitch markers");
            _statusMessage = "Failed to load pitches. Map is still usable.";
        }

        if (!_isDisposing)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task UpdatePitchGraphicsAsync(List<PitchModel> pitches)
    {
        if (_isDisposing || _pitchLayer is null) return;

        var graphics = new List<KeyValuePair<int, Graphic>>(pitches.Count);
        foreach (var pitch in pitches)
        {
            graphics.Add(new KeyValuePair<int, Graphic>(
                pitch.Id,
                MapGraphicFactory.CreatePitchGraphic(
                    pitch,
                    PitchTypeDisplayName(pitch.Type),
                    PitchTypeDescription(pitch.Type))));
        }

        try
        {
            await GraphicsLayerSync.ReplaceManyAsync(_pitchLayer, _pitchGraphics, graphics);
        }
        catch (Exception ex)
        {
            if (IsExpectedGeoBlazorCancellation(ex))
            {
                Logger.LogDebug(ex, "Pitch graphics update cancelled during map lifecycle transition");
                return;
            }

            Logger.LogWarning(ex, "Failed to add pitch graphics");
        }
    }

    private async Task ClearPitchLayersAsync()
    {
        if (_isDisposing) return;

        if (_pitchLayer is not null)
        {
            await _pitchLayer.Clear();
        }
    }

    private async Task UpdateEncounterGraphicsAsync(IReadOnlyList<PlayerEncounterDto> encounters)
    {
        if (_isDisposing || _encounterLayer is null) return;

        var spotlightEncounterId = SpotlightSightingSelector
            .Select(encounters, _lastKnownPosition, DateTime.UtcNow)
            ?.EncounterId;
        var graphics = new List<KeyValuePair<Guid, Graphic>>(encounters.Count);
        foreach (var encounter in encounters)
        {
            graphics.Add(new KeyValuePair<Guid, Graphic>(
                encounter.EncounterId,
                MapGraphicFactory.CreateEncounterGraphic(encounter, encounter.EncounterId == spotlightEncounterId)));
        }

        try
        {
            await GraphicsLayerSync.ReplaceManyAsync(_encounterLayer, _encounterGraphics, graphics);
            Logger.LogInformation(
                "Encounter graphics synced: requested={RequestedCount}, retained={RetainedCount}",
                encounters.Count,
                _encounterGraphics.Count);
        }
        catch (Exception ex)
        {
            if (IsExpectedGeoBlazorCancellation(ex))
            {
                Logger.LogDebug(ex, "Encounter graphics update cancelled during map lifecycle transition");
                return;
            }

            Logger.LogWarning(ex, "Failed to add encounter graphics");
        }
    }

