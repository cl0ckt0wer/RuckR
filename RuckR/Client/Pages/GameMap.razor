    private string RecruitItemCountText(RecruitmentItemKind itemKind)
    {
        if (itemKind == RecruitmentItemKind.None)
            return string.Empty;

        var quantity = _recruitmentProfile?.Items.FirstOrDefault(i => i.ItemKind == itemKind)?.Quantity ?? 0;
        return $"({quantity})";
    }

    private static string FormatDuration(int seconds)
    {
        if (seconds < 60)
        {
            return $"{seconds}s";
        }

        var minutes = seconds / 60;
        var remainderSeconds = seconds % 60;
        return remainderSeconds == 0
            ? $"{minutes}m"
            : $"{minutes}m {remainderSeconds}s";
    }

    private async Task AttemptRecruitment()
    {
        if (_selectedEncounter is null || _isRecruiting) return;

        _isRecruiting = true;
        _recruitMessage = null;
        StateHasChanged();

        try
        {
            var itemKind = CanChooseRecruitmentItem ? _selectedRecruitItem : RecruitmentItemKind.None;
            var result = await ApiClient.AttemptRecruitmentAsync(
                _selectedEncounter.EncounterId,
                _selectedEncounter.PlayerId,
                itemKind,
                _lastKnownPosition);
            if (result is null)
            {
                _recruitMessage = "Recruitment failed. Please try again.";
                _recruitMessageClass = "danger";
            }
            else if (result.Success)
            {
                _activeRecruitment = null;
                _recruitMessage = result.Message;
                _recruitMessageClass = "success";
                _recruitToastMessage = $"{result.Message} +25 XP";
                _recruitToastClass = "success";
                await RefreshGameProgress();
                await LoadPitchMarkersAsync(_lastKnownPosition?.Latitude ?? _latitude, _lastKnownPosition?.Longitude ?? _longitude, "recruitment");
                Dispatcher.Dispatch(new ClearSelectionAction());
            }
            else
            {
                _activeRecruitment = result.RemainingSeconds > 0 || result.CompletesAtUtc is not null ? result : null;
                _recruitMessage = result.Message;
                _recruitMessageClass = _activeRecruitment is null ? "danger" : "success";
                _recruitToastMessage = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Recruitment attempt failed");
            _recruitMessage = "Recruitment failed. Please try again.";
            _recruitMessageClass = "danger";
            _recruitToastMessage = "Recruitment failed. Please try again.";
            _recruitToastClass = "danger";
        }
        finally
        {
            _isRecruiting = false;
            StateHasChanged();
        }
    }

    private double ProgressPercent => _gameProgress is null || _prevLevelXp >= _gameProgress.NextLevelExperience
        ? 0
        : Math.Clamp((double)(_gameProgress.Experience - _prevLevelXp) / (_gameProgress.NextLevelExperience - _prevLevelXp) * 100, 0, 100);

    private async Task RefreshGameProgress()
    {
        await RefreshAuthenticationStateAsync();
        _recruitmentProfile = _isAuthenticated
            ? await ApiClient.GetRecruitmentProfileAsync()
            : null;
        _gameProgress = _recruitmentProfile is null
            ? null
            : new GameProgressDto(_recruitmentProfile.Level, _recruitmentProfile.Experience, _recruitmentProfile.NextLevelExperience);
        _prevLevelXp = _gameProgress is null ? 0 : _gameProgress.Level <= 1 ? 0 : (_gameProgress.Level - 1) * 100;
    }

    private async Task RefreshAuthenticationStateAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
    }

    private int LevelForXp(int xp) => Math.Clamp(1 + (xp / 100), 1, 100);

    private async Task NavigateToPointAsync(double longitude, double latitude, int zoom)
    {
        if (_mapView is null)
        {
            return;
        }

        const double navigationExtentPaddingDegrees = 0.001;
        await _mapView.GoTo(new Extent(
            xmax: longitude + navigationExtentPaddingDegrees,
            xmin: longitude - navigationExtentPaddingDegrees,
            ymax: latitude + navigationExtentPaddingDegrees,
            ymin: latitude - navigationExtentPaddingDegrees,
            spatialReference: SpatialReference.Wgs84));
        await _mapView.SetZoom(zoom);
    }

