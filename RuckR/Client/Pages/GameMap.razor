    private string EncounterRouteInstruction(PlayerEncounterDto encounter)
    {
        var distance = EncounterDistanceMeters(encounter);
        if (!distance.HasValue)
        {
            return $"Enable GPS and head to {EncounterParkName(encounter)}.";
        }

        if (_lastKnownPosition?.Accuracy is > MaxRecruitAccuracyMeters)
        {
            return $"Hold for better GPS accuracy. Current: {_lastKnownPosition.Accuracy.Value:0} m.";
        }

        return distance.Value <= RecruitDistanceMeters
            ? "Recruit window open."
            : $"Move within {FormatDistance(RecruitDistanceMeters)} of the park.";
    }

    private string RecruitStateLabel
    {
        get
        {
            return BuildRecruitStateLabel(
                _selectedEncounter,
                _lastKnownPosition,
                _canRecruit,
                DateTime.UtcNow);
        }
    }

    private string RecruitStateCssClass => RecruitStateCssClassForLabel(RecruitStateLabel);

    public static string BuildRecruitStateLabel(
        PlayerEncounterDto? selectedEncounter,
        GeoPosition? lastKnownPosition,
        bool canRecruit,
        DateTime utcNow)
    {
        if (selectedEncounter is null)
        {
            return "Select a recruitable player.";
        }

        if (FormatEncounterExpiresText(selectedEncounter, utcNow) == "Expired")
        {
            return "Sighting expired";
        }

        if (lastKnownPosition is null)
        {
            return "GPS needed";
        }

        if (lastKnownPosition.Accuracy is > MaxRecruitAccuracyMeters)
        {
            return "Weak GPS";
        }

        return canRecruit ? "Recruit window" : "Move closer";
    }

    public static string RecruitStateCssClassForLabel(string recruitStateLabel) => recruitStateLabel switch
    {
        "Recruit window" => "ready",
        "Weak GPS" => "weak",
        "GPS needed" => "blocked",
        "Sighting expired" => "expired",
        _ => "waiting"
    };

    private static string EncounterExpiresText(PlayerEncounterDto encounter) =>
        FormatEncounterExpiresText(encounter, DateTime.UtcNow);

    public static string FormatEncounterExpiresText(PlayerEncounterDto encounter, DateTime utcNow)
    {
        var remaining = encounter.ExpiresAtUtc - utcNow;
        if (remaining <= TimeSpan.Zero)
        {
            return "Expired";
        }

        if (remaining.TotalMinutes < 1)
        {
            return "<1 min left";
        }

        return remaining.TotalHours >= 1
            ? $"{(int)remaining.TotalHours}h {remaining.Minutes}m left"
            : $"{(int)Math.Ceiling(remaining.TotalMinutes)}m left";
    }

    private void UpdateRecruitEligibility()
    {
        _canRecruit = false;

        if (_selectedEncounter is null)
        {
            _recruitBlockedReason = "Select a recruitable player.";
            return;
        }

        var parkName = EncounterParkName(_selectedEncounter);
        if (_lastKnownPosition is null)
        {
            _recruitBlockedReason = $"Waiting for GPS. Go to {parkName} to recruit.";
            return;
        }

        var distanceMeters = GeoPosition.HaversineDistance(
            _lastKnownPosition,
            new GeoPosition { Latitude = _selectedEncounter.Latitude, Longitude = _selectedEncounter.Longitude });

        if (_lastKnownPosition.Accuracy.HasValue && _lastKnownPosition.Accuracy.Value > MaxRecruitAccuracyMeters)
        {
            _recruitBlockedReason =
                $"Improve GPS accuracy to {MaxRecruitAccuracyMeters:0}m or better. Current accuracy: {_lastKnownPosition.Accuracy.Value:0}m.";
            return;
        }

        if (distanceMeters > RecruitDistanceMeters)
        {
            _recruitBlockedReason = $"Go to {parkName} to recruit. You are about {FormatDistance(distanceMeters)} away.";
            return;
        }

        _canRecruit = true;
        _recruitBlockedReason = $"Ready to recruit at {parkName}.";
    }

    private string RecruitButtonClass()
    {
        if (!_canRecruit) return "secondary";
        return "success";
    }

    private async Task RunSpotlightClockAsync(CancellationToken cancellationToken)
    {
        while (!cancellationToken.IsCancellationRequested)
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(1), cancellationToken);
            }
            catch (OperationCanceledException)
            {
                return;
            }

            if (_isDisposing)
            {
                return;
            }

            if (_selectedEncounter is not null || ActiveSpotlightEncounter is not null || ShouldShowRecruitBoard)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private static string FormatDistance(double distanceMeters)
    {
        return distanceMeters < 1000
            ? $"{Math.Round(distanceMeters)} m"
            : $"{distanceMeters / 1000:0.0} km";
    }

    private static string FormatDistanceBucket(string? bucket)
    {
        if (Enum.TryParse<DistanceBucket>(bucket, out var parsed))
        {
            return parsed switch
            {
                DistanceBucket.Within50m => "< 50m",
                DistanceBucket.Within100m => "< 100m",
                DistanceBucket.Within250m => "< 250m",
                DistanceBucket.Within500m => "< 500m",
                _ => "> 500m"
            };
        }

        return bucket switch
        {
            "<50m" => "< 50m",
            "<100m" => "< 100m",
            "<250m" => "< 250m",
            "<500m" => "< 500m",
            ">500m" => "> 500m",
            _ => "Unknown"
        };
    }

    private static string EncounterParkName(PlayerEncounterDto encounter)
    {
        return string.IsNullOrWhiteSpace(encounter.ParkName)
            ? "this park"
            : encounter.ParkName;
    }

    private string RecruitTimerText
    {
        get
        {
            if (CurrentRecruitmentCompletesAtUtc is not null)
            {
                return $"{FormatDuration(ActiveRecruitmentRemainingSeconds)} remaining";
            }

            var baseSeconds = _selectedEncounter?.BaseRecruitmentSeconds > 0
                ? _selectedEncounter.BaseRecruitmentSeconds
                : 60;
            return $"{FormatDuration(baseSeconds)} recruit time";
        }
    }

    private int ActiveRecruitmentRemainingSeconds
    {
        get
        {
            if (CurrentRecruitmentCompletesAtUtc is null)
            {
                return 0;
            }

            return Math.Max(0, (int)Math.Ceiling((CurrentRecruitmentCompletesAtUtc.Value - DateTime.UtcNow).TotalSeconds));
        }
    }

    private double RecruitTimeProgressPercent
    {
        get
        {
            var requiredSeconds = CurrentRecruitmentRequiredSeconds;
            if (requiredSeconds <= 0)
            {
                return 100;
            }

            var elapsed = requiredSeconds - ActiveRecruitmentRemainingSeconds;
            return Math.Clamp(elapsed / (double)requiredSeconds * 100, 0, 100);
        }
    }

    private string RecruitButtonText =>
        CurrentRecruitmentCompletesAtUtc is not null
            ? CurrentUserJoinedRecruitment
                ? ActiveRecruitmentRemainingSeconds <= 0 ? "Finish recruit" : "Check recruit progress"
                : "Join shared recruit"
            : $"Recruit {_selectedEncounter?.Name}";

    private Color RecruitButtonColor => CurrentRecruitmentCompletesAtUtc is not null && ActiveRecruitmentRemainingSeconds > 0
        ? Color.Info
        : Color.Success;

    private DateTime? CurrentRecruitmentCompletesAtUtc =>
        _activeRecruitment?.CompletesAtUtc ?? _selectedEncounter?.RecruitmentCompletesAtUtc;

    private int CurrentRecruitmentRequiredSeconds =>
        _activeRecruitment?.RequiredDurationSeconds
        ?? _selectedEncounter?.RequiredRecruitmentSeconds
        ?? 0;

    private int CurrentRecruitmentParticipantCount =>
        Math.Max(
            _activeRecruitment?.ParticipantCount
            ?? _selectedEncounter?.ParticipantCount
            ?? 0,
            CurrentUserJoinedRecruitment ? 1 : 0);

    private bool CurrentUserJoinedRecruitment =>
        _activeRecruitment?.CurrentUserJoined
        ?? _selectedEncounter?.CurrentUserJoined
        ?? false;

    private RecruitmentItemKind CurrentRecruitmentGroupItem =>
        _activeRecruitment?.ItemKind
        ?? _selectedEncounter?.GroupItemKind
        ?? RecruitmentItemKind.None;

    private string RecruitParticipantText =>
        CurrentRecruitmentParticipantCount <= 0
            ? "No participants yet"
            : $"{CurrentRecruitmentParticipantCount} participant{(CurrentRecruitmentParticipantCount == 1 ? string.Empty : "s")}";

    private string? RecruitGroupItemText =>
        CurrentRecruitmentGroupItem == RecruitmentItemKind.None
            ? null
            : $"Group item: {CurrentRecruitmentGroupItem}";

    private bool CanChooseRecruitmentItem =>
        CurrentRecruitmentCompletesAtUtc is null
        && CurrentRecruitmentGroupItem == RecruitmentItemKind.None;

    private Severity RecruitMessageSeverity => _recruitMessageClass == "danger"
        ? Severity.Error
        : Severity.Success;

