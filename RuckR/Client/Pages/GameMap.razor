    private async Task RefreshPitchHubAsync(int pitchId)
    {
        if (!_isAuthenticated || (_isLoadingPitchHub && _pitchHubRequestPitchId == pitchId))
        {
            return;
        }

        _pitchHubRequestPitchId = pitchId;
        _isLoadingPitchHub = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var hub = await ApiClient.GetPitchHubAsync(pitchId, _lastKnownPosition);
            if (_selectedPitch?.Id != pitchId)
            {
                return;
            }

            _pitchHub = hub;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load pitch hub {PitchId}", pitchId);
            _pitchHub = null;
        }
        finally
        {
            if (_pitchHubRequestPitchId == pitchId)
            {
                _isLoadingPitchHub = false;
                _pitchHubRequestPitchId = -1;
            }

            await InvokeAsync(StateHasChanged);
        }
    }

