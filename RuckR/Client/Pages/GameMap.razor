    public static string BuildGpsNoticeTitle(GpsStatusView status) => status.Kind switch
    {
        GpsStatusKind.Blocked => "Location permission is off",
        GpsStatusKind.Searching => "GPS needed",
        _ => "GPS needed"
    };

    public static string BuildGpsNoticeBody(GpsStatusView status) => status.Kind switch
    {
        GpsStatusKind.Blocked =>
            "The map still works, but recruiting, capture, and distance checks need browser location permission.",
        GpsStatusKind.Searching =>
