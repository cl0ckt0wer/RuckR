@page "/map"
@page "/"
@using dymaptic.GeoBlazor.Core.Components
@using dymaptic.GeoBlazor.Core.Components.Geometries
@using dymaptic.GeoBlazor.Core.Components.Layers
@using dymaptic.GeoBlazor.Core.Components.Popups
@using dymaptic.GeoBlazor.Core.Components.Symbols
@using dymaptic.GeoBlazor.Core.Components.Views
@using dymaptic.GeoBlazor.Core.Components.Widgets
@using dymaptic.GeoBlazor.Core.Enums
@using dymaptic.GeoBlazor.Core.Events
@using dymaptic.GeoBlazor.Core.Model
@using Fluxor
@using RuckR.Client.MapRendering
@using RuckR.Client.Services
@using RuckR.Client.Store.MapFeature
@using RuckR.Client.Store.LocationFeature
@using RuckR.Shared.Models
@inject IConfiguration Configuration
@inject ILogger<GameMap> Logger
@inject IGeolocationService GeolocationService
@inject ApiClientService ApiClient
@inject SignalRClientService SignalRClient
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IDispatcher Dispatcher
@inject IState<MapState> MapState
@inject IState<LocationState> LocationState
@implements IAsyncDisposable

<div class="map-shell @(HasRecruitUi ? "map-shell--recruit-ui" : null)" data-testid="map-container">
    @if (!_hasApiKey)
    {
        <div class="map-unavailable-shell" data-testid="map-unavailable">
            <div class="map-unavailable-panel">
                <p class="map-unavailable-panel__eyebrow">Map offline</p>
                <h2>@MapUnavailableTitle</h2>
                <p>@MapUnavailableBody</p>
                <div class="map-unavailable-panel__actions">
                    <a class="btn btn-sm btn-primary" href="/catalog">Browse players</a>
                    <a class="btn btn-sm btn-outline-secondary" href="/collection">View collection</a>
                </div>
            </div>
        </div>
    }

    <div data-testid="map-loading" class="map-loading" style="@(_viewReady || !_hasApiKey ? "display:none" : "")">
        <div class="spinner-border text-light" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    @if (_hasApiKey)
    {
        <MapView @ref="_mapView"
                 Latitude="@_latitude"
                 Longitude="@_longitude"
                 Zoom="@_zoom"
                 OnClick="HandleMapClick"
                 OnViewInitialized="OnViewInitializedAsync"
                 OnViewRendered="OnViewRenderedAsync"
                 ShowZoomWidget="true"
                 Style="height: calc(100dvh - 3.5rem); min-height: 480px; width: 100%;">
            <Map>
                @if (_basemapMode == MapBasemapMode.Styled)
                {
                    <Basemap>
                        <BasemapStyle Name="@BasemapStyleName.ArcgisNavigation" ApiKey="@_apiKey" />
                    </Basemap>
                }
                @if (_enableGameGraphics)
                {
                    <GraphicsLayer @ref="_playerLocationLayer" Title="Player location" />
                    <GraphicsLayer @ref="_encounterLayer" Title="Encounters" />
                    <GraphicsLayer @ref="_candidatePlaceLayer" Title="Candidate places" Visible="@_showCandidatePlaces" />
                    <GraphicsLayer @ref="_pitchLayer" Title="Pitches" />
                }
            </Map>
            @if (_enableArcGisWidgets)
            {
                <HomeWidget Position="OverlayPosition.TopLeft" />
                <CompassWidget Position="OverlayPosition.TopLeft" />
                <LocateWidget Position="OverlayPosition.TopLeft" />
                <ScaleBarWidget Position="OverlayPosition.BottomLeft" />
            }
        </MapView>

        @if (_enableArcGisWidgets)
        {
            <div class="map-key" data-testid="map-key" aria-label="Map key">
                <div class="map-key__title">Map key</div>
                <div class="map-key__row">
                    <span class="map-key__symbol map-key__symbol--standard"></span>
                    <span>Standard pitch</span>
                </div>
                <div class="map-key__row">
                    <span class="map-key__symbol map-key__symbol--training"></span>
                    <span>Training pitch</span>
                </div>
                <div class="map-key__row">
                    <span class="map-key__symbol map-key__symbol--stadium"></span>
                    <span>Stadium</span>
                </div>
                <div class="map-key__row">
                    <span class="map-key__symbol map-key__symbol--encounter"></span>
                    <span>Recruit</span>
                </div>
                <div class="map-key__row">
                    <span class="map-key__symbol map-key__symbol--candidate"></span>
                    <span>Candidate place</span>
                </div>
                <div class="map-key__row">
                    <span class="map-key__symbol map-key__symbol--player"></span>
                    <span>You</span>
                </div>
            </div>
        }

        @if (ShouldShowGpsNotice)
        {
            <div class="gps-readiness" data-testid="gps-readiness">
                <div>
                    <div class="gps-readiness__title">@GpsNoticeTitle</div>
                    <p>@GpsNoticeBody</p>
                </div>
                <button class="btn btn-sm btn-outline-light"
                        type="button"
                        data-testid="gps-retry-btn"
                        @onclick="EnableGpsAsync">
                    Retry GPS
                </button>
            </div>
        }

        @if (_isAuthenticated && _selectedEncounter is null && MapState.Value.VisibleEncounters.Count > 0)
        {
            <div class="encounter-radar" data-testid="encounter-radar">
                <div class="encounter-radar__header">
                    <span>Recruit board</span>
                    <strong>@MapState.Value.VisibleEncounters.Count</strong>
                </div>
                @if (SpotlightEncounter is not null)
                {
                    <button class="encounter-radar__target encounter-radar__target--spotlight"
                            data-testid="spotlight-encounter-btn"
                            type="button"
                            aria-label="Rare sighting: @SpotlightEncounter.Name"
                            @onclick="() => SelectEncounterAsync(SpotlightEncounter)">
                        <span>
                            <small class="encounter-radar__kicker">Rare sighting</small>
                            <strong>@SpotlightEncounter.Name</strong>
                            <small>@SpotlightSightingSummary(SpotlightEncounter)</small>
                        </span>
                        <span class="encounter-radar__timer">@EncounterExpiresText(SpotlightEncounter)</span>
                    </button>
                }
            </div>
        }
    }
</div>

@if (_showOnboarding)
{
    <div class="onboarding-banner" data-testid="onboarding-banner">
        <span class="onboarding-text">Welcome to RuckR! Explore the map to find pitches and recruit players.</span>
        <button class="btn-close btn-close-white" data-testid="onboarding-close" @onclick="DismissOnboarding" aria-label="Dismiss"></button>
    </div>
}

@if (_selectedPitch is not null)
{
    <div class="map-overlay pitch-card pitch-card--@PitchTypeCssClass(_selectedPitch.Type)" data-testid="pitch-overlay">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <div class="pitch-card__eyebrow">@PitchTypeDisplayName(_selectedPitch.Type)</div>
                <h5 class="mb-0" data-testid="pitch-name">@_selectedPitch.Name</h5>
            </div>
            <button type="button" class="btn-close" data-testid="pitch-close" @onclick="ClearSelection" aria-label="Close"></button>
        </div>
        <div class="pitch-card__meta mb-2">
            <span class="pitch-card__pill">@PitchTypeDescription(_selectedPitch.Type)</span>
            <span class="pitch-card__distance">@PitchDistanceText(_selectedPitch)</span>
        </div>
        <div class="capture-panel" data-testid="capture-panel">
            <div class="capture-panel__row">
                <span>Available players</span>
                @if (_isLoadingEligibility)
                {
                    <span class="spinner-border spinner-border-sm text-light" role="status"></span>
                }
                else
                {
                    <strong data-testid="available-player-count">@_nearbyPlayerCount</strong>
                }
            </div>
            <div class="capture-panel__row">
                <span>Capture range</span>
                <strong>@CaptureDistanceText</strong>
            </div>
            <p class="capture-panel__status" data-testid="capture-status">@CaptureStatusText</p>
            @if (GpsActionHint is not null)
            {
                <p class="capture-panel__gps" data-testid="capture-gps-hint">@GpsActionHint</p>
            }
            <button class="btn btn-sm btn-primary w-100"
                    data-testid="capture-players-btn"
                    disabled="@(!CanCaptureSelectedPitch)"
                    @onclick="NavigateToCapture">
                Capture Players
            </button>
        </div>
    </div>
}

@if (_selectedEncounter is not null)
{
    <div class="map-overlay map-overlay--encounter @(IsSpotlightEncounter(_selectedEncounter) ? "map-overlay--spotlight" : null)" data-testid="encounter-overlay">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <div class="encounter-card__eyebrow" data-testid="encounter-kicker">
                    @(IsSpotlightEncounter(_selectedEncounter) ? "Rare sighting" : EncounterParkName(_selectedEncounter))
                </div>
                <h5 class="mb-0" data-testid="encounter-name">@_selectedEncounter.Name</h5>
            </div>
            <button type="button" class="btn-close" data-testid="encounter-close" @onclick="ClearEncounterSelection" aria-label="Close"></button>
        </div>
        <div class="mb-2 d-flex gap-2 flex-wrap">
            <span class="badge bg-@EncounterRarityBadgeClass(_selectedEncounter.Rarity) me-2">@_selectedEncounter.Rarity</span>
            @if (IsSpotlightEncounter(_selectedEncounter))
            {
                <span class="badge spotlight-timer" data-testid="spotlight-timer">@EncounterExpiresText(_selectedEncounter)</span>
            }
            <span class="badge bg-secondary">Level @_selectedEncounter.Level</span>
            <span class="badge bg-dark">@_selectedEncounter.Position</span>
            @if (!IsSpotlightEncounter(_selectedEncounter))
            {
                <span class="badge bg-info text-dark">@EncounterExpiresText(_selectedEncounter)</span>
            }
        </div>
        @if (IsSpotlightEncounter(_selectedEncounter))
        {
            <p class="encounter-card__spotlight-copy" data-testid="spotlight-copy">
                Last chance at @EncounterParkName(_selectedEncounter). Close the distance and recruit before the bell.
            </p>
        }
        <div class="encounter-card__route mb-2">
            <span>@EncounterDistanceText(_selectedEncounter)</span>
            <strong>@EncounterRouteInstruction(_selectedEncounter)</strong>
        </div>
        <div class="encounter-card__state mb-2 encounter-card__state--@RecruitStateCssClass" data-testid="spotlight-recruit-state">
            @RecruitStateLabel
        </div>
        <div class="encounter-card__chance mb-3"
             role="timer"
             aria-label="Recruitment time needed"
             data-testid="recruit-time-needed">
            <div style="width:@RecruitTimeProgressPercent%"></div>
            <span>@RecruitTimerText</span>
        </div>
        <div class="encounter-card__items mb-3" data-testid="recruit-item-picker">
            <label class="form-label small mb-1" for="recruit-item">Use item</label>
            <select id="recruit-item"
                    class="form-select form-select-sm"
                    disabled="@(_activeRecruitment is not null)"
                    @bind="_selectedRecruitItem">
                <option value="@RecruitmentItemKind.None">No item</option>
                <option value="@RecruitmentItemKind.Chips">Chips</option>
                <option value="@RecruitmentItemKind.Beer">Beer</option>
                <option value="@RecruitmentItemKind.Whiskey">Whiskey</option>
            </select>
        </div>
        @if (_activeRecruitment?.Boosts is { Count: > 0 } boosts)
        {
            <div class="encounter-card__boosts mb-3" data-testid="recruit-boosts">
                @foreach (var boost in boosts)
                {
                    <span>@boost.Label</span>
                }
            </div>
        }
        <button class="btn btn-sm btn-@RecruitButtonClass()"
                data-testid="recruit-btn"
                disabled="@(!_canRecruit)"
                title="@_recruitBlockedReason"
                @onclick="AttemptRecruitment">
            @if (_isRecruiting)
            {
                <span class="spinner-border spinner-border-sm" role="status"></span>
            }
            else
            {
                @RecruitButtonText
            }
        </button>
        @if (!_canRecruit)
        {
            <p class="small mt-2 mb-0 text-warning">@_recruitBlockedReason</p>
        }
        @if (GpsActionHint is not null)
        {
            <p class="small mt-1 mb-0 text-muted" data-testid="recruit-gps-hint">@GpsActionHint</p>
        }
        @if (_recruitMessage is not null)
        {
            <p class="small mt-2 mb-0 text-@_recruitMessageClass">@_recruitMessage</p>
        }
    </div>
}

@if (_selectedCandidatePlace is not null)
{
    <div class="map-overlay pitch-card" data-testid="candidate-place-overlay">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <div class="pitch-card__eyebrow">Candidate place</div>
                <h5 class="mb-0" data-testid="candidate-place-name">@_selectedCandidatePlace.Name</h5>
            </div>
            <button type="button" class="btn-close" data-testid="candidate-place-close" @onclick="ClearCandidateSelection" aria-label="Close"></button>
        </div>
        <div class="pitch-card__meta mb-2">
            <span class="pitch-card__pill">@_selectedCandidatePlace.CategoryLabel</span>
            <span class="pitch-card__distance">@CandidateDistanceText(_selectedCandidatePlace)</span>
        </div>
        <p class="capture-panel__status mb-2">
            @_selectedCandidatePlace.MatchReason. Confidence @_selectedCandidatePlace.Confidence%.
        </p>
        <div class="mb-2">
            <label class="form-label small text-muted mb-1" for="candidate-pitch-name">Pitch name</label>
            <input id="candidate-pitch-name"
                   class="form-control form-control-sm"
                   data-testid="candidate-pitch-name-input"
                   maxlength="200"
                   @bind="_candidatePitchName" />
        </div>
        <div class="mb-3">
            <label class="form-label small text-muted mb-1" for="candidate-pitch-type">Pitch type</label>
            <select id="candidate-pitch-type"
                    class="form-select form-select-sm"
                    data-testid="candidate-pitch-type-select"
                    @bind="_candidatePitchType">
                <option value="Stadium">Stadium</option>
                <option value="Standard">Standard</option>
                <option value="Training">Training</option>
            </select>
        </div>
        @if (_candidateCreateMessage is not null)
        {
            <p class="small mb-2 text-@_candidateCreateMessageClass">@_candidateCreateMessage</p>
        }
        <button class="btn btn-sm btn-primary w-100"
                data-testid="create-candidate-pitch-btn"
                disabled="@(!CanCreateSelectedCandidatePitch)"
                @onclick="CreateSelectedCandidatePitchAsync">
            @if (_isCreatingCandidatePitch)
            {
                <span class="spinner-border spinner-border-sm" role="status"></span>
            }
            else if (_isAuthenticated)
            {
                @:Create pitch
            }
            else
            {
                @:Log in to create pitch
            }
        </button>
    </div>
}

@if (_recruitToastMessage is not null)
{
    <div class="recruit-toast recruit-toast--@_recruitToastClass" data-testid="recruit-toast">
        @_recruitToastMessage
        <button type="button" class="btn-close btn-close-white" @onclick="DismissRecruitToast" aria-label="Dismiss"></button>
    </div>
}

@if (_gameProgress is not null)
{
    <div class="game-progress-chip" title="Level @_gameProgress.Level — @_gameProgress.Experience / @_gameProgress.NextLevelExperience XP">
        <span class="fw-bold">@_gameProgress.Level</span>
        <div class="progress flex-grow-1 ms-2">
            <div class="progress-bar"
                 role="progressbar"
                 style="width:@ProgressPercent%; min-width: 8px;"
                 aria-valuenow="@_gameProgress.Experience - _prevLevelXp"
                 aria-valuemin="0"
                 aria-valuemax="@_gameProgress.NextLevelExperience - _prevLevelXp">
            </div>
        </div>
    </div>
}

<div class="map-info-bar">
    <span class="text-muted small">
        @if (_statusMessage is not null)
        {
            @_statusMessage
        }
        else if (_pitchGraphics.Count > 0 || _encounterGraphics.Count > 0 || _candidatePlaceGraphics.Count > 0)
        {
            <text>@_pitchGraphics.Count pitches, @_encounterGraphics.Count encounters, @CandidatePlaceCount candidates visible. Tap a marker to see details.</text>
        }
        else
        {
            <text>Loading...</text>
        }
    </span>
</div>

<style>
     .onboarding-banner {
         position: fixed;
         top: 0.75rem;
         left: 50%;
         z-index: 1500;
         display: flex;
         align-items: center;
         justify-content: space-between;
         gap: 0.75rem;
         width: min(640px, calc(100vw - 1.5rem));
         transform: translateX(-50%);
         border: 1px solid rgba(255,255,255,0.16);
         border-radius: 0.5rem;
         padding: 0.65rem 0.8rem;
         background: rgba(15,23,42,0.94);
         color: #fff;
         box-shadow: 0 16px 40px rgba(0,0,0,0.28);
     }
     .onboarding-text {
         min-width: 0;
         font-size: 0.9rem;
         line-height: 1.35;
     }
     .gps-readiness {
         position: absolute;
         top: 0.75rem;
         right: 0.75rem;
         z-index: 11;
         display: grid;
         grid-template-columns: minmax(0, 1fr) auto;
         align-items: center;
         gap: 0.75rem;
         width: min(420px, calc(100vw - 1.5rem));
         border: 1px solid rgba(250,204,21,0.32);
         border-radius: 0.5rem;
         padding: 0.7rem 0.8rem;
         background: rgba(24, 21, 12, 0.92);
         color: #fff;
         box-shadow: 0 16px 40px rgba(0,0,0,0.3);
         backdrop-filter: blur(8px);
     }
     .gps-readiness__title {
         margin-bottom: 0.15rem;
         font-size: 0.78rem;
         font-weight: 800;
         letter-spacing: 0.08em;
         text-transform: uppercase;
         color: #fde68a;
     }
     .gps-readiness p {
         margin: 0;
         font-size: 0.82rem;
         line-height: 1.35;
         color: rgba(248,250,252,0.86);
     }
     .gps-readiness .btn {
         white-space: nowrap;
     }
     .encounter-radar {
         position: absolute;
         top: 25.75rem;
         left: 0.75rem;
         z-index: 10;
         width: min(260px, calc(100vw - 1.5rem));
         padding: 0.6rem;
         border: 1px solid rgba(74,222,128,0.22);
         border-radius: 0.5rem;
         background: rgba(12, 20, 18, 0.9);
         color: #f8fafc;
         box-shadow: 0 16px 36px rgba(0,0,0,0.28);
         backdrop-filter: blur(8px);
     }
     .encounter-radar__header {
         display: flex;
         justify-content: space-between;
         align-items: center;
         margin-bottom: 0.45rem;
         font-size: 0.72rem;
         font-weight: 800;
         letter-spacing: 0.08em;
         text-transform: uppercase;
         color: rgba(226,232,240,0.78);
     }
     .encounter-radar__header strong {
         display: inline-flex;
         align-items: center;
         justify-content: center;
         min-width: 1.45rem;
         height: 1.45rem;
         border-radius: 999px;
         background: rgba(34,197,94,0.22);
         color: #bbf7d0;
     }
     .encounter-radar__target {
         display: grid;
         grid-template-columns: minmax(0, 1fr) auto;
         align-items: center;
         gap: 0.6rem;
         width: 100%;
         border: 1px solid rgba(255,255,255,0.1);
         border-radius: 0.4rem;
         padding: 0.5rem 0.55rem;
         background: rgba(255,255,255,0.06);
         color: inherit;
         text-align: left;
     }
     .encounter-radar__target:hover {
         background: rgba(34,197,94,0.14);
     }
     .encounter-radar__target--spotlight {
         min-height: 4.2rem;
         border-color: rgba(244,201,93,0.68);
         background: linear-gradient(135deg, rgba(24,47,37,0.94), rgba(54,43,26,0.9));
         box-shadow: inset 0 0 0 1px rgba(255,255,255,0.05);
     }
     .encounter-radar__target--spotlight:hover {
         background: linear-gradient(135deg, rgba(31,65,48,0.96), rgba(69,54,31,0.92));
     }
     .encounter-radar__target strong,
     .encounter-radar__target small {
         display: block;
         overflow: hidden;
         text-overflow: ellipsis;
         white-space: nowrap;
     }
     .encounter-radar__kicker {
         margin-bottom: 0.08rem;
         color: #f4c95d !important;
         font-weight: 900;
         letter-spacing: 0.08em;
         text-transform: uppercase;
     }
     .encounter-radar__target small,
     .encounter-radar__target > span:last-child {
         font-size: 0.76rem;
         color: rgba(226,232,240,0.72);
     }
     .encounter-radar__timer {
         align-self: stretch;
         display: inline-flex;
         align-items: center;
         min-height: 2.75rem;
         border-radius: 0.35rem;
         padding: 0 0.45rem;
         background: rgba(244,201,93,0.16);
         color: #fff7d6 !important;
         font-weight: 900;
     }

     .map-overlay {
         position: absolute;
         bottom: 1rem;
         left: 0.5rem;
         right: 0.5rem;
         max-width: 380px;
         margin: 0 auto;
         background: rgba(33,37,41,0.92);
         border: 1px solid rgba(255,255,255,0.15);
         border-radius: 0.5rem;
         padding: 0.75rem 1rem;
         color: #fff;
         z-index: 10;
     }
     .map-overlay--encounter {
         border-color: rgba(74,222,128,0.4);
     }
     .map-overlay--spotlight {
         border-color: rgba(244,201,93,0.72);
         background:
             linear-gradient(180deg, rgba(33,37,41,0.96), rgba(19,31,26,0.96));
         box-shadow: 0 18px 44px rgba(0,0,0,0.4), inset 0 1px 0 rgba(244,201,93,0.18);
     }
     .encounter-card__eyebrow {
         margin-bottom: 0.15rem;
         font-size: 0.72rem;
         font-weight: 800;
         letter-spacing: 0.08em;
         text-transform: uppercase;
         color: rgba(187,247,208,0.8);
     }
     .map-overlay--spotlight .encounter-card__eyebrow {
         color: #f4c95d;
     }
     .spotlight-timer {
         background: rgba(244,201,93,0.94);
         color: #1f2933;
     }
     .encounter-card__spotlight-copy {
         margin: -0.1rem 0 0.55rem;
         font-size: 0.82rem;
         line-height: 1.35;
         color: rgba(255,247,214,0.88);
     }
     .encounter-card__route {
         display: grid;
         grid-template-columns: auto 1fr;
         align-items: center;
         gap: 0.6rem;
         border-radius: 0.45rem;
         padding: 0.5rem 0.6rem;
         background: rgba(34,197,94,0.1);
     }
     .encounter-card__route span {
         color: #bbf7d0;
         font-weight: 700;
     }
     .encounter-card__route strong {
         min-width: 0;
         font-size: 0.82rem;
         color: rgba(248,250,252,0.9);
     }
     .encounter-card__state {
         min-height: 2.75rem;
         display: flex;
         align-items: center;
         border-radius: 0.45rem;
         padding: 0.45rem 0.6rem;
         font-size: 0.82rem;
         font-weight: 900;
         text-transform: uppercase;
         letter-spacing: 0.04em;
     }
     .encounter-card__state--ready {
         background: rgba(34,197,94,0.16);
         color: #bbf7d0;
     }
     .encounter-card__state--weak,
     .encounter-card__state--waiting {
         background: rgba(244,201,93,0.14);
         color: #fde68a;
     }
     .encounter-card__state--blocked,
     .encounter-card__state--expired {
         background: rgba(185,28,28,0.18);
         color: #fecaca;
     }
     .encounter-card__chance {
         position: relative;
         height: 1.35rem;
