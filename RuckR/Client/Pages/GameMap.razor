    private async Task ToggleCandidatePlacesAsync()
    {
        _showCandidatePlaces = !_showCandidatePlaces;
        if (!_showCandidatePlaces)
        {
            _candidatePlaces = Array.Empty<PitchCandidatePlaceDto>();
            _candidatePlaceGraphics.Clear();
            ClearCandidateSelection();
            await SetCandidatePlaceLayerVisibleAsync(false);
            _statusMessage = "Candidate place overlay hidden.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        var lat = _lastKnownPosition?.Latitude ?? _lastPitchFetchPosition?.Latitude ?? _latitude;
        var lng = _lastKnownPosition?.Longitude ?? _lastPitchFetchPosition?.Longitude ?? _longitude;
        _candidatePlaces = await ApiClient.GetPitchCandidatePlacesAsync(lat, lng, BrowseRadiusMeters);
        await UpdateCandidatePlaceGraphicsAsync(_candidatePlaces);
        _statusMessage = _candidatePlaces.Count == 0
            ? "No candidate places found in this map area."
            : $"{_candidatePlaces.Count} candidate places visible.";
        await InvokeAsync(StateHasChanged);
