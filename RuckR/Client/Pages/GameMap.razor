    private bool TrySelectCandidatePlaceGraphic(MapSelection selection)
    {
        if (selection.CandidatePlaceId is { Length: > 0 } placeId)
        {
            SelectCandidatePlace(placeId);
        }

        var name = selection.CandidateName ?? _selectedCandidatePlace?.Name ?? "Candidate place";
        var recommendedType = selection.CandidateRecommendedPitchType ?? _selectedCandidatePlace?.RecommendedPitchType ?? "Pitch";
        var confidence = selection.CandidateConfidence ?? "?";
        var reason = selection.CandidateMatchReason ?? "matched place category";
        var category = selection.CandidateCategoryLabel ?? "Place";
        _statusMessage = $"Candidate: {name} -> {recommendedType} ({confidence}%). {reason}; {category}.";
        Dispatcher.Dispatch(new ClearSelectionAction());
        StateHasChanged();
        return true;
    }

