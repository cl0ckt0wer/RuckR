    private string DistanceBucketFromPosition(double lat, double lng)
    {
        if (_lastKnownPosition is null) return "unknown";
        var d = GeoPosition.HaversineDistance(_lastKnownPosition!, new GeoPosition { Latitude = lat, Longitude = lng });
        return d < 50 ? "<50m" : d < 100 ? "<100m" : d < 250 ? "<250m" : d < 500 ? "<500m" : ">500m";
    }

    private PlayerEncounterDto? NearestEncounter => MapState.Value.VisibleEncounters
        .OrderBy(e => EncounterDistanceMeters(e) ?? double.MaxValue)
        .ThenBy(e => e.ExpiresAtUtc)
        .FirstOrDefault();

    private async Task SelectEncounterAsync(PlayerEncounterDto? encounter)
    {
        if (encounter is null)
        {
            return;
        }

        _selectedEncounter = encounter;
        _recruitMessage = null;
        UpdateRecruitEligibility();
        Dispatcher.Dispatch(new SelectEncounterAction(encounter.EncounterId));

        if (_mapView is not null)
        {
            try
            {
                await _mapView.SetCenter(new Point(longitude: encounter.Longitude, latitude: encounter.Latitude));
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Failed to center on selected encounter");
            }
        }
    }

    private double? EncounterDistanceMeters(PlayerEncounterDto encounter)
    {
        if (_lastKnownPosition is null)
        {
            return null;
        }

        return GeoPosition.HaversineDistance(
            _lastKnownPosition,
            new GeoPosition { Latitude = encounter.Latitude, Longitude = encounter.Longitude });
    }

    private string EncounterDistanceText(PlayerEncounterDto encounter)
    {
        var distance = EncounterDistanceMeters(encounter);
        return distance.HasValue ? FormatDistance(distance.Value) : "GPS pending";
    }

    private string EncounterRouteInstruction(PlayerEncounterDto encounter)
    {
        var distance = EncounterDistanceMeters(encounter);
        if (!distance.HasValue)
        {
            return $"Enable GPS and head to {EncounterParkName(encounter)}.";
        }

        if (_lastKnownPosition?.Accuracy is > MaxRecruitAccuracyMeters)
        {
            return $"Hold for better GPS accuracy. Current: {_lastKnownPosition.Accuracy.Value:0} m.";
        }

        return distance.Value <= RecruitDistanceMeters
            ? "In range. Make the recruit attempt."
            : $"Move within {RecruitDistanceMeters:0} m of the park.";
    }

    private static string EncounterExpiresText(PlayerEncounterDto encounter)
    {
        var remaining = encounter.ExpiresAtUtc - DateTime.UtcNow;
        if (remaining <= TimeSpan.Zero)
        {
            return "Expired";
        }

        if (remaining.TotalMinutes < 1)
        {
            return "<1 min left";
        }

        return remaining.TotalHours >= 1
            ? $"{(int)remaining.TotalHours}h {remaining.Minutes}m left"
            : $"{(int)Math.Ceiling(remaining.TotalMinutes)}m left";
    }

    private void UpdateRecruitEligibility()
    {
        _canRecruit = false;

        if (_selectedEncounter is null)
        {
            _recruitBlockedReason = "Select a recruitable player.";
            return;
        }

        var parkName = EncounterParkName(_selectedEncounter);
        if (_lastKnownPosition is null)
        {
            _recruitBlockedReason = $"Waiting for GPS. Go to {parkName} to recruit.";
            return;
        }

        var distanceMeters = GeoPosition.HaversineDistance(
            _lastKnownPosition,
            new GeoPosition { Latitude = _selectedEncounter.Latitude, Longitude = _selectedEncounter.Longitude });

        if (_lastKnownPosition.Accuracy.HasValue && _lastKnownPosition.Accuracy.Value > MaxRecruitAccuracyMeters)
        {
            _recruitBlockedReason =
                $"Improve GPS accuracy to {MaxRecruitAccuracyMeters:0}m or better. Current accuracy: {_lastKnownPosition.Accuracy.Value:0}m.";
            return;
        }

        if (distanceMeters > RecruitDistanceMeters)
        {
            _recruitBlockedReason = $"Go to {parkName} to recruit. You are about {FormatDistance(distanceMeters)} away.";
            return;
        }

        _canRecruit = true;
        _recruitBlockedReason = $"Ready to recruit at {parkName}.";
    }

    private string RecruitButtonClass()
    {
        if (!_canRecruit) return "secondary";
        return "success";
    }

    private static string FormatDistance(double distanceMeters)
    {
        return distanceMeters < 1000
            ? $"{Math.Round(distanceMeters)} m"
            : $"{distanceMeters / 1000:0.0} km";
    }

    private static string FormatDistanceBucket(string? bucket)
    {
        if (Enum.TryParse<DistanceBucket>(bucket, out var parsed))
        {
            return parsed switch
            {
                DistanceBucket.Within50m => "< 50m",
                DistanceBucket.Within100m => "< 100m",
                DistanceBucket.Within250m => "< 250m",
                DistanceBucket.Within500m => "< 500m",
                _ => "> 500m"
            };
        }

        return bucket switch
        {
            "<50m" => "< 50m",
            "<100m" => "< 100m",
            "<250m" => "< 250m",
            "<500m" => "< 500m",
            ">500m" => "> 500m",
            _ => "Unknown"
        };
    }

    private static string EncounterParkName(PlayerEncounterDto encounter)
    {
        return string.IsNullOrWhiteSpace(encounter.ParkName)
            ? "this park"
            : encounter.ParkName;
    }

    private async Task AttemptRecruitment()
    {
        if (_selectedEncounter is null || _isRecruiting) return;

        _isRecruiting = true;
        _recruitMessage = null;
        StateHasChanged();

        try
        {
            var result = await ApiClient.AttemptRecruitmentAsync(_selectedEncounter.EncounterId, _selectedEncounter.PlayerId);
            if (result is null)
            {
                _recruitMessage = "Recruitment failed. Please try again.";
                _recruitMessageClass = "danger";
            }
            else if (result.Success)
            {
                _recruitMessage = result.Message;
                _recruitMessageClass = "success";
                _recruitToastMessage = $"{result.Message} +25 XP";
                _recruitToastClass = "success";
                await RefreshGameProgress();
                await LoadPitchMarkersAsync(_lastKnownPosition?.Latitude ?? _latitude, _lastKnownPosition?.Longitude ?? _longitude);
                Dispatcher.Dispatch(new ClearSelectionAction());
            }
            else
            {
                _recruitMessage = result.Message;
                _recruitMessageClass = "danger";
                _recruitToastMessage = null;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Recruitment attempt failed");
            _recruitMessage = "Recruitment failed. Please try again.";
            _recruitMessageClass = "danger";
            _recruitToastMessage = "Recruitment failed. Please try again.";
            _recruitToastClass = "danger";
        }
        finally
        {
            _isRecruiting = false;
            StateHasChanged();
        }
    }

    private double ProgressPercent => _gameProgress is null || _prevLevelXp >= _gameProgress.NextLevelExperience
        ? 0
        : Math.Clamp((double)(_gameProgress.Experience - _prevLevelXp) / (_gameProgress.NextLevelExperience - _prevLevelXp) * 100, 0, 100);

    private async Task RefreshGameProgress()
    {
        await RefreshAuthenticationStateAsync();
        _gameProgress = _isAuthenticated
            ? await ApiClient.GetGameProgressAsync()
            : null;
        _prevLevelXp = _gameProgress is null ? 0 : _gameProgress.Level <= 1 ? 0 : (_gameProgress.Level - 1) * 100;
    }

    private async Task RefreshAuthenticationStateAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
    }

    private int LevelForXp(int xp) => Math.Clamp(1 + (xp / 100), 1, 100);

    private async Task CenterOnNearestPitchByTypeAsync(PitchType? filterType = null)
    {
        if (_mapView is null || _pitchGraphics.Count == 0)
            return;

        var currentLat = _lastKnownPosition?.Latitude ?? _latitude;
        var currentLng = _lastKnownPosition?.Longitude ?? _longitude;

        var candidates = filterType.HasValue
            ? MapState.Value.VisiblePitches.Where(p => p.Type == filterType.Value)
            : MapState.Value.VisiblePitches;

        var nearest = candidates
            .OrderBy(p => GeoPosition.HaversineDistance(
                new GeoPosition { Latitude = currentLat, Longitude = currentLng },
                new GeoPosition { Latitude = p.Latitude, Longitude = p.Longitude }))
            .FirstOrDefault();

        if (nearest is null)
            return;

        try
        {
            await NavigateToPointAsync(nearest.Longitude, nearest.Latitude, _zoom);
            Dispatcher.Dispatch(new SelectPitchAction(nearest.Id));
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to center on nearest pitch");
        }
    }

    private async Task NavigateToPointAsync(double longitude, double latitude, int zoom)
    {
        if (_mapView is null)
        {
            return;
        }

        await _mapView.SetCenter(new Point(longitude: longitude, latitude: latitude));
        await _mapView.SetZoom(zoom);
    }

    private Viewpoint HomeViewpoint =>
        new(new Point(longitude: _homeLongitude, latitude: _homeLatitude), ScaleForZoom(_zoom), 0, null);

    private static double ScaleForZoom(int zoom) =>
        591657527.591555 / Math.Pow(2, zoom);

    private bool ShouldRefreshPitches(GeoPosition current)
    {
        if (_lastPitchFetchPosition is null) return true;
        if ((DateTime.UtcNow - _lastPitchFetchAtUtc) >= PitchRefreshInterval) return true;

        var moved = GeoPosition.HaversineDistance(_lastPitchFetchPosition, current);
        return moved >= MinPitchRefreshDistanceMeters;
    }

    private int PitchCount(PitchType type)
    {
        return MapState.Value.VisiblePitches.Count(p => p.Type == type);
    }

    private int CandidatePlaceCount => _showCandidatePlaces ? _candidatePlaceGraphics.Count : 0;

    private string PitchDistanceText(PitchModel pitch)
    {
        if (_lastKnownPosition is null)
        {
            return "Distance unknown";
        }

        var distanceMeters = GeoPosition.HaversineDistance(
            _lastKnownPosition,
            new GeoPosition { Latitude = pitch.Latitude, Longitude = pitch.Longitude });

        return distanceMeters < 1000
            ? $"{Math.Round(distanceMeters)} m away"
            : $"{distanceMeters / 1000:0.0} km away";
    }

    private string CandidateDistanceText(PitchCandidatePlaceDto candidate)
    {
        var distanceMeters = _lastKnownPosition is not null
            ? GeoPosition.HaversineDistance(
                _lastKnownPosition,
                new GeoPosition { Latitude = candidate.Latitude, Longitude = candidate.Longitude })
            : candidate.DistanceMeters;

        return distanceMeters < 1000
            ? $"{Math.Round(distanceMeters)} m away"
            : $"{distanceMeters / 1000:0.0} km away";
    }

