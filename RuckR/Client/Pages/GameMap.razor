@page "/map"
@page "/"
@page "/debug-map/geoblazor-native"
@using System.Diagnostics
@using dymaptic.GeoBlazor.Core.Components
@using dymaptic.GeoBlazor.Core.Components.Geometries
@using dymaptic.GeoBlazor.Core.Components.Layers
@using dymaptic.GeoBlazor.Core.Components.Popups
@using dymaptic.GeoBlazor.Core.Components.Renderers
@using dymaptic.GeoBlazor.Core.Components.Symbols
@using dymaptic.GeoBlazor.Core.Components.Views
@using dymaptic.GeoBlazor.Core.Components.Widgets
@using dymaptic.GeoBlazor.Core.Enums
@using dymaptic.GeoBlazor.Core.Events
@using dymaptic.GeoBlazor.Core.Model
@using Fluxor
@using RuckR.Client.MapRendering
@using RuckR.Client.Services
@using RuckR.Client.Store.MapFeature
@using RuckR.Client.Store.LocationFeature
@using RuckR.Shared.Models
@inject IConfiguration Configuration
@inject ILogger<GameMap> Logger
@inject IGeolocationService GeolocationService
@inject ApiClientService ApiClient
@inject SignalRClientService SignalRClient
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IDispatcher Dispatcher
@inject IState<MapState> MapState
@inject IState<LocationState> LocationState
@implements IAsyncDisposable

<h1 class="visually-hidden">RuckR map</h1>

<div class="map-shell @MapShellModeClass @(HasRecruitUi ? "map-shell--recruit-ui" : null)" data-testid="map-container">
    @if (!_hasApiKey)
    {
        <div class="map-unavailable-shell" data-testid="map-unavailable">
            <div class="map-unavailable-panel">
                <p class="map-unavailable-panel__eyebrow">Map offline</p>
                <h2>@MapUnavailableTitle</h2>
                <p>@MapUnavailableBody</p>
                <div class="map-unavailable-panel__actions">
                    <a class="btn btn-sm btn-primary" href="/catalog">Browse players</a>
                    <a class="btn btn-sm btn-outline-secondary" href="/collection">View collection</a>
                </div>
            </div>
        </div>
    }

    <div data-testid="map-loading" class="map-loading" style="@(_viewReady || !_hasApiKey ? "display:none" : "")">
        <div class="spinner-border text-light" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    @if (_hasApiKey)
    {
        <MapView @ref="_mapView"
                 Latitude="@_latitude"
                 Longitude="@_longitude"
                 Zoom="@_zoom"
                 OnClick="HandleMapClick"
                 OnViewInitialized="OnViewInitializedAsync"
                 OnViewRendered="OnViewRenderedAsync"
                 ShowZoomWidget="true"
                 Style="height: calc(100dvh - 3.5rem); min-height: 480px; width: 100%;">
            <Map>
                @if (_basemapMode == MapBasemapMode.Styled)
                {
                    <Basemap>
                        <BasemapStyle Name="@BasemapStyleName.ArcgisNavigation" ApiKey="@_apiKey" />
                    </Basemap>
                }
                @if (_enableGameGraphics)
                {
                    @if (_useNativeGeoBlazorMap)
                    {
                        <FeatureLayer @key='NativeLayerKey("player-accuracy", _nativePlayerAccuracyLayerVersion)'
                                      Title="Player accuracy"
                                      Source="@_nativePlayerAccuracyFeatures"
                                      Fields="@NativeMapFeatureLayerFactory.PlayerAccuracyFields"
                                      OutFields="@NativeMapFeatureLayerFactory.OutFields"
                                      ObjectIdField="@NativeMapFeatureLayerFactory.PlayerAccuracyObjectIdField"
                                      GeometryType="@FeatureGeometryType.Polygon"
                                      Renderer="@_nativePlayerAccuracyRenderer"
                                      PopupEnabled="true"
                                      LegendEnabled="true" />
                        <FeatureLayer @key='NativeLayerKey("player-location", _nativePlayerLocationLayerVersion)'
                                      Title="Player location"
                                      Source="@_nativePlayerLocationFeatures"
                                      Fields="@NativeMapFeatureLayerFactory.PlayerLocationFields"
                                      OutFields="@NativeMapFeatureLayerFactory.OutFields"
                                      ObjectIdField="@NativeMapFeatureLayerFactory.PlayerObjectIdField"
                                      GeometryType="@FeatureGeometryType.Point"
                                      Renderer="@_nativePlayerLocationRenderer"
                                      PopupEnabled="true"
                                      LegendEnabled="true" />
                        <FeatureLayer @key='NativeLayerKey("encounters", _nativeEncounterLayerVersion)'
                                      Title="Encounters"
                                      Source="@_nativeEncounterFeatures"
                                      Fields="@NativeMapFeatureLayerFactory.EncounterFields"
                                      OutFields="@NativeMapFeatureLayerFactory.OutFields"
                                      ObjectIdField="@NativeMapFeatureLayerFactory.EncounterObjectIdField"
                                      GeometryType="@FeatureGeometryType.Point"
                                      Renderer="@_nativeEncounterRenderer"
                                      PopupTemplate="@_nativeEncounterPopupTemplate"
                                      PopupEnabled="true"
                                      LegendEnabled="true" />
                        <FeatureLayer @key='NativeLayerKey("candidate-places", _nativeCandidatePlaceLayerVersion)'
                                      @ref="_nativeCandidatePlaceLayer"
                                      Title="Candidate places"
                                      Source="@_nativeCandidatePlaceFeatures"
                                      Fields="@NativeMapFeatureLayerFactory.CandidateFields"
                                      OutFields="@NativeMapFeatureLayerFactory.OutFields"
                                      ObjectIdField="@NativeMapFeatureLayerFactory.CandidateObjectIdField"
                                      GeometryType="@FeatureGeometryType.Point"
                                      Renderer="@_nativeCandidatePlaceRenderer"
                                      PopupEnabled="true"
                                      LegendEnabled="true"
                                      Visible="@_showCandidatePlaces" />
                        <FeatureLayer @key='NativeLayerKey("pitches", _nativePitchLayerVersion)'
                                      @ref="_nativePitchLayer"
                                      Title="Pitches"
                                      Source="@_nativePitchFeatures"
                                      Fields="@NativePitchFeatureLayerFactory.Fields"
                                      OutFields="@NativePitchFeatureLayerFactory.OutFields"
                                      ObjectIdField="@NativePitchFeatureLayerFactory.ObjectIdField"
                                      GeometryType="@FeatureGeometryType.Point"
                                      Renderer="@_nativePitchRenderer"
                                      PopupEnabled="true"
                                      LegendEnabled="true" />
                    }
                    else
                    {
                        <GraphicsLayer @ref="_playerLocationLayer" Title="Player location" />
                        <GraphicsLayer @ref="_encounterLayer" Title="Encounters" />
                        <GraphicsLayer @ref="_candidatePlaceLayer" Title="Candidate places" Visible="@_showCandidatePlaces" />
                        <GraphicsLayer @ref="_pitchLayer" Title="Pitches" />
                    }
                }
            </Map>
            @if (ShouldRenderArcGisWidgets)
            {
                <CompassWidget Position="OverlayPosition.TopLeft" />
                <LocateWidget Position="OverlayPosition.TopLeft" />
                <ScaleBarWidget Position="OverlayPosition.BottomLeft" />
                @if (_useNativeGeoBlazorMap)
                {
                    <LegendWidget Position="OverlayPosition.BottomRight" />
                }
            }
        </MapView>

        @if (ShouldRenderArcGisWidgets && !_useNativeGeoBlazorMap)
        {
            <div class="map-key" data-testid="map-key" aria-label="Map key">
                <div class="map-key__title">Map key</div>
                <div class="map-key__row">
                    <span class="map-key__symbol map-key__symbol--standard"></span>
                    <span>Standard pitch</span>
                </div>
                <div class="map-key__row">
                    <span class="map-key__symbol map-key__symbol--training"></span>
                    <span>Training pitch</span>
                </div>
                <div class="map-key__row">
                    <span class="map-key__symbol map-key__symbol--stadium"></span>
                    <span>Stadium</span>
                </div>
                <div class="map-key__row">
                    <span class="map-key__symbol map-key__symbol--encounter"></span>
                    <span>Recruit</span>
                </div>
                <div class="map-key__row">
                    <span class="map-key__symbol map-key__symbol--candidate"></span>
                    <span>Candidate place</span>
                </div>
                <div class="map-key__row">
                    <span class="map-key__symbol map-key__symbol--player"></span>
                    <span>You</span>
                </div>
            </div>
        }

        @if (ShouldShowGpsNotice)
        {
            <div class="gps-readiness" data-testid="gps-readiness">
                <div>
                    <div class="gps-readiness__title">@GpsNoticeTitle</div>
                    <p>@GpsNoticeBody</p>
                    @if (GpsPermissionHelp is not null)
                    {
                        <p class="gps-readiness__help" data-testid="gps-permission-help">@GpsPermissionHelp</p>
                    }
                </div>
                <div class="gps-readiness__actions">
                    <button class="btn btn-sm btn-outline-light"
                            type="button"
                            data-testid="gps-retry-btn"
                            @onclick="EnableGpsAsync">
                        @GpsRetryButtonText
                    </button>
                    @if (GpsStatus.Kind == GpsStatusKind.Blocked)
                    {
                        <button class="btn btn-sm btn-link gps-readiness__dismiss"
                                type="button"
                                data-testid="gps-dismiss-btn"
                                @onclick="DismissGpsNotice">
                            Keep browsing
                        </button>
                    }
                </div>
            </div>
        }

    }

    @if (ShouldShowRecruitBoard)
    {
        var recruitBoardEncounters = RecruitBoardEncounters;
        var recruitBoardSpotlight = RecruitBoardSpotlightEncounter;

        <MudPaper Elevation="3" Class="encounter-radar" data-testid="encounter-radar">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="encounter-radar__header">
                <MudText Typo="Typo.caption" data-testid="recruit-board-title">Recruiting at @RecruitBoardPitchName</MudText>
                <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" data-testid="recruit-board-count">@recruitBoardEncounters.Count</MudChip>
            </MudStack>
            @if (recruitBoardSpotlight is not null)
            {
                <MudButton Class="encounter-radar__target encounter-radar__target--spotlight"
                           Variant="Variant.Text"
                           FullWidth="true"
                           data-testid="spotlight-encounter-btn"
                           aria-label="@($"Rare sighting: {recruitBoardSpotlight.Name}")"
                           OnClick="() => SelectEncounterAsync(recruitBoardSpotlight)">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="encounter-radar__target-inner">
                        <span>
                            <small class="encounter-radar__kicker">Rare sighting</small>
                            <strong>@recruitBoardSpotlight.Name</strong>
                            <small>@SpotlightSightingSummary(recruitBoardSpotlight)</small>
                        </span>
                        <span class="encounter-radar__timer">@EncounterExpiresText(recruitBoardSpotlight)</span>
                    </MudStack>
                </MudButton>
            }
            else
            {
                <MudText Typo="Typo.body2" Class="encounter-radar__empty" data-testid="recruit-board-empty">
                    No recruits are currently visible at this pitch. Refresh the map or check another pitch.
                </MudText>
            }
        </MudPaper>
    }
</div>

@if (_showOnboarding)
{
    <div class="onboarding-banner" data-testid="onboarding-banner">
        <span class="onboarding-text">Welcome to RuckR! Explore the map to find pitches and recruit players.</span>
        <button class="btn-close btn-close-white" data-testid="onboarding-close" @onclick="DismissOnboarding" aria-label="Dismiss"></button>
    </div>
}

@if (_selectedPitch is not null)
{
    <MudPaper Elevation="4" Class="@($"map-overlay pitch-card pitch-card--{PitchTypeCssClass(_selectedPitch.Type)}")" data-testid="pitch-overlay">
        <MudStack Spacing="2">
            <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                <div>
                    <MudText Typo="Typo.overline" Class="pitch-card__eyebrow">Pitch Hub</MudText>
                    <MudText Typo="Typo.h6" data-testid="pitch-name">@_selectedPitch.Name</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Inherit" data-testid="pitch-close" OnClick="ClearSelection" aria-label="Close" />
            </MudStack>

            <MudStack Row="true" Class="pitch-card__meta">
                <MudChip T="string" Color="@PitchTypeChipColor(_selectedPitch.Type)" Size="Size.Small" Variant="Variant.Filled" data-testid="pitch-type">@PitchTypeDisplayName(_selectedPitch.Type)</MudChip>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@PitchHubDistanceText</MudChip>
            </MudStack>

            <MudText Typo="Typo.caption" Color="Color.Secondary" data-testid="pitch-source">@PitchHubSourceText</MudText>

            <div class="capture-panel" data-testid="pitch-hub-panel">
                <div class="capture-panel__row">
                    <span>Active recruits</span>
                    @if (_isLoadingPitchHub)
                    {
                        <span class="spinner-border spinner-border-sm text-light" role="status"></span>
                    }
                    else
                    {
                        <strong data-testid="active-recruit-count">@(_pitchHub?.ActiveRecruitCount ?? 0)</strong>
                    }
                </div>
                <div class="capture-panel__row">
                    <span>Nearby users</span>
                    <strong data-testid="challengeable-user-count">@(_pitchHub?.ChallengeableUserCount ?? 0)</strong>
                </div>
                <div class="capture-panel__row">
                    <span>Hub range</span>
                    <strong>@PitchHubRangeText</strong>
                </div>
                <p class="capture-panel__status" data-testid="capture-status">@PitchHubStatusText</p>
                @if (GpsActionHint is not null && _pitchHub?.Reason is "GPS_REQUIRED" or "GPS_INACCURATE")
                {
                    <p class="capture-panel__gps" data-testid="capture-gps-hint">@GpsActionHint</p>
                }
                <MudStack Row="true" Spacing="1" Class="pitch-hub-actions">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.Groups"
                               data-testid="capture-players-btn"
                               Disabled="@(!CanRecruitAtSelectedPitch)"
                               OnClick="OpenPitchRecruitBoard">
                        Recruit here
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               FullWidth="true"
                               StartIcon="@Icons.Material.Filled.SportsKabaddi"
                               data-testid="challenge-users-btn"
                               Disabled="@(!CanChallengeFromSelectedPitch)"
                               OnClick="NavigateToPitchChallenges">
                        Challenge users
                    </MudButton>
                </MudStack>
            </div>
        </MudStack>
    </MudPaper>
}

@if (_selectedEncounter is not null && _showRecruitBoard)
{
    <MudPaper Elevation="4" Class="@EncounterOverlayClass(_selectedEncounter)" data-testid="encounter-overlay">
        <div class="encounter-card__header">
            <div class="encounter-card__identity">
                <MudText Typo="Typo.overline" Class="encounter-card__eyebrow" data-testid="encounter-kicker">
                    @(IsSpotlightEncounter(_selectedEncounter) ? "Rare sighting" : EncounterParkName(_selectedEncounter))
                </MudText>
                <MudText Typo="Typo.h6" Class="encounter-card__name" data-testid="encounter-name">@_selectedEncounter.Name</MudText>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Class="encounter-card__close" Size="Size.Small" Color="Color.Default" data-testid="encounter-close" OnClick="ClearEncounterSelection" aria-label="Close" />
        </div>
        <div class="encounter-card__badges">
            <MudChip T="string" Color="@EncounterRarityColor(_selectedEncounter.Rarity)" Variant="Variant.Filled" Size="Size.Small">@_selectedEncounter.Rarity</MudChip>
            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small">Level @_selectedEncounter.Level</MudChip>
            <MudChip T="string" Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">@_selectedEncounter.Position</MudChip>
            <MudChip T="string" Color="@(IsSpotlightEncounter(_selectedEncounter) ? Color.Warning : Color.Info)" Variant="Variant.Filled" Size="Size.Small" Class="spotlight-timer" data-testid="spotlight-timer">@EncounterExpiresText(_selectedEncounter)</MudChip>
        </div>
        @if (IsSpotlightEncounter(_selectedEncounter))
        {
            <MudText Typo="Typo.body2" Class="encounter-card__spotlight-copy" data-testid="spotlight-copy">
                Last chance at @EncounterParkName(_selectedEncounter). Close the distance and recruit before the bell.
            </MudText>
        }
        <div class="encounter-card__route">
            <span>@EncounterDistanceText(_selectedEncounter)</span>
            <strong>@EncounterRouteInstruction(_selectedEncounter)</strong>
        </div>
        <div class="encounter-card__status-panel">
            <div class="encounter-card__state encounter-card__state--@RecruitStateCssClass" data-testid="spotlight-recruit-state">
                @RecruitStateLabel
            </div>
            <div class="encounter-card__meta" data-testid="recruit-shared-state">
                <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">@RecruitParticipantText</MudChip>
                @if (RecruitGroupItemText is not null)
                {
                    <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small">@RecruitGroupItemText</MudChip>
                }
                @if (CurrentUserJoinedRecruitment)
                {
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small">Joined</MudChip>
                }
            </div>
            <div class="encounter-card__chance"
                 role="timer"
                 aria-label="Recruitment time needed"
                 data-testid="recruit-time-needed">
                <div style="width:@RecruitTimeProgressPercent%"></div>
                <span>@RecruitTimerText</span>
            </div>
        </div>
        <div class="encounter-card__action-panel">
            <MudSelect T="RecruitmentItemKind"
                       Label="Use item"
                       Variant="Variant.Outlined"
                       Dense="true"
                       Disabled="@(!CanChooseRecruitmentItem)"
                       Class="encounter-card__item-picker"
                       @bind-Value="_selectedRecruitItem"
                       data-testid="recruit-item-picker">
                <MudSelectItem T="RecruitmentItemKind" Value="@RecruitmentItemKind.None">No item @RecruitItemCountText(RecruitmentItemKind.None)</MudSelectItem>
                <MudSelectItem T="RecruitmentItemKind" Value="@RecruitmentItemKind.Chips">Chips @RecruitItemCountText(RecruitmentItemKind.Chips)</MudSelectItem>
                <MudSelectItem T="RecruitmentItemKind" Value="@RecruitmentItemKind.Beer">Beer @RecruitItemCountText(RecruitmentItemKind.Beer)</MudSelectItem>
                <MudSelectItem T="RecruitmentItemKind" Value="@RecruitmentItemKind.Whiskey">Whiskey @RecruitItemCountText(RecruitmentItemKind.Whiskey)</MudSelectItem>
            </MudSelect>
            @if (_activeRecruitment?.Boosts is { Count: > 0 } boosts)
            {
                <div class="encounter-card__boosts" data-testid="recruit-boosts">
                    @foreach (var boost in boosts)
                    {
                        <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small">@boost.Label</MudChip>
                    }
                </div>
            }
            <MudButton Variant="Variant.Filled"
                       Color="@RecruitButtonColor"
                       StartIcon="@Icons.Material.Filled.PersonAdd"
                       FullWidth="true"
                       Disabled="@(!_canRecruit)"
                       Class="encounter-card__cta"
                       title="@_recruitBlockedReason"
                       OnClick="AttemptRecruitment"
                       data-testid="recruit-btn">
                @(_isRecruiting ? "Recruiting..." : RecruitButtonText)
            </MudButton>
            @if (!_canRecruit)
            {
                <MudText Typo="Typo.caption" Color="Color.Warning">@_recruitBlockedReason</MudText>
            }
            @if (GpsActionHint is not null)
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" data-testid="recruit-gps-hint">@GpsActionHint</MudText>
            }
            @if (_recruitMessage is not null)
            {
                <MudAlert Severity="@RecruitMessageSeverity" Dense="true">@_recruitMessage</MudAlert>
            }
        </div>
    </MudPaper>
}

@if (_selectedCandidatePlace is not null)
{
    <div class="map-overlay pitch-card" data-testid="candidate-place-overlay">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <div class="pitch-card__eyebrow">Candidate place</div>
                <h5 class="mb-0" data-testid="candidate-place-name">@_selectedCandidatePlace.Name</h5>
            </div>
            <button type="button" class="btn-close" data-testid="candidate-place-close" @onclick="ClearCandidateSelection" aria-label="Close"></button>
        </div>
        <div class="pitch-card__meta mb-2">
            <span class="pitch-card__pill">@_selectedCandidatePlace.CategoryLabel</span>
            <span class="pitch-card__distance">@CandidateDistanceText(_selectedCandidatePlace)</span>
        </div>
        <p class="capture-panel__status mb-2">
            @_selectedCandidatePlace.MatchReason. Confidence @_selectedCandidatePlace.Confidence%.
        </p>
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-0" data-testid="candidate-place-disabled">
            Manual pitch creation is disabled. Approved Places candidates are promoted automatically.
        </MudAlert>
    </div>
}

@if (_recruitToastMessage is not null)
{
    <div class="recruit-toast recruit-toast--@_recruitToastClass" data-testid="recruit-toast">
        @_recruitToastMessage
        <button type="button" class="btn-close btn-close-white" @onclick="DismissRecruitToast" aria-label="Dismiss"></button>
    </div>
}

@if (_gameProgress is not null)
{
    <div class="game-progress-chip" title="Level @_gameProgress.Level — @_gameProgress.Experience / @_gameProgress.NextLevelExperience XP">
        <span class="fw-bold">@_gameProgress.Level</span>
        <div class="progress flex-grow-1 ms-2">
            <div class="progress-bar"
                 role="progressbar"
                 style="width:@ProgressPercent%; min-width: 8px;"
                 aria-valuenow="@_gameProgress.Experience - _prevLevelXp"
                 aria-valuemin="0"
                 aria-valuemax="@_gameProgress.NextLevelExperience - _prevLevelXp">
            </div>
        </div>
    </div>
}

<div class="map-info-bar">
    <span class="text-muted small">
        @if (_statusMessage is not null)
        {
            @_statusMessage
        }
        else if (_pitchGraphics.Count > 0 || _encounterGraphics.Count > 0 || _candidatePlaceGraphics.Count > 0)
        {
            <text>@_pitchGraphics.Count pitches, @_encounterGraphics.Count encounters, @CandidatePlaceCount candidates visible. Tap a marker to see details.</text>
        }
        else
        {
            <text>Loading...</text>
        }
    </span>
</div>

<style>
     .onboarding-banner {
         position: fixed;
         top: 4.25rem;
         left: 50%;
         z-index: 1500;
         display: flex;
         align-items: center;
         justify-content: space-between;
         gap: 0.75rem;
         width: min(640px, calc(100vw - 1.5rem));
         transform: translateX(-50%);
         border: 1px solid rgba(255,255,255,0.16);
         border-radius: 0.5rem;
         padding: 0.65rem 0.8rem;
         background: rgba(15,23,42,0.94);
         color: #fff;
         box-shadow: 0 16px 40px rgba(0,0,0,0.28);
     }
     .onboarding-text {
         min-width: 0;
         font-size: 0.9rem;
         line-height: 1.35;
     }
     .gps-readiness {
         position: absolute;
         top: 0.75rem;
         right: 0.75rem;
         z-index: 11;
         display: grid;
         grid-template-columns: minmax(0, 1fr) auto;
         align-items: center;
         gap: 0.75rem;
         width: min(420px, calc(100vw - 1.5rem));
         border: 1px solid rgba(250,204,21,0.32);
         border-radius: 0.5rem;
         padding: 0.7rem 0.8rem;
         background: rgba(24, 21, 12, 0.92);
         color: #fff;
         box-shadow: 0 16px 40px rgba(0,0,0,0.3);
         backdrop-filter: blur(8px);
     }
     .gps-readiness__title {
         margin-bottom: 0.15rem;
         font-size: 0.78rem;
         font-weight: 800;
         letter-spacing: 0.08em;
         text-transform: uppercase;
         color: #fde68a;
     }
     .gps-readiness p {
         margin: 0;
         font-size: 0.82rem;
         line-height: 1.35;
         color: rgba(248,250,252,0.86);
     }
     .gps-readiness__help {
         margin-top: 0.35rem !important;
         color: #fde68a !important;
      }
     .gps-readiness__actions {
         display: flex;
         flex-direction: column;
         align-items: stretch;
         gap: 0.25rem;
      }
     .gps-readiness .btn {
         white-space: nowrap;
     }
     .gps-readiness__dismiss {
         color: rgba(248,250,252,0.78);
         text-decoration: none;
      }
     .gps-readiness__dismiss:hover {
         color: #fff;
      }
     .encounter-radar {
         position: absolute;
         top: 8.75rem;
         left: 0.75rem;
         z-index: 10;
         width: min(260px, calc(100vw - 1.5rem));
         padding: 0.6rem;
