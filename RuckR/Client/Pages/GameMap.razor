    private async Task EnableGpsAsync()
    {
        var permissionWasBlocked = GpsStatus.Kind == GpsStatusKind.Blocked;
        _gpsRetryAttempts++;
        if (!permissionWasBlocked && ShouldDismissGpsNoticeAfterRetry(_gpsRetryAttempts))
        {
            _gpsNoticeDismissed = true;
        }

        try
        {
            _statusMessage = permissionWasBlocked
                ? "Checking location permission..."
                : "Waiting for GPS...";
            await GeolocationService.StartWatchAsync();
        }
        catch
        {
            _statusMessage = "GPS is blocked or unavailable. Enable location permission in your browser to recruit players.";
        }

        await InvokeAsync(StateHasChanged);
    }

    private void DismissGpsNotice()
    {
        _gpsNoticeDismissed = true;
    }

    public static bool ShouldDismissGpsNoticeAfterRetry(int retryAttempts) =>
        retryAttempts >= MaxGpsNoticeRetryAttempts;

    public static bool IsLocationPermissionDenied(string? errorMessage) =>
        !string.IsNullOrWhiteSpace(errorMessage)
        && (errorMessage.Contains("permission", StringComparison.OrdinalIgnoreCase)
            || errorMessage.Contains("denied", StringComparison.OrdinalIgnoreCase)
            || errorMessage.Contains("site settings", StringComparison.OrdinalIgnoreCase));

    public static bool ShouldMonitorLocationSearch(
        string? errorMessage,
        DateTime? searchStartedAtUtc,
        DateTime? lastErrorAtUtc,
        DateTime nowUtc)
    {
        if (searchStartedAtUtc is null)
        {
            return false;
        }

        if (nowUtc < searchStartedAtUtc.Value)
        {
            return true;
        }

        if (nowUtc - searchStartedAtUtc.Value > LocationSearchPolicy.PendingErrorGracePeriod)
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(errorMessage)
            || IsLocationPermissionDenied(errorMessage)
            || lastErrorAtUtc is null;
    }

