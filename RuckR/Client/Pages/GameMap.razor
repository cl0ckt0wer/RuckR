    private async Task HandleMapClick(ClickEvent clickEvent)
    {
        if (clickEvent?.MapPoint is null || _mapView is null)
            return;

        try
        {
            var hitResult = await _mapView.HitTest(clickEvent);
            foreach (var hit in hitResult.Results)
            {
                if (hit is GraphicHit graphicHit && TryApplyGraphicHitSelection(graphicHit.Graphic))
                {
                    return;
                }
            }

            Dispatcher.Dispatch(new ClearSelectionAction());
            _statusMessage = $"Clicked: {clickEvent.MapPoint.Latitude:F5}, {clickEvent.MapPoint.Longitude:F5}";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Map click hit-test failed");
            _statusMessage = $"Clicked: {clickEvent.MapPoint.Latitude:F5}, {clickEvent.MapPoint.Longitude:F5}";
            StateHasChanged();
        }
    }

    private bool TryApplyGraphicHitSelection(Graphic graphic)
    {
        var attrs = graphic.Attributes;
        if (!attrs.TryGetValue("_ruckrType", out var type))
        {
            return false;
        }

        return type?.ToString() switch
        {
            "pitch" => TrySelectPitchGraphic(attrs),
            "encounter" => TrySelectEncounterGraphic(attrs),
            "candidate-place" => TrySelectCandidatePlaceGraphic(attrs),
            _ => false
        };
    }

    private bool TrySelectPitchGraphic(AttributesDictionary attrs)
    {
        if (!attrs.TryGetValue("_ruckrId", out var idObj) || idObj is not int pitchId)
        {
            return false;
        }

        ClearCandidateSelection();
        Dispatcher.Dispatch(new SelectPitchAction(pitchId));
        return true;
    }

    private bool TrySelectEncounterGraphic(AttributesDictionary attrs)
    {
        if (!attrs.TryGetValue("_ruckrEncounterId", out var encIdObj)
            || !Guid.TryParse(encIdObj?.ToString(), out var encounterId))
        {
            return false;
        }

        var encounter = MapState.Value.VisibleEncounters.FirstOrDefault(e => e.EncounterId == encounterId);
        if (encounter is null)
        {
            return false;
        }

        ClearCandidateSelection();
        _selectedEncounter = encounter;
        UpdateRecruitEligibility();
        _recruitMessage = null;
        Dispatcher.Dispatch(new SelectEncounterAction(encounterId));
        return true;
    }

    private bool TrySelectCandidatePlaceGraphic(AttributesDictionary attrs)
    {
        if (attrs.TryGetValue("_ruckrPlaceId", out var placeIdObj)
            && placeIdObj?.ToString() is { Length: > 0 } placeId)
        {
            SelectCandidatePlace(placeId);
        }

        var name = attrs.TryGetValue("name", out var nameObj) ? nameObj?.ToString() : _selectedCandidatePlace?.Name ?? "Candidate place";
        var recommendedType = attrs.TryGetValue("recommendedPitchType", out var typeObj) ? typeObj?.ToString() : _selectedCandidatePlace?.RecommendedPitchType ?? "Pitch";
        var confidence = attrs.TryGetValue("confidence", out var confidenceObj) ? confidenceObj?.ToString() : "?";
        var reason = attrs.TryGetValue("matchReason", out var reasonObj) ? reasonObj?.ToString() : "matched place category";
        var category = attrs.TryGetValue("categoryLabel", out var categoryObj) ? categoryObj?.ToString() : "Place";
        _statusMessage = $"Candidate: {name} -> {recommendedType} ({confidence}%). {reason}; {category}.";
        Dispatcher.Dispatch(new ClearSelectionAction());
        StateHasChanged();
        return true;
    }

