    private static bool IsExpectedGeoBlazorCancellation(Exception ex)
    {
        return ex is OperationCanceledException
            || ex is TaskCanceledException
            || ex.Message.Contains("TaskCanceledException", StringComparison.OrdinalIgnoreCase)
            || ex.Message.Contains("Cannot read properties of null (reading 'reject')", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsExpectedMapDiagnosticsDisposal(Exception ex)
    {
        return _isDisposing
            || ex is ObjectDisposedException
            || ex is OperationCanceledException
            || ex is TaskCanceledException
            || ex.Message.Contains("ObjectDisposed", StringComparison.OrdinalIgnoreCase)
            || ex.Message.Contains("JSObjectReference", StringComparison.OrdinalIgnoreCase);
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposing = true;
        await _diagnosticsCts.CancelAsync();
        await _spotlightClockCts.CancelAsync();
        if (_candidatePlaceLoadCts is not null)
        {
            await _candidatePlaceLoadCts.CancelAsync();
            _candidatePlaceLoadCts.Dispose();
            _candidatePlaceLoadCts = null;
        }

        if (_subscriptionsActive)
        {
            GeolocationService.PositionChanged -= OnPositionChanged;
            SignalRClient.RecruitmentEncounterChanged -= OnRecruitmentEncounterChanged;
            SignalRClient.RecruitmentEncounterRemoved -= OnRecruitmentEncounterRemoved;
            MapState.StateChanged -= OnMapStateChanged;
            LocationState.StateChanged -= OnLocationStateChanged;
            _subscriptionsActive = false;
        }
        GeolocationService.StopWatch();

        try { await ClearPitchLayersAsync(); } catch { }
        if (_encounterLayer is not null)
        {
            try { await _encounterLayer.Clear(); } catch { }
        }
        if (_candidatePlaceLayer is not null)
        {
            try { await _candidatePlaceLayer.Clear(); } catch { }
        }
        if (_playerLocationLayer is not null)
        {
            try { await _playerLocationLayer.Clear(); } catch { }
        }
        if (_mapDiagnosticsModule is not null)
        {
            try { await _mapDiagnosticsModule.InvokeVoidAsync("stopMapDiagnosticsCapture"); } catch { }
            try { await _mapDiagnosticsModule.DisposeAsync(); } catch { }
        }
        _pitchGraphics.Clear();
        _encounterGraphics.Clear();
        _candidatePlaceGraphics.Clear();
        _nativePitchFeatures = Array.Empty<Graphic>();
        _nativeEncounterFeatures = Array.Empty<Graphic>();
        _nativeCandidatePlaceFeatures = Array.Empty<Graphic>();
        _nativePlayerLocationFeatures = Array.Empty<Graphic>();
        _nativePlayerAccuracyFeatures = Array.Empty<Graphic>();
        _diagnosticsCts.Dispose();
        _spotlightClockCts.Dispose();
    }
