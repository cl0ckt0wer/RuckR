    private bool CanCreateSelectedCandidatePitch =>
        _isAuthenticated
        && !_isCreatingCandidatePitch
        && _selectedCandidatePlace is not null
        && !string.IsNullOrWhiteSpace(_candidatePitchName)
        && Enum.TryParse<PitchType>(_candidatePitchType, ignoreCase: true, out _);

    private async Task CreateSelectedCandidatePitchAsync()
    {
        if (!CanCreateSelectedCandidatePitch || _selectedCandidatePlace is null)
        {
            return;
        }

        _isCreatingCandidatePitch = true;
        _candidateCreateMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var created = await ApiClient.CreatePitchFromCandidateAsync(
                _selectedCandidatePlace,
                _candidatePitchName.Trim(),
                _candidatePitchType);

            _candidateCreateMessageClass = "success";
            _candidateCreateMessage = created is null
                ? "Pitch created."
                : $"{created.Name} created.";

            var lat = _lastPitchFetchPosition?.Latitude ?? _selectedCandidatePlace.Latitude;
            var lng = _lastPitchFetchPosition?.Longitude ?? _selectedCandidatePlace.Longitude;
            ClearCandidateSelection();
            await LoadPitchMarkersAsync(lat, lng);
            _statusMessage = "Candidate converted into a pitch.";
        }
        catch (HttpRequestException ex)
        {
            Logger.LogWarning(ex, "Failed to create pitch from candidate place {PlaceId}", _selectedCandidatePlace.PlaceId);
            _candidateCreateMessageClass = "warning";
            _candidateCreateMessage = "Could not create this pitch. It may already exist nearby or have a duplicate name.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error creating pitch from candidate place {PlaceId}", _selectedCandidatePlace.PlaceId);
            _candidateCreateMessageClass = "danger";
            _candidateCreateMessage = "Unable to create this pitch right now.";
        }
        finally
        {
            _isCreatingCandidatePitch = false;
            await InvokeAsync(StateHasChanged);
        }
    }

