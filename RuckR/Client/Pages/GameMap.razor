    private async Task<T> TimedMapDataCallAsync<T>(string step, string reason, Func<Task<T>> action)
    {
        var stopwatch = Stopwatch.StartNew();
        _ = MarkMapTimingAsync($"{step}-api-start", new { reason });
        try
        {
            return await action();
        }
        finally
        {
            stopwatch.Stop();
            Logger.LogInformation(
                "MapPerf {Step} completed in {DurationMs} ms for {Reason}",
                step,
                stopwatch.ElapsedMilliseconds,
                reason);
            _ = MarkMapTimingAsync($"{step}-api-end", new { reason, durationMs = stopwatch.ElapsedMilliseconds });
        }
    }

    private async void OnPositionChanged(GeoPosition pos)
    {
        if (_isDisposing)
        {
            return;
        }

        try
        {
            _lastKnownPosition = pos;
            if (_enableGameGraphics)
            {
                await UpdatePlayerLocationGraphicAsync(pos);
            }
            if (_statusMessage is not null
                && (_statusMessage.StartsWith("GPS", StringComparison.OrdinalIgnoreCase)
                    || _statusMessage.StartsWith("Waiting for GPS", StringComparison.OrdinalIgnoreCase)))
            {
                _statusMessage = null;
            }

            if (!_initialCenterPerformed)
            {
                _initialCenterPerformed = true;
                _latitude = pos.Latitude;
                _longitude = pos.Longitude;
                _homeLatitude = pos.Latitude;
                _homeLongitude = pos.Longitude;
            }

            if (_initialMapDataLoadPending)
            {
                _positionReceivedDuringInitialMapDataLoad = pos;
            }
            else if (_enableGameGraphics && ShouldRefreshPitches(pos))
            {
                await LoadPitchMarkersAsync(pos.Latitude, pos.Longitude, "gps");
            }

            if (_isAuthenticated)
            {
                await SignalRClient.UpdateLocationAsync(pos.Latitude, pos.Longitude, pos.Accuracy);
            }

            UpdateRecruitEligibility();
            if (_selectedPitch is not null)
            {
                _ = RefreshPitchHubAsync(_selectedPitch.Id);
            }
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            if (IsExpectedGeoBlazorCancellation(ex))
            {
                Logger.LogDebug(ex, "Position change handler cancelled during map lifecycle transition");
                return;
            }

            Logger.LogError(ex, "Error in position change handler");
        }
    }

    private void OnMapStateChanged(object? sender, EventArgs e)
    {
        var state = ((IState<MapState>)sender!).Value;
        if (state.SelectedPitchId.HasValue && state.SelectedPitchId.Value != _lastSelectedPitchId)
        {
            _lastSelectedPitchId = state.SelectedPitchId.Value;
            _selectedPitch = state.VisiblePitches.FirstOrDefault(p => p.Id == state.SelectedPitchId.Value);
            _pitchHub = null;
            if (_selectedPitch is not null)
            {
                _ = RefreshPitchHubAsync(_selectedPitch.Id);
            }
            _ = InvokeAsync(StateHasChanged);
        }
        else if (!state.SelectedPitchId.HasValue && _selectedPitch is not null)
        {
            _lastSelectedPitchId = -1;
            _selectedPitch = null;
            _pitchHub = null;
            _ = InvokeAsync(StateHasChanged);
        }

        if (state.SelectedEncounterId.HasValue)
        {
            _selectedEncounter = state.VisibleEncounters.FirstOrDefault(e => e.EncounterId == state.SelectedEncounterId.Value);
            UpdateRecruitEligibility();
        }
        else if (_selectedEncounter is not null)
        {
            _selectedEncounter = null;
            _showRecruitBoard = false;
            _canRecruit = false;
            _recruitBlockedReason = "Select a recruitable player.";
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadPitchMarkersAsync(double lat, double lng, string reason = "refresh")
    {
        if (_isDisposing || !_enableGameGraphics || !_viewRendered || _mapView is null)
            return;

        var requestId = ++_pitchMarkerLoadRequestId;
        _pitchMarkerLoadInFlightPosition = new GeoPosition { Latitude = lat, Longitude = lng };
        _pitchMarkerLoadStartedAtUtc = DateTime.UtcNow;
        var loadStopwatch = Stopwatch.StartNew();
        await MarkMapTimingAsync("map-data-load-start", new { reason, lat, lng });

        try
        {
            var pitchesTask = TimedMapDataCallAsync(
                "pitches",
                reason,
                () => ApiClient.GetNearbyPitchesAsync(lat, lng, BrowseRadiusMeters));
            var encountersTask = _isAuthenticated
                ? TimedMapDataCallAsync(
                    "encounters",
                    reason,
                    () => ApiClient.GetEncountersAsync(lat, lng, EncounterBrowseRadiusMeters))
                : Task.FromResult(new List<PlayerEncounterDto>());

            await Task.WhenAll(pitchesTask, encountersTask);
            if (_isDisposing || requestId != _pitchMarkerLoadRequestId) return;

            var pitches = await pitchesTask;
            var encounters = await encountersTask;
            if (_isDisposing) return;

            Dispatcher.Dispatch(new SetPitchesAction(pitches.AsReadOnly()));
            await UpdatePitchGraphicsAsync(pitches);
            await MarkMapTimingAsync("pitch-graphics-synced", new { reason, count = pitches.Count });
            if (_isDisposing || requestId != _pitchMarkerLoadRequestId) return;

            if (_isAuthenticated)
            {
                Logger.LogInformation(
                    "Map encounters loaded: count={EncounterCount}, authenticated={Authenticated}, lat={Latitude}, lng={Longitude}, radiusMeters={RadiusMeters}",
                    encounters.Count,
                    _isAuthenticated,
                    lat,
                    lng,
                    EncounterBrowseRadiusMeters);

                _statusMessage = encounters.Count == 0
                    ? "No recruitable players nearby. Head to a real-world park to find recruits."
                    : null;
            }
            else
            {
                Logger.LogInformation(
                    "Map encounters skipped: authenticated={Authenticated}, lat={Latitude}, lng={Longitude}, radiusMeters={RadiusMeters}",
                    _isAuthenticated,
                    lat,
                    lng,
                    EncounterBrowseRadiusMeters);
                _statusMessage = "Log in to discover recruitable players at nearby real-world parks.";
            }

            Dispatcher.Dispatch(new SetEncountersAction(encounters.AsReadOnly()));
            await UpdateEncounterGraphicsAsync(encounters);
            await MarkMapTimingAsync("encounter-graphics-synced", new { reason, count = encounters.Count });

            _lastPitchFetchPosition = new GeoPosition { Latitude = lat, Longitude = lng };
            _lastPitchFetchAtUtc = DateTime.UtcNow;

            ScheduleCandidatePlaceLoad(lat, lng, reason);
        }
        catch (Exception ex)
        {
            if (IsExpectedGeoBlazorCancellation(ex))
            {
                Logger.LogDebug(ex, "Pitch marker load cancelled during map lifecycle transition");
                return;
            }

            Logger.LogError(ex, "Failed to load pitch markers");
            _statusMessage = "Failed to load pitches. Map is still usable.";
        }
        finally
        {
            loadStopwatch.Stop();
            if (requestId == _pitchMarkerLoadRequestId)
            {
                _pitchMarkerLoadInFlightPosition = null;
            }

            await MarkMapTimingAsync(
                "map-data-load-end",
                new { reason, durationMs = loadStopwatch.ElapsedMilliseconds });
            await LogMapPerfSummaryAsync("map-data-load-end");
        }

        if (!_isDisposing)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ScheduleCandidatePlaceLoad(double lat, double lng, string reason)
    {
        _candidatePlaceLoadCts?.Cancel();
        _candidatePlaceLoadCts?.Dispose();
        _candidatePlaceLoadCts = null;

        if (!_showCandidatePlaces || _isDisposing || !_enableGameGraphics || !_viewRendered)
        {
            _candidatePlaces = Array.Empty<PitchCandidatePlaceDto>();
            _ = ClearCandidatePlaceGraphicsAsync();
            return;
        }

        _candidatePlaceLoadCts = CancellationTokenSource.CreateLinkedTokenSource(_diagnosticsCts.Token);
        var token = _candidatePlaceLoadCts.Token;
        _ = LoadCandidatePlacesAfterDelayAsync(lat, lng, reason, token);
    }

    private async Task LoadCandidatePlacesAfterDelayAsync(double lat, double lng, string reason, CancellationToken token)
    {
        await MarkMapTimingAsync(
            "candidate-places-deferred",
            new { reason, delayMs = (int)CandidatePlaceDeferredLoadDelay.TotalMilliseconds });

        try
        {
            await Task.Delay(CandidatePlaceDeferredLoadDelay, token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        if (_isDisposing || token.IsCancellationRequested)
        {
            return;
        }

        await LoadCandidatePlacesAsync(lat, lng, reason, token);
    }

    private async Task LoadCandidatePlacesAsync(double lat, double lng, string reason, CancellationToken token)
    {
        try
        {
            var candidates = await TimedMapDataCallAsync(
                "candidate-places",
                reason,
                () => ApiClient.GetPitchCandidatePlacesAsync(lat, lng, BrowseRadiusMeters));
            if (_isDisposing || token.IsCancellationRequested) return;

            _candidatePlaces = candidates;
            await UpdateCandidatePlaceGraphicsAsync(_candidatePlaces);
            await MarkMapTimingAsync("candidate-place-graphics-synced", new { reason, count = candidates.Count });
            await LogMapPerfSummaryAsync("candidate-places-loaded");
        }
        catch (Exception ex)
        {
            if (IsExpectedGeoBlazorCancellation(ex) || token.IsCancellationRequested)
            {
                Logger.LogDebug(ex, "Candidate place load cancelled during map lifecycle transition");
                return;
            }

            Logger.LogWarning(ex, "Failed to load candidate places");
        }

        if (!_isDisposing && !token.IsCancellationRequested)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task UpdatePitchGraphicsAsync(List<PitchModel> pitches)
    {
        if (_isDisposing) return;

        var graphics = new List<KeyValuePair<int, Graphic>>(pitches.Count);
        foreach (var pitch in pitches)
        {
            var typeName = PitchTypeDisplayName(pitch.Type);
            var typeDescription = PitchTypeDescription(pitch.Type);
            var graphic = _useNativeGeoBlazorMap
                ? NativePitchFeatureLayerFactory.CreatePitchFeature(pitch, typeName, typeDescription)
                : MapGraphicFactory.CreatePitchGraphic(pitch, typeName, typeDescription);
            graphics.Add(new KeyValuePair<int, Graphic>(pitch.Id, graphic));
        }

        if (_useNativeGeoBlazorMap)
        {
            _pitchGraphics.Clear();
            foreach (var (key, graphic) in graphics)
            {
                _pitchGraphics[key] = graphic;
            }

            _nativePitchFeatures = graphics.Select(item => item.Value).ToArray();
            _nativePitchLayerVersion++;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_pitchLayer is null) return;

        try
        {
            await GraphicsLayerSync.ReplaceManyAsync(_pitchLayer, _pitchGraphics, graphics);
        }
        catch (Exception ex)
        {
            if (IsExpectedGeoBlazorCancellation(ex))
            {
                Logger.LogDebug(ex, "Pitch graphics update cancelled during map lifecycle transition");
                return;
            }

            Logger.LogWarning(ex, "Failed to add pitch graphics");
        }
    }

    private async Task ClearPitchLayersAsync()
    {
        if (_isDisposing) return;

        if (_useNativeGeoBlazorMap)
        {
            _nativePitchFeatures = Array.Empty<Graphic>();
            _pitchGraphics.Clear();
            _nativePitchLayerVersion++;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_pitchLayer is not null)
        {
            await _pitchLayer.Clear();
        }
    }

    private async Task UpdateEncounterGraphicsAsync(IReadOnlyList<PlayerEncounterDto> encounters)
    {
        if (_isDisposing) return;

        var spotlightEncounterId = SpotlightSightingSelector
            .Select(encounters, _lastKnownPosition, DateTime.UtcNow)
            ?.EncounterId;
        var graphics = new List<KeyValuePair<Guid, Graphic>>(encounters.Count);
        for (var i = 0; i < encounters.Count; i++)
        {
            var encounter = encounters[i];
            var isSpotlight = encounter.EncounterId == spotlightEncounterId;
            graphics.Add(new KeyValuePair<Guid, Graphic>(
                encounter.EncounterId,
                _useNativeGeoBlazorMap
                    ? NativeMapFeatureLayerFactory.CreateEncounterFeature(encounter, i + 1, isSpotlight)
                    : MapGraphicFactory.CreateEncounterGraphic(encounter, isSpotlight)));
        }

        if (_useNativeGeoBlazorMap)
        {
            _encounterGraphics.Clear();
            foreach (var (key, graphic) in graphics)
            {
                _encounterGraphics[key] = graphic;
            }

            _nativeEncounterFeatures = graphics.Select(item => item.Value).ToArray();
            _nativeEncounterLayerVersion++;
            Logger.LogInformation(
                "Native encounter features synced: requested={RequestedCount}, retained={RetainedCount}",
                encounters.Count,
                _encounterGraphics.Count);
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_encounterLayer is null) return;

        try
        {
            await GraphicsLayerSync.ReplaceManyAsync(_encounterLayer, _encounterGraphics, graphics);
            Logger.LogInformation(
                "Encounter graphics synced: requested={RequestedCount}, retained={RetainedCount}",
                encounters.Count,
                _encounterGraphics.Count);
        }
        catch (Exception ex)
        {
            if (IsExpectedGeoBlazorCancellation(ex))
            {
                Logger.LogDebug(ex, "Encounter graphics update cancelled during map lifecycle transition");
                return;
            }

            Logger.LogWarning(ex, "Failed to add encounter graphics");
        }
    }

    private async Task UpdateCandidatePlaceGraphicsAsync(IReadOnlyList<PitchCandidatePlaceDto> candidates)
    {
        if (_isDisposing) return;

        var graphics = new List<KeyValuePair<string, Graphic>>(candidates.Count);
        for (var i = 0; i < candidates.Count; i++)
        {
            var candidate = candidates[i];
            graphics.Add(new KeyValuePair<string, Graphic>(
                candidate.PlaceId,
                _useNativeGeoBlazorMap
                    ? NativeMapFeatureLayerFactory.CreateCandidatePlaceFeature(candidate, i + 1)
                    : MapGraphicFactory.CreateCandidatePlaceGraphic(candidate)));
        }

        if (_useNativeGeoBlazorMap)
        {
            _candidatePlaceGraphics.Clear();
            foreach (var (key, graphic) in graphics)
            {
                _candidatePlaceGraphics[key] = graphic;
            }

            _nativeCandidatePlaceFeatures = graphics.Select(item => item.Value).ToArray();
            _nativeCandidatePlaceLayerVersion++;
            await SetCandidatePlaceLayerVisibleAsync(true);
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_candidatePlaceLayer is null) return;

        try
        {
            await GraphicsLayerSync.ReplaceManyAsync(_candidatePlaceLayer, _candidatePlaceGraphics, graphics);
            await SetCandidatePlaceLayerVisibleAsync(true);
        }
        catch (Exception ex)
        {
            if (IsExpectedGeoBlazorCancellation(ex))
            {
                Logger.LogDebug(ex, "Candidate place graphics update cancelled during map lifecycle transition");
                return;
            }

            Logger.LogWarning(ex, "Failed to add pitch candidate place graphics");
        }
    }

    private async Task ClearCandidatePlaceGraphicsAsync()
    {
        if (_isDisposing) return;

        if (_useNativeGeoBlazorMap)
        {
            _nativeCandidatePlaceFeatures = Array.Empty<Graphic>();
            _candidatePlaceGraphics.Clear();
            _nativeCandidatePlaceLayerVersion++;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_candidatePlaceLayer is null) return;

        await _candidatePlaceLayer.Clear();
        _candidatePlaceGraphics.Clear();
    }

    private async Task SetCandidatePlaceLayerVisibleAsync(bool visible)
    {
        if (_isDisposing) return;

        try
        {
            if (_useNativeGeoBlazorMap)
            {
                _nativeCandidatePlaceLayerVersion++;
                if (_nativeCandidatePlaceLayer is not null)
                {
                    await _nativeCandidatePlaceLayer.SetVisible(visible);
                }
            }
            else if (_candidatePlaceLayer is not null)
            {
                await _candidatePlaceLayer.SetVisible(visible);
            }
        }
        catch (Exception ex)
        {
            if (IsExpectedGeoBlazorCancellation(ex))
            {
                Logger.LogDebug(ex, "Candidate place layer visibility update cancelled during map lifecycle transition");
                return;
            }

            Logger.LogDebug(ex, "Failed to update candidate place layer visibility");
        }
    }

    private async Task UpdatePlayerLocationGraphicAsync(GeoPosition position)
    {
        if (_isDisposing) return;

        if (_useNativeGeoBlazorMap)
        {
            _nativePlayerLocationFeatures = [NativeMapFeatureLayerFactory.CreatePlayerLocationFeature(position)];
            _nativePlayerAccuracyFeatures = [NativeMapFeatureLayerFactory.CreatePlayerAccuracyFeature(position)];
            _nativePlayerLocationLayerVersion++;
            _nativePlayerAccuracyLayerVersion++;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_playerLocationLayer is null) return;

        var graphics = MapGraphicFactory.CreatePlayerLocationGraphics(position);

        try
        {
            await GraphicsLayerSync.ReplaceAllAsync(_playerLocationLayer, graphics);
        }
        catch (Exception ex)
        {
            if (IsExpectedGeoBlazorCancellation(ex))
            {
                Logger.LogDebug(ex, "Player location graphic update cancelled during map lifecycle transition");
                return;
            }

            Logger.LogDebug(ex, "Failed to update player location graphic");
        }
    }

    private async Task HandleMapClick(ClickEvent clickEvent)
    {
        if (clickEvent?.MapPoint is null || _mapView is null)
            return;

        try
        {
            var hitResult = await _mapView.HitTest(clickEvent);
            foreach (var hit in hitResult.Results)
            {
                if (hit is GraphicHit graphicHit && TryApplyGraphicHitSelection(graphicHit.Graphic))
                {
                    return;
                }
            }

            if (clickEvent.MapPoint.Latitude.HasValue
                && clickEvent.MapPoint.Longitude.HasValue
                && TryApplyNearestMapSelection(clickEvent.MapPoint.Latitude.Value, clickEvent.MapPoint.Longitude.Value))
            {
                return;
            }

            Dispatcher.Dispatch(new ClearSelectionAction());
            _statusMessage = $"Clicked: {clickEvent.MapPoint.Latitude:F5}, {clickEvent.MapPoint.Longitude:F5}";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Map click hit-test failed");
            _statusMessage = $"Clicked: {clickEvent.MapPoint.Latitude:F5}, {clickEvent.MapPoint.Longitude:F5}";
            StateHasChanged();
        }
    }

    private bool TryApplyGraphicHitSelection(Graphic graphic)
    {
        var selection = MapGraphicSelection.FromGraphic(graphic);
        if (selection is null)
        {
            return false;
        }

        return selection.Kind switch
        {
            MapSelectionKind.Pitch => TrySelectPitchGraphic(selection.PitchId),
            MapSelectionKind.Encounter => TrySelectEncounterGraphic(selection.EncounterId),
            MapSelectionKind.CandidatePlace => TrySelectCandidatePlaceGraphic(selection),
            _ => false
        };
    }

    private bool TryApplyNearestMapSelection(double latitude, double longitude)
    {
        var clickedPosition = new GeoPosition { Latitude = latitude, Longitude = longitude };

        var nearestEncounter = MapState.Value.VisibleEncounters
            .Select(encounter => new
            {
                Encounter = encounter,
                DistanceMeters = DistanceMeters(clickedPosition, encounter.Latitude, encounter.Longitude)
            })
            .Where(item => item.DistanceMeters <= MapTapSelectionRadiusMeters)
            .OrderBy(item => item.DistanceMeters)
            .FirstOrDefault();
        if (nearestEncounter is not null)
        {
            return TrySelectEncounterGraphic(nearestEncounter.Encounter.EncounterId);
        }

        var nearestCandidate = _candidatePlaces
            .Select(candidate => new
            {
                Candidate = candidate,
                DistanceMeters = DistanceMeters(clickedPosition, candidate.Latitude, candidate.Longitude)
            })
            .Where(item => item.DistanceMeters <= MapTapSelectionRadiusMeters)
            .OrderBy(item => item.DistanceMeters)
            .FirstOrDefault();
        if (nearestCandidate is not null)
        {
            return TrySelectCandidatePlaceGraphic(MapSelection.CandidatePlace(
                nearestCandidate.Candidate.PlaceId,
                nearestCandidate.Candidate.Name,
                nearestCandidate.Candidate.RecommendedPitchType,
                nearestCandidate.Candidate.Confidence.ToString(System.Globalization.CultureInfo.InvariantCulture),
                nearestCandidate.Candidate.MatchReason,
                nearestCandidate.Candidate.CategoryLabel));
        }

        var nearestPitch = MapState.Value.VisiblePitches
            .Select(pitch => new
            {
                Pitch = pitch,
                DistanceMeters = DistanceMeters(clickedPosition, pitch.Latitude, pitch.Longitude)
            })
            .Where(item => item.DistanceMeters <= MapTapSelectionRadiusMeters)
            .OrderBy(item => item.DistanceMeters)
            .FirstOrDefault();
        if (nearestPitch is not null)
        {
            return TrySelectPitchGraphic(nearestPitch.Pitch.Id);
        }

        return false;
    }

    private static double DistanceMeters(GeoPosition origin, double latitude, double longitude) =>
        GeoPosition.HaversineDistance(origin, new GeoPosition { Latitude = latitude, Longitude = longitude });

    private bool TrySelectPitchGraphic(int? pitchId)
    {
        if (!pitchId.HasValue)
        {
            return false;
        }

        ClearCandidateSelection();
        _recruitBoardPitch = null;
        Dispatcher.Dispatch(new SelectPitchAction(pitchId.Value));
        _showRecruitBoard = false;
        return true;
    }

    private bool TrySelectEncounterGraphic(Guid? encounterId)
    {
        if (!encounterId.HasValue)
        {
            return false;
        }

        var encounter = MapState.Value.VisibleEncounters.FirstOrDefault(e => e.EncounterId == encounterId.Value);
        if (encounter is null)
        {
            return false;
        }

        ClearCandidateSelection();
        _recruitBoardPitch = null;
        _selectedEncounter = encounter;
        _showRecruitBoard = !_useNativeGeoBlazorMap;
        UpdateRecruitEligibility();
        _recruitMessage = null;
        Dispatcher.Dispatch(new SelectEncounterAction(encounterId.Value));
        return true;
    }

    private bool TrySelectCandidatePlaceGraphic(MapSelection selection)
    {
        if (selection.CandidatePlaceId is { Length: > 0 } placeId)
        {
            SelectCandidatePlace(placeId);
        }

        _recruitBoardPitch = null;
        _showRecruitBoard = false;
        var name = selection.CandidateName ?? _selectedCandidatePlace?.Name ?? "Candidate place";
        var recommendedType = selection.CandidateRecommendedPitchType ?? _selectedCandidatePlace?.RecommendedPitchType ?? "Pitch";
        var confidence = selection.CandidateConfidence ?? "?";
        var reason = selection.CandidateMatchReason ?? "matched place category";
        var category = selection.CandidateCategoryLabel ?? "Place";
        _statusMessage = $"Candidate: {name} -> {recommendedType} ({confidence}%). {reason}; {category}.";
        Dispatcher.Dispatch(new ClearSelectionAction());
        StateHasChanged();
        return true;
    }

