    private async Task RefreshSharedRecruitmentMapAsync(Guid encounterId, bool clearSelection)
    {
        if (_isDisposing || !_enableGameGraphics)
        {
            return;
        }

        try
        {
            var position = _lastKnownPosition;
            await InvokeAsync(async () =>
            {
                if (clearSelection)
                {
                    ClearEncounterSelection();
                }

                await RefreshGameProgress();
                await LoadPitchMarkersAsync(position?.Latitude ?? _latitude, position?.Longitude ?? _longitude, "shared-recruitment");
            });
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Failed to refresh shared recruitment encounter {EncounterId}", encounterId);
        }
    }

