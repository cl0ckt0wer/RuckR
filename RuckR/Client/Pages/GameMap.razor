    public static GpsStatusView BuildGpsStatus(
        bool hasApiKey,
        bool isWatching,
        string? errorMessage,
        GeoPosition? lastKnownPosition,
        double maxActionAccuracyMeters,
        DateTime? searchStartedAtUtc = null,
        DateTime? lastErrorAtUtc = null,
        DateTime? nowUtc = null)
    {
        var now = nowUtc ?? DateTime.UtcNow;
        var isMonitoringLocationSearch = ShouldMonitorLocationSearch(
            errorMessage,
            searchStartedAtUtc,
            lastErrorAtUtc,
            now);

        if (!hasApiKey)
        {
            return new GpsStatusView(
                GpsStatusKind.Offline,
                "Map offline",
                "Map services are not configured.",
                "offline",
                null);
        }

        if (!string.IsNullOrWhiteSpace(errorMessage) && isMonitoringLocationSearch)
        {
            return new GpsStatusView(
                GpsStatusKind.Searching,
                "Checking GPS",
                "Waiting for the browser to finish location permission and GPS lock.",
                "searching",
                null);
        }

        if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            return new GpsStatusView(
                GpsStatusKind.Blocked,
                "GPS blocked",
                errorMessage,
                "blocked",
                null);
        }

        if (lastKnownPosition is null)
        {
            return new GpsStatusView(
                GpsStatusKind.Searching,
                isWatching || isMonitoringLocationSearch ? "Searching" : "GPS idle",
                isWatching || isMonitoringLocationSearch
                    ? "Waiting for browser location."
                    : "Enable GPS to unlock distance checks.",
                "searching",
                null);
        }

        var accuracyText = lastKnownPosition.Accuracy.HasValue
            ? $"{Math.Round(lastKnownPosition.Accuracy.Value)}m"
            : null;

        if (lastKnownPosition.Accuracy.HasValue
            && lastKnownPosition.Accuracy.Value > maxActionAccuracyMeters)
        {
            return new GpsStatusView(
                GpsStatusKind.Weak,
                "Weak GPS",
                $"Accuracy is {Math.Round(lastKnownPosition.Accuracy.Value)}m. Recruiting needs {Math.Round(maxActionAccuracyMeters)}m or better.",
                "weak",
                accuracyText);
        }

        return new GpsStatusView(
            GpsStatusKind.Ready,
            "GPS on",
            accuracyText is null
                ? "Location is active."
                : $"Location is active with {accuracyText} accuracy.",
            "ready",
            accuracyText);
    }

    public static string? BuildGpsActionHint(GpsStatusView status, double maxActionAccuracyMeters)
    {
        return status.Kind switch
        {
            GpsStatusKind.Blocked => "Allow location permission in browser site settings, then retry GPS.",
            GpsStatusKind.Searching => "Waiting for GPS before checking range.",
            GpsStatusKind.Weak => $"Improve GPS accuracy to {Math.Round(maxActionAccuracyMeters)}m or better for recruiting and capture.",
            _ => null
        };
    }

