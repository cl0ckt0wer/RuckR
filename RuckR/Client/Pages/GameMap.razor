    private async Task LoadInitialPitchMarkersAsync()
    {
        if (_isDisposing)
        {
            return;
        }

        _initialMapDataLoadPending = true;
        _positionReceivedDuringInitialMapDataLoad = null;

        try
        {
            if (ShouldWaitForInitialGpsPosition(_enableAutoGpsWatch, _lastKnownPosition))
            {
                await MarkMapTimingAsync("initial-map-gps-wait-start", new { delayMs = (int)InitialMapGpsCoalesceDelay.TotalMilliseconds });
                try
                {
                    await Task.Delay(InitialMapGpsCoalesceDelay, _diagnosticsCts.Token);
                }
                catch (OperationCanceledException)
                {
                    return;
                }

                await MarkMapTimingAsync("initial-map-gps-wait-end", new { hasPosition = _lastKnownPosition is not null });
            }

            var initialPosition = _lastKnownPosition ?? new GeoPosition { Latitude = _latitude, Longitude = _longitude };
            await LoadPitchMarkersAsync(initialPosition.Latitude, initialPosition.Longitude, "initial");
        }
        finally
        {
            _initialMapDataLoadPending = false;
        }

        var pendingPosition = _positionReceivedDuringInitialMapDataLoad;
        _positionReceivedDuringInitialMapDataLoad = null;
        if (!_isDisposing && pendingPosition is not null && ShouldRefreshPitches(pendingPosition))
        {
            await LoadPitchMarkersAsync(pendingPosition.Latitude, pendingPosition.Longitude, "gps-after-initial");
        }
    }

