@page "/battle"
@using RuckR.Shared.Models
@using RuckR.Client.Store.InventoryFeature
@inject ApiClientService ApiClient
@inject SignalRClientService SignalRClient
@inject IState<BattleState> BattleState
@inject IState<InventoryState> InventoryState
@inject IDispatcher Dispatcher
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Battle Arena</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="game-page battle-page">
    @if (_requiresAuth)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2">Checking session...</MudText>
        </MudStack>
    }
    else if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8" data-testid="battle-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2">Loading battle arena...</MudText>
        </MudStack>
    }
    else
    {
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="game-page__header">
                <div>
                    <MudText Typo="Typo.overline">Arena</MudText>
                    <MudText Typo="Typo.h4">Battle Arena</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Challenge nearby users, accept matches, then choose a recruit and hidden rugby play.
                    </MudText>
                </div>
                <MudStack Row="true" Spacing="1" Class="battle-header__actions">
                    <MudButton Href="/players/nearby" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Groups">
                        Nearby
                    </MudButton>
                    <MudButton Href="/battles/history" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.History">
                        History
                    </MudButton>
                </MudStack>
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" data-testid="battle-error">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText>@_errorMessage</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="LoadBattlesAsync" data-testid="battle-retry-btn">Retry</MudButton>
                    </MudStack>
                </MudAlert>
            }

            @if (!string.IsNullOrWhiteSpace(_successMessage))
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" data-testid="battle-success">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText>@_successMessage</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="@(() => _successMessage = null)" />
                    </MudStack>
                </MudAlert>
            }

            <MudTabs @bind-ActivePanelIndex="_activeTabIndex" Rounded="true" Border="true" Class="battle-tabs" data-testid="battle-tabs">
                <MudTabPanel Text="New" Icon="@Icons.Material.Filled.SportsMma" data-testid="challenge-tab">
                    <MudGrid Class="mt-3" Spacing="3">
                        <MudItem xs="12" lg="5">
                            <MudPaper Elevation="1" Class="game-panel" data-testid="challenge-card">
                                <MudStack Spacing="2">
                                    <MudText Typo="Typo.h6">Send a challenge</MudText>
                                    <MudTextField T="string"
                                                  Label="Opponent username"
                                                  @bind-Value="_opponentUsername"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="ruckr2@ruckr.game"
                                                  data-testid="opponent-input" />

                                    <MudText Typo="Typo.caption" Color="Color.Secondary" data-testid="rate-limit-info">
                                        @_challengesSentThisHour of 10 challenges sent this hour
                                    </MudText>

                                    @if (!string.IsNullOrWhiteSpace(_formError))
                                    {
                                        <MudAlert Severity="Severity.Error" Dense="true">@_formError</MudAlert>
                                    }

                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.Send"
                                               Disabled="@(string.IsNullOrWhiteSpace(_opponentUsername) || _isSubmitting)"
                                               OnClick="SendChallengeAsync"
                                               data-testid="send-challenge-btn">
                                        @(_isSubmitting ? "Sending..." : "Send Challenge")
                                    </MudButton>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" lg="7">
                            <MudPaper Elevation="1" Class="game-panel collection-panel">
                                <MudStack Spacing="2">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                        <div>
                                            <MudText Typo="Typo.overline">Collection</MudText>
                                            <MudText Typo="Typo.h6">@_collectedPlayers.Count battle-ready recruits</MudText>
                                        </div>
                                        <MudButton Href="/collection" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Inventory2">
                                            Collection
                                        </MudButton>
                                    </MudStack>
                                    @if (_collectedPlayers.Count == 0)
                                    {
                                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Recruit at least one player before battling.</MudAlert>
                                    }
                                    else
                                    {
                                        <MudGrid Spacing="2">
                                            @foreach (var collection in _collectedPlayers.Where(c => c.Player is not null).Take(4))
                                            {
                                                <MudItem xs="12" sm="6">
                                                    <div class="mini-recruit">
                                                        <MudText Typo="Typo.subtitle2">@collection.Player!.Name</MudText>
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@collection.Player!.Position, @collection.Player!.Rarity</MudText>
                                                    </div>
                                                </MudItem>
                                            }
                                        </MudGrid>
                                    }
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <MudTabPanel Text="@IncomingTabLabel" Icon="@Icons.Material.Filled.CallReceived" data-testid="incoming-tab">
                    <MudStack Class="mt-3" Spacing="2" data-testid="incoming-challenges">
                        @if (_incomingChallenges.Count == 0)
                        {
                            <MudPaper Elevation="0" Class="game-panel empty-panel" data-testid="battle-empty">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">No incoming challenges.</MudText>
                            </MudPaper>
                        }
                        @foreach (var challenge in _incomingChallenges)
                        {
                            @RenderChallengeCard(challenge)
                        }
                    </MudStack>
                </MudTabPanel>

                <MudTabPanel Text="@OutgoingTabLabel" Icon="@Icons.Material.Filled.CallMade" data-testid="outgoing-tab">
                    <MudStack Class="mt-3" Spacing="2" data-testid="outgoing-challenges">
                        @if (_outgoingChallenges.Count == 0)
                        {
                            <MudPaper Elevation="0" Class="game-panel empty-panel">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">No outgoing challenges.</MudText>
                            </MudPaper>
                        }
                        @foreach (var challenge in _outgoingChallenges)
                        {
                            @RenderChallengeCard(challenge)
                        }
                    </MudStack>
                </MudTabPanel>

                <MudTabPanel Text="@SelectionTabLabel" Icon="@Icons.Material.Filled.SportsKabaddi" data-testid="selection-tab">
                    <MudStack Class="mt-3" Spacing="2" data-testid="selection-challenges">
                        @if (_acceptedChallenges.Count == 0)
                        {
                            <MudPaper Elevation="0" Class="game-panel empty-panel">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">No accepted battles waiting for selections.</MudText>
                            </MudPaper>
                        }
                        @foreach (var challenge in _acceptedChallenges)
                        {
                            @RenderChallengeCard(challenge)
                        }
                    </MudStack>
                </MudTabPanel>
            </MudTabs>
        </MudStack>
    }
</MudContainer>

@if (_showSelectionModal && _selectionTargetBattle is not null)
{
    <div class="game-modal-backdrop" data-testid="selection-modal">
        <MudPaper Elevation="8" Class="game-modal selection-modal">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.overline">Battle selection</MudText>
                        <MudText Typo="Typo.h6">vs @OpponentName(_selectionTargetBattle)</MudText>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseSelectionModal" data-testid="selection-cancel-btn" />
                </MudStack>

                <MudSelect T="int?" Label="Your recruit" @bind-Value="_selectedPlayerForSelection" Variant="Variant.Outlined" Dense="true" data-testid="selection-player-select">
                    <MudSelectItem T="int?" Value="@((int?)null)">Select a recruit</MudSelectItem>
                    @foreach (var collection in _collectedPlayers.Where(c => c.Player is not null))
                    {
                        <MudSelectItem T="int?" Value="@((int?)collection.Player!.Id)">
                            @collection.Player!.Name - @collection.Player.Position, @collection.Player.Rarity
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="BattleMove?" Label="Hidden rugby play" @bind-Value="_selectedMove" Variant="Variant.Outlined" Dense="true" data-testid="selection-move-select">
                    <MudSelectItem T="BattleMove?" Value="@((BattleMove?)null)">Select a play</MudSelectItem>
                    @foreach (var move in Enum.GetValues<BattleMove>())
                    {
                        <MudSelectItem T="BattleMove?" Value="@move">@BattleMoveDisplay.Name(move)</MudSelectItem>
                    }
                </MudSelect>

                @if (SelectedSelectionCollection?.Player is { } player)
                {
                    <MudPaper Elevation="0" Class="selection-preview">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="selection-preview__header">
                                <div>
                                    <MudText Typo="Typo.overline">Selected recruit</MudText>
                                    <MudText Typo="Typo.h6">@player.Name</MudText>
                                </div>
                                <MudChip T="string" Color="@RarityColor(player.Rarity)" Variant="Variant.Filled">@player.Rarity</MudChip>
                            </MudStack>
                            @RenderStats(player)
                        </MudStack>
                    </MudPaper>
                }

                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1" Class="selection-modal__actions">
                    <MudButton Variant="Variant.Text" OnClick="CloseSelectionModal">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Check"
                               Disabled="@(!_selectedPlayerForSelection.HasValue || !_selectedMove.HasValue || _isSubmittingSelection)"
                               OnClick="SubmitSelectionAsync"
                               data-testid="selection-submit-btn">
                        @(_isSubmittingSelection ? "Submitting..." : "Submit")
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </div>
}

@if (_showResultModal && _resultToShow is { } result)
{
    var isWinner = string.Equals(result.WinnerUsername, _currentUsername, StringComparison.OrdinalIgnoreCase);
    <div class="game-modal-backdrop" data-testid="result-modal">
        <MudPaper Elevation="8" Class="game-modal result-modal">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.overline">Battle result</MudText>
                        <MudText Typo="Typo.h5" Color="@(isWinner ? Color.Success : Color.Error)" data-testid="result-header">
                            @(isWinner ? "Victory" : "Defeat")
                        </MudText>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="DismissResultModal" data-testid="result-close-btn" />
                </MudStack>
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <div class="result-side result-side--winner">
                            <MudText Typo="Typo.caption">Winner</MudText>
                            <MudText Typo="Typo.h6">@result.WinnerUsername</MudText>
                            <MudText Typo="Typo.body2">@result.WinnerPlayerName</MudText>
                            <MudText Typo="Typo.caption">@MoveScoreDisplay(result.WinnerMove, result.WinnerScore)</MudText>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <div class="result-side">
                            <MudText Typo="Typo.caption">Defeated</MudText>
                            <MudText Typo="Typo.h6">@result.LoserUsername</MudText>
                            <MudText Typo="Typo.body2">@result.LoserPlayerName</MudText>
                            <MudText Typo="Typo.caption">@MoveScoreDisplay(result.LoserMove, result.LoserScore)</MudText>
                        </div>
                    </MudItem>
                </MudGrid>
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Method: @result.Method
                </MudAlert>
                <MudButton Href="/battles/history" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.History">
                    View History
                </MudButton>
            </MudStack>
        </MudPaper>
    </div>
}

@code {
    private bool _requiresAuth = true;
    private bool _isLoading = true;
    private string? _errorMessage;
    private string? _successMessage;
    private string? _formError;
    private bool _isSubmitting;
    private bool _isAccepting;
    private bool _isSubmittingSelection;
    private string _currentUsername = string.Empty;
    private int _activeTabIndex;
    private string _opponentUsername = string.Empty;
    private bool _showSelectionModal;
    private BattleSummaryDto? _selectionTargetBattle;
    private int? _selectedPlayerForSelection;
    private BattleMove? _selectedMove;
    private bool _showResultModal;
    private BattleResult? _resultToShow;
    private int _challengesSentThisHour;
    private DateTime _rateLimitWindowStart = DateTime.UtcNow;
    private IReadOnlyList<CollectionModel> _collectedPlayers = Array.Empty<CollectionModel>();
    private BattleResult? _lastShownResult;

    private CollectionModel? SelectedSelectionCollection =>
        _selectedPlayerForSelection.HasValue ? _collectedPlayers.FirstOrDefault(c => c.PlayerId == _selectedPlayerForSelection.Value) : null;

    private List<BattleSummaryDto> _incomingChallenges => BattleState.Value.ActiveChallenges
        .Where(b => string.Equals(b.OpponentUsername, _currentUsername, StringComparison.OrdinalIgnoreCase)
                    && b.Status == BattleStatus.Pending)
        .OrderByDescending(b => b.CreatedAt)
        .ToList();

    private List<BattleSummaryDto> _outgoingChallenges => BattleState.Value.ActiveChallenges
        .Where(b => string.Equals(b.ChallengerUsername, _currentUsername, StringComparison.OrdinalIgnoreCase)
                    && b.Status == BattleStatus.Pending)
        .OrderByDescending(b => b.CreatedAt)
        .ToList();

    private List<BattleSummaryDto> _acceptedChallenges => BattleState.Value.ActiveChallenges
        .Where(b => b.Status == BattleStatus.Accepted
                    && (string.Equals(b.ChallengerUsername, _currentUsername, StringComparison.OrdinalIgnoreCase)
                        || string.Equals(b.OpponentUsername, _currentUsername, StringComparison.OrdinalIgnoreCase)))
        .OrderByDescending(b => b.AcceptedAt ?? b.CreatedAt)
        .ToList();

    private string IncomingTabLabel => _incomingChallenges.Count == 0 ? "Incoming" : $"Incoming ({_incomingChallenges.Count})";
    private string OutgoingTabLabel => _outgoingChallenges.Count == 0 ? "Outgoing" : $"Outgoing ({_outgoingChallenges.Count})";
    private string SelectionTabLabel => _acceptedChallenges.Count == 0 ? "Pick" : $"Pick ({_acceptedChallenges.Count})";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is null || !user.Identity.IsAuthenticated)
        {
            var returnUrl = Uri.EscapeDataString("/" + Navigation.ToBaseRelativePath(Navigation.Uri));
            Navigation.NavigateTo($"/Identity/Account/Login?returnUrl={returnUrl}", forceLoad: true);
            return;
        }

        _requiresAuth = false;
        _currentUsername = user.Identity.Name ?? string.Empty;

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _opponentUsername = query["opponent"] ?? string.Empty;

        await LoadCollectionAsync();
        await LoadBattlesAsync();
        BattleState.StateChanged += OnBattleStateChanged;
        SignalRClient.BattleResolved += OnBattleResolved;
        SignalRClient.BattleUpdated += OnBattleUpdated;
        SignalRClient.ChallengeReceived += OnChallengeReceived;

        try
        {
            await SignalRClient.StartAsync();
        }
        catch
        {
            _errorMessage = "Live battle updates are disconnected. Actions still work, but updates may require refresh.";
        }
    }

    private async Task LoadCollectionAsync()
    {
        _collectedPlayers = InventoryState.Value.CollectedPlayers;
        if (_collectedPlayers.Count > 0)
            return;

        try
        {
            var collection = await ApiClient.GetCollectionAsync();
            _collectedPlayers = collection.AsReadOnly();
            Dispatcher.Dispatch(new FetchInventoryResultAction(collection.AsReadOnly()));
        }
        catch
        {
            _collectedPlayers = Array.Empty<CollectionModel>();
        }
    }

    private async Task LoadBattlesAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var pending = await ApiClient.GetPendingBattlesAsync();
            var history = await ApiClient.GetBattleHistoryAsync();
            Dispatcher.Dispatch(new FetchBattlesResultAction(pending.AsReadOnly(), history.AsReadOnly()));
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Failed to load battles: {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SendChallengeAsync()
    {
        if (string.IsNullOrWhiteSpace(_opponentUsername))
        {
            _formError = "Enter an opponent username.";
            return;
        }

        if (DateTime.UtcNow - _rateLimitWindowStart > TimeSpan.FromHours(1))
        {
            _rateLimitWindowStart = DateTime.UtcNow;
            _challengesSentThisHour = 0;
        }

        _isSubmitting = true;
        _formError = null;

        try
        {
            var battle = await ApiClient.SendChallengeAsync(_opponentUsername.Trim());
            if (battle is not null)
            {
                Dispatcher.Dispatch(new BattleUpdatedAction(battle));
                _challengesSentThisHour++;
                _successMessage = $"Challenge sent to {battle.OpponentUsername}.";
                _opponentUsername = string.Empty;
                _activeTabIndex = 2;
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.BadRequest)
        {
            _formError = "Check the opponent username, collection requirements, and pending challenge limit.";
        }
        catch (HttpRequestException ex) when ((int?)ex.StatusCode == 429)
        {
            _formError = "Rate limit exceeded. You can send 10 challenges per hour.";
        }
        catch (HttpRequestException ex)
        {
            _formError = $"Failed to send challenge: {ex.Message}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task AcceptChallengeAsync(BattleSummaryDto challenge)
    {
        _isAccepting = true;
        _errorMessage = null;

        try
        {
            var battle = await ApiClient.AcceptChallengeAsync(challenge.Id);
            if (battle is not null)
            {
                Dispatcher.Dispatch(new BattleUpdatedAction(battle));
                _successMessage = "Challenge accepted.";
                _activeTabIndex = 3;
                OpenSelectionModal(battle);
            }
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Failed to accept challenge: {ex.Message}";
        }
        finally
        {
            _isAccepting = false;
        }
    }

    private async Task DeclineChallengeAsync(int battleId)
    {
        try
        {
            await ApiClient.DeclineChallengeAsync(battleId);
            Dispatcher.Dispatch(new ChallengeRespondedAction(battleId, BattleStatus.Declined));
            _successMessage = "Challenge declined.";
            await LoadBattlesAsync();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Failed to decline challenge: {ex.Message}";
        }
    }

    private void OpenSelectionModal(BattleSummaryDto battle)
    {
        _selectionTargetBattle = battle;
        _selectedPlayerForSelection = CurrentUserPlayerId(battle);
        _selectedMove = CurrentUserMove(battle);
        _showSelectionModal = true;
    }

    private void CloseSelectionModal()
    {
        _showSelectionModal = false;
        _selectionTargetBattle = null;
        _selectedPlayerForSelection = null;
        _selectedMove = null;
    }

    private async Task SubmitSelectionAsync()
    {
        if (_selectionTargetBattle is null || !_selectedPlayerForSelection.HasValue || !_selectedMove.HasValue)
            return;

        _isSubmittingSelection = true;
        _errorMessage = null;

        try
        {
            var battle = await ApiClient.SubmitBattleSelectionAsync(
                _selectionTargetBattle.Id,
                _selectedPlayerForSelection.Value,
                _selectedMove.Value);

            if (battle is not null)
            {
                Dispatcher.Dispatch(new BattleUpdatedAction(battle));
                if (battle.Result is not null)
                {
                    _resultToShow = battle.Result;
                    _showResultModal = true;
                    _successMessage = "Battle resolved.";
                }
                else
                {
                    _successMessage = "Selection submitted.";
                }

                await LoadBattlesAsync();
            }
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Failed to submit selection: {ex.Message}";
        }
        finally
        {
            _isSubmittingSelection = false;
            CloseSelectionModal();
        }
    }

    private void OnBattleStateChanged(object? sender, EventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnBattleUpdated(BattleSummaryDto battle)
    {
        if (battle.Result is not null)
        {
            _resultToShow = battle.Result;
            _showResultModal = true;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    private void OnBattleResolved(BattleResult result)
    {
        if (_lastShownResult is { } last &&
            last.WinnerUsername == result.WinnerUsername &&
            last.LoserUsername == result.LoserUsername &&
            last.CreatedAt == result.CreatedAt)
        {
            return;
        }

        _lastShownResult = result;
        _resultToShow = result;
        _showResultModal = true;
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnChallengeReceived(ChallengeNotification notification)
    {
        _successMessage = $"{notification.ChallengerUsername} challenged you.";
        _activeTabIndex = 1;
        _ = InvokeAsync(async () =>
        {
            await LoadBattlesAsync();
            StateHasChanged();
        });
    }

    private void DismissResultModal()
    {
        _showResultModal = false;
        _resultToShow = null;
    }

    private RenderFragment RenderChallengeCard(BattleSummaryDto challenge) => @<MudPaper Elevation="1" Class="game-panel challenge-card" data-testid="@ChallengeCardTestId(challenge)">
        <MudStack Spacing="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="challenge-card__summary">
                <div class="challenge-card__identity">
                    <MudText Typo="Typo.caption">@RoleLabel(challenge)</MudText>
                    <MudText Typo="Typo.h6">@OpponentName(challenge)</MudText>
                </div>
                <MudChip T="string" Color="@StatusColor(challenge.Status)" Variant="Variant.Filled">@StatusLabel(challenge.Status)</MudChip>
            </MudStack>

            <MudGrid Spacing="2">
                <MudItem xs="12" md="6">
                    <div class="selection-status">
                        <MudText Typo="Typo.caption">Your selection</MudText>
                        <MudText Typo="Typo.body2">@SelectionDisplay(CurrentUserPlayer(challenge), CurrentUserMove(challenge))</MudText>
                    </div>
                </MudItem>
                <MudItem xs="12" md="6">
                    <div class="selection-status">
                        <MudText Typo="Typo.caption">Opponent</MudText>
                        <MudText Typo="Typo.body2">@OpponentSubmissionDisplay(challenge)</MudText>
                    </div>
                </MudItem>
            </MudGrid>

            <MudText Typo="Typo.caption" Color="Color.Secondary">@GetRelativeTime(challenge.CreatedAt)</MudText>

            @if (IsIncoming(challenge) && challenge.Status == BattleStatus.Pending)
            {
                <MudStack Row="true" Spacing="1" Class="challenge-card__actions">
                    <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Check" Size="Size.Small" Disabled="@_isAccepting" OnClick="() => AcceptChallengeAsync(challenge)" data-testid="accept-btn">
                        Accept
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => DeclineChallengeAsync(challenge.Id)" data-testid="decline-btn">
                        Decline
                    </MudButton>
                </MudStack>
            }
            else if (challenge.Status == BattleStatus.Pending)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">Waiting for opponent response.</MudText>
            }
            else if (challenge.Status == BattleStatus.Accepted && !CurrentUserSubmitted(challenge))
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.SportsKabaddi" Size="Size.Small" Class="challenge-card__primary-action" OnClick="() => OpenSelectionModal(challenge)" data-testid="pick-selection-btn">
                    Pick Recruit and Play
                </MudButton>
            }
            else if (challenge.Status == BattleStatus.Accepted)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">You submitted. Waiting for opponent.</MudAlert>
            }
        </MudStack>
    </MudPaper>;

    private RenderFragment RenderStats(PlayerModel player) => @<MudStack Spacing="1">
        @RenderStat("Speed", player.Speed, Color.Success)
        @RenderStat("Strength", player.Strength, Color.Error)
        @RenderStat("Agility", player.Agility, Color.Info)
        @RenderStat("Kicking", player.Kicking, Color.Warning)
    </MudStack>;

    private RenderFragment RenderStat(string label, int value, Color color) => @<div class="stat-row">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.caption">@label</MudText>
            <MudText Typo="Typo.caption">@value / 99</MudText>
        </MudStack>
        <MudProgressLinear Value="@StatPercent(value)" Color="@color" Rounded="true" />
    </div>;

    private bool IsIncoming(BattleSummaryDto battle) =>
        string.Equals(battle.OpponentUsername, _currentUsername, StringComparison.OrdinalIgnoreCase);

    private string RoleLabel(BattleSummaryDto battle) => IsIncoming(battle) ? "From" : "To";

    private string OpponentName(BattleSummaryDto battle) =>
        IsIncoming(battle) ? battle.ChallengerUsername : battle.OpponentUsername;

    private bool CurrentUserIsChallenger(BattleSummaryDto battle) =>
        string.Equals(battle.ChallengerUsername, _currentUsername, StringComparison.OrdinalIgnoreCase);

    private bool CurrentUserSubmitted(BattleSummaryDto battle) =>
        CurrentUserIsChallenger(battle) ? battle.ChallengerSubmitted : battle.OpponentSubmitted;

    private bool OpponentSubmitted(BattleSummaryDto battle) =>
        CurrentUserIsChallenger(battle) ? battle.OpponentSubmitted : battle.ChallengerSubmitted;

    private BattlePlayerSummaryDto? CurrentUserPlayer(BattleSummaryDto battle) =>
        CurrentUserIsChallenger(battle) ? battle.ChallengerPlayer : battle.OpponentPlayer;

    private int? CurrentUserPlayerId(BattleSummaryDto battle) =>
        CurrentUserIsChallenger(battle) ? battle.ChallengerPlayerId : battle.OpponentPlayerId;

    private BattleMove? CurrentUserMove(BattleSummaryDto battle) =>
        CurrentUserIsChallenger(battle) ? battle.ChallengerMove : battle.OpponentMove;

    private static string SelectionDisplay(BattlePlayerSummaryDto? player, BattleMove? move)
    {
        if (player is null || move is null)
            return "Not submitted";

        return $"{player.Name} with {BattleMoveDisplay.Name(move.Value)}";
    }

    private string OpponentSubmissionDisplay(BattleSummaryDto battle)
    {
        if (battle.Status == BattleStatus.Completed)
        {
            var player = CurrentUserIsChallenger(battle) ? battle.OpponentPlayer : battle.ChallengerPlayer;
            var move = CurrentUserIsChallenger(battle) ? battle.OpponentMove : battle.ChallengerMove;
            return SelectionDisplay(player, move);
        }

        return OpponentSubmitted(battle) ? "Submitted" : "Waiting";
    }

    private static string ChallengeCardTestId(BattleSummaryDto battle) => battle.Status switch
    {
        BattleStatus.Accepted => "accepted-card",
        BattleStatus.Pending => "pending-card",
        _ => "battle-card"
    };

    private static double StatPercent(int value) => Math.Clamp(value, 0, 99) * 100.0 / 99.0;

    private static string GetRelativeTime(DateTime utcTime)
    {
        var elapsed = DateTime.UtcNow - utcTime;
        if (elapsed.TotalSeconds < 60) return "just now";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes} min ago";
        if (elapsed.TotalHours < 24) return $"{(int)elapsed.TotalHours}h ago";
        if (elapsed.TotalDays < 7) return $"{(int)elapsed.TotalDays}d ago";
        return utcTime.ToString("MMM d");
    }

    private static string MoveScoreDisplay(BattleMove? move, double? score)
    {
        return BattleMoveDisplay.Score(move, score, string.Empty);
    }

    private static Color StatusColor(BattleStatus status) => status switch
    {
        BattleStatus.Pending => Color.Warning,
        BattleStatus.Accepted => Color.Info,
        BattleStatus.Completed => Color.Success,
        BattleStatus.Declined => Color.Secondary,
        BattleStatus.Expired => Color.Dark,
        _ => Color.Default
    };

    private static string StatusLabel(BattleStatus status) => status switch
    {
        BattleStatus.Pending => "Pending",
        BattleStatus.Accepted => "Accepted",
        BattleStatus.Completed => "Completed",
        BattleStatus.Declined => "Declined",
        BattleStatus.Expired => "Expired",
        _ => status.ToString()
    };

    private static Color RarityColor(PlayerRarity rarity) => rarity switch
    {
        PlayerRarity.Common => Color.Secondary,
        PlayerRarity.Uncommon => Color.Success,
        PlayerRarity.Rare => Color.Primary,
        PlayerRarity.Epic => Color.Tertiary,
        PlayerRarity.Legendary => Color.Warning,
        _ => Color.Default
    };

    public void Dispose()
    {
        BattleState.StateChanged -= OnBattleStateChanged;
        SignalRClient.BattleResolved -= OnBattleResolved;
        SignalRClient.BattleUpdated -= OnBattleUpdated;
        SignalRClient.ChallengeReceived -= OnChallengeReceived;
    }
}

