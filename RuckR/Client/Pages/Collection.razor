@page "/collection"
@using RuckR.Shared.Models
@using RuckR.Client.Store.InventoryFeature
@inject ApiClientService ApiClient
@inject IDispatcher Dispatcher
@inject IState<InventoryState> InventoryState
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>My Collection</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="game-page collection-page">
    @if (requiresAuth)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2">Checking session...</MudText>
        </MudStack>
    }
    else if (isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8" data-testid="collection-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2">Loading your collection...</MudText>
        </MudStack>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" data-testid="collection-error">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText>@errorMessage</MudText>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="LoadCollectionAsync" data-testid="collection-retry-btn">Retry</MudButton>
            </MudStack>
        </MudAlert>
    }
    else if (collectedPlayers is null || collectedPlayers.Count == 0)
    {
        <MudPaper Elevation="0" Class="game-panel empty-panel" data-testid="empty-state">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.TravelExplore" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h5">No recruits yet</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Open the map and recruit from nearby parks.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Map" OnClick="GoToMap">
                    Explore Map
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="game-page__header">
                <div>
                    <MudText Typo="Typo.overline">Roster</MudText>
                    <MudText Typo="Typo.h4">My Collection</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @collectedPlayers.Count recruits ready for challenges.
                    </MudText>
                </div>
                <MudStack Row="true" Spacing="1">
                    <MudButton Href="/map" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Map">
                        Recruit
                    </MudButton>
                    <MudButton Href="/battle" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Bolt">
                        Battle
                    </MudButton>
                </MudStack>
            </MudStack>

            <MudGrid Spacing="3" data-testid="collection-grid">
                @foreach (var item in collectedPlayers.OrderByDescending(c => c.IsFavorite).ThenBy(c => c.Player?.Name))
                {
                    var player = item.Player;
                    if (player is null)
                    {
                        continue;
                    }

                    var isExpanded = expandedId == item.Id;
                    var pitchName = item.CapturedAtPitchId is not null && pitchNames.TryGetValue(item.CapturedAtPitchId.Value, out var pn) ? pn : "Unknown pitch";

                    <MudItem xs="12" md="6" xl="4">
                        <MudPaper Elevation="1" Class="@CollectionCardClass(isExpanded)" data-testid="collection-card">
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                                    <div role="button" @onclick="() => ToggleExpand(item.Id)" class="collection-card__title">
                                        <MudText Typo="Typo.h6" data-testid="collection-player-name">@player.Name</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Captured @item.CapturedAt.ToString("MMM dd, yyyy") at @pitchName
                                        </MudText>
                                    </div>
                                    <MudIconButton Icon="@(item.IsFavorite ? Icons.Material.Filled.Star : Icons.Material.Outlined.StarBorder)"
                                                   Color="@(item.IsFavorite ? Color.Warning : Color.Default)"
                                                   OnClick="() => ToggleFavoriteAsync(item)"
                                                   title="@(item.IsFavorite ? "Remove favorite" : "Add favorite")"
                                                   data-testid="favorite-btn" />
                                </MudStack>

                                <MudChipSet T="string">
                                    <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" data-testid="collection-position-badge">@player.Position</MudChip>
                                    <MudChip T="string" Color="@RarityColor(player.Rarity)" Variant="Variant.Filled" data-testid="collection-rarity-badge">@player.Rarity</MudChip>
                                    <MudChip T="string" Variant="Variant.Outlined">Level @player.Level</MudChip>
                                </MudChipSet>

                                @RenderCompactStats(player)

                                <MudStack Row="true" Spacing="1">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Primary"
                                               StartIcon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                               OnClick="() => ToggleExpand(item.Id)">
                                        @(isExpanded ? "Less" : "Details")
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.Bolt"
                                               OnClick="() => ChallengePlayer(item)"
                                               data-testid="collection-challenge-btn">
                                        Challenge
                                    </MudButton>
                                </MudStack>

                                @if (isExpanded)
                                {
                                    <div class="collection-card__detail" data-testid="collection-detail">
                                        @RenderFullStats(player)
                                        @if (!string.IsNullOrWhiteSpace(player.Team))
                                        {
                                            <MudText Typo="Typo.body2"><strong>Team:</strong> @player.Team</MudText>
                                        }
                                        <MudText Typo="Typo.body2">
                                            <strong>Rarity:</strong> @RarityDescription(player.Rarity)
                                        </MudText>
                                        @if (!string.IsNullOrWhiteSpace(player.Bio))
                                        {
                                            <MudText Typo="Typo.body2">@player.Bio</MudText>
                                        }
                                    </div>
                                }
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        </MudStack>
    }
</MudContainer>

@code {
    private bool requiresAuth = true;
    private bool isLoading = true;
    private string? errorMessage;
    private IReadOnlyList<CollectionModel>? collectedPlayers;
    private Dictionary<int, string> pitchNames = new();
    private int? expandedId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is null || !user.Identity.IsAuthenticated)
        {
            var returnUrl = Uri.EscapeDataString("/" + Navigation.ToBaseRelativePath(Navigation.Uri));
            Navigation.NavigateTo($"/Identity/Account/Login?returnUrl={returnUrl}", forceLoad: true);
            return;
        }

        requiresAuth = false;
        await LoadCollectionAsync();
    }

    private void GoToMap()
    {
        Navigation.NavigateTo("/map");
    }

    private async Task LoadCollectionAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var collection = await ApiClient.GetCollectionAsync();
            Dispatcher.Dispatch(new FetchInventoryResultAction(collection.AsReadOnly()));

            if (collection.Count > 0)
            {
                try
                {
                    var pitches = await ApiClient.GetPitchesAsync();
                    pitchNames = pitches.ToDictionary(p => p.Id, p => p.Name);
                }
                catch
                {
                    pitchNames = new();
                }
            }

            collectedPlayers = collection.AsReadOnly();
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"Failed to load collection: {ex.Message}";
        }
        catch (Exception ex)
        {
            errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleExpand(int collectionId)
    {
        expandedId = expandedId == collectionId ? null : collectionId;
    }

    private async Task ToggleFavoriteAsync(CollectionModel item)
    {
        var previousValue = item.IsFavorite;
        item.IsFavorite = !item.IsFavorite;
        Dispatcher.Dispatch(new ToggleFavoriteAction(item.Id));

        try
        {
            await ApiClient.ToggleFavoriteAsync(item.Id);
        }
        catch
        {
            item.IsFavorite = previousValue;
            Dispatcher.Dispatch(new ToggleFavoriteAction(item.Id));
            errorMessage = "Failed to update favorite. Please try again.";
        }
    }

    private void ChallengePlayer(CollectionModel item)
    {
        Navigation.NavigateTo($"/battle?player={item.PlayerId}");
    }

    private RenderFragment RenderCompactStats(PlayerModel player) => @<MudGrid Spacing="1">
        <MudItem xs="6"><MudText Typo="Typo.caption">Speed <strong>@player.Speed</strong></MudText></MudItem>
        <MudItem xs="6"><MudText Typo="Typo.caption">Strength <strong>@player.Strength</strong></MudText></MudItem>
        <MudItem xs="6"><MudText Typo="Typo.caption">Agility <strong>@player.Agility</strong></MudText></MudItem>
        <MudItem xs="6"><MudText Typo="Typo.caption">Kicking <strong>@player.Kicking</strong></MudText></MudItem>
    </MudGrid>;

    private RenderFragment RenderFullStats(PlayerModel player) => @<MudStack Spacing="1" Class="collection-stats">
        @RenderStat("Speed", player.Speed, Color.Success)
        @RenderStat("Strength", player.Strength, Color.Error)
        @RenderStat("Agility", player.Agility, Color.Info)
        @RenderStat("Kicking", player.Kicking, Color.Warning)
    </MudStack>;

    private RenderFragment RenderStat(string label, int value, Color color) => @<div class="stat-row">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.caption">@label</MudText>
            <MudText Typo="Typo.caption">@value / 99</MudText>
        </MudStack>
        <MudProgressLinear Value="@StatPercent(value)" Color="@color" Rounded="true" />
    </div>;

    private static string CollectionCardClass(bool expanded) => expanded
        ? "game-panel collection-card collection-card--expanded"
        : "game-panel collection-card";

    private static double StatPercent(int value) => Math.Clamp(value, 0, 99) * 100.0 / 99.0;

    private static Color RarityColor(PlayerRarity rarity) => rarity switch
    {
        PlayerRarity.Common => Color.Secondary,
        PlayerRarity.Uncommon => Color.Success,
        PlayerRarity.Rare => Color.Primary,
        PlayerRarity.Epic => Color.Tertiary,
        PlayerRarity.Legendary => Color.Warning,
        _ => Color.Default
    };

    private static string RarityDescription(PlayerRarity rarity) => rarity switch
    {
        PlayerRarity.Common => "Common recruit with reliable fundamentals.",
        PlayerRarity.Uncommon => "Above-average recruit with useful upside.",
        PlayerRarity.Rare => "Hard-to-find recruit with strong match impact.",
        PlayerRarity.Epic => "High-impact recruit for serious challenges.",
        PlayerRarity.Legendary => "Top-tier recruit and a major battle threat.",
        _ => string.Empty
    };
}

<style>
    .game-page {
        padding: 1rem;
    }

    .game-page__header {
        gap: 1rem;
        flex-wrap: wrap;
    }

    .game-panel {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 8px;
        padding: 1rem;
        background: #fff;
    }

    .empty-panel {
        min-height: 18rem;
        display: grid;
        place-items: center;
        text-align: center;
    }

    .collection-card {
        min-height: 19rem;
    }

    .collection-card--expanded {
        border-color: rgba(15, 118, 110, 0.4);
    }

    .collection-card__title {
        min-width: 0;
        cursor: pointer;
    }

    .collection-card__detail {
        display: grid;
        gap: 0.75rem;
        border-top: 1px solid rgba(15, 23, 42, 0.08);
        padding-top: 0.75rem;
    }

    .stat-row {
        display: grid;
        gap: 0.25rem;
    }

    @@media (max-width: 720px) {
        .game-page {
            padding: 0.75rem;
        }

        .game-panel {
            padding: 0.85rem;
        }
    }
</style>
