@page "/catalog"
@using RuckR.Shared.Models
@using RuckR.Client.Store.InventoryFeature
@inject ApiClientService ApiClient
@inject IDispatcher Dispatcher
@inject IState<InventoryState> InventoryState

<PageTitle>Player Catalog</PageTitle>

<h1>Player Catalog</h1>

<div class="row mb-3 g-2 align-items-end">
    <div class="col-auto">
        <label class="form-label mb-1">Position</label>
        <select class="form-select form-select-sm" @bind="selectedPosition">
            <option value="">All</option>
            @foreach (var pos in Enum.GetValues<PlayerPosition>())
            {
                <option value="@pos.ToString()">@pos</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label mb-1">Rarity</label>
        <select class="form-select form-select-sm" @bind="selectedRarity">
            <option value="">All</option>
            @foreach (var rar in Enum.GetValues<PlayerRarity>())
            {
                <option value="@rar.ToString()">@rar</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label mb-1">Name</label>
        <input type="text" class="form-control form-control-sm" placeholder="Search..." @bind="nameFilter" @bind:event="oninput" />
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Loading players...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger d-flex align-items-center">
        <span class="me-auto">@errorMessage</span>
        <button class="btn btn-outline-danger btn-sm ms-3" @onclick="LoadData">Retry</button>
    </div>
}
else if (!filteredPlayers.Any())
{
    <div class="text-center py-5">
        <div class="display-1 mb-3">🏉</div>
        <h4>No players found!</h4>
        <p class="text-muted">No players match your filters. Try adjusting them or explore the map.</p>
        <button class="btn btn-primary me-2" @onclick="ClearFilters">Clear Filters</button>
        <a href="/map" class="btn btn-outline-primary">Explore Map</a>
    </div>
}
else
{
    var collectedPlayerIds = InventoryState.Value.CollectedPlayers
        .Select(c => c.PlayerId)
        .ToHashSet();

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
        @foreach (var player in filteredPlayers)
        {
            var rarityColor = GetRarityColor(player.Rarity);
            <div class="card h-100">
                <div class="card-header d-flex flex-wrap gap-1 align-items-center">
                    <span class="badge" style="background-color: @rarityColor;">
                        @player.Rarity
                    </span>
                    <span class="badge bg-secondary">@player.Position</span>
                    @if (collectedPlayerIds.Contains(player.Id))
                    {
                        <span class="badge bg-success ms-auto">✅ Collected</span>
                    }
                </div>
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title mb-1">@player.Name</h5>
                    @if (!string.IsNullOrEmpty(player.Team))
                    {
                        <h6 class="card-subtitle mb-3 text-muted">@player.Team</h6>
                    }
                    else
                    {
                        <div class="mb-3"></div>
                    }

                    <div class="mt-auto">
                        <div class="mb-1">
                            <small class="d-flex justify-content-between">
                                <span>Speed</span><span>@player.Speed</span>
                            </small>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-primary" role="progressbar" style="width: @player.Speed%;" aria-valuenow="@player.Speed" aria-valuemin="0" aria-valuemax="99"></div>
                            </div>
                        </div>
                        <div class="mb-1">
                            <small class="d-flex justify-content-between">
                                <span>Strength</span><span>@player.Strength</span>
                            </small>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-danger" role="progressbar" style="width: @player.Strength%;" aria-valuenow="@player.Strength" aria-valuemin="0" aria-valuemax="99"></div>
                            </div>
                        </div>
                        <div class="mb-1">
                            <small class="d-flex justify-content-between">
                                <span>Agility</span><span>@player.Agility</span>
                            </small>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: @player.Agility%;" aria-valuenow="@player.Agility" aria-valuemin="0" aria-valuemax="99"></div>
                            </div>
                        </div>
                        <div class="mb-1">
                            <small class="d-flex justify-content-between">
                                <span>Kicking</span><span>@player.Kicking</span>
                            </small>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-warning" role="progressbar" style="width: @player.Kicking%;" aria-valuenow="@player.Kicking" aria-valuemin="0" aria-valuemax="99"></div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(player.Bio))
                    {
                        <p class="card-text mt-2 mb-0">
                            <small class="text-muted">
                                @(player.Bio.Length > 100 ? player.Bio[..100] + "..." : player.Bio)
                            </small>
                        </p>
                    }
                </div>
            </div>
        }
    </div>
}

@code {
    private List<PlayerModel> allPlayers = new();
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private string selectedPosition = string.Empty;
    private string selectedRarity = string.Empty;
    private string nameFilter = string.Empty;

    private IEnumerable<PlayerModel> filteredPlayers =>
        allPlayers.Where(p =>
            (string.IsNullOrEmpty(selectedPosition) || p.Position.ToString() == selectedPosition) &&
            (string.IsNullOrEmpty(selectedRarity) || p.Rarity.ToString() == selectedRarity) &&
            (string.IsNullOrEmpty(nameFilter) || p.Name.Contains(nameFilter, StringComparison.OrdinalIgnoreCase))
        );

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            errorMessage = string.Empty;

            allPlayers = await ApiClient.GetPlayersAsync();
            var collection = await ApiClient.GetCollectionAsync();
            Dispatcher.Dispatch(new FetchInventoryResultAction(collection));
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load players: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ClearFilters()
    {
        selectedPosition = string.Empty;
        selectedRarity = string.Empty;
        nameFilter = string.Empty;
    }

    private static string GetRarityColor(PlayerRarity rarity) => rarity switch
    {
        PlayerRarity.Common => "#9e9e9e",
        PlayerRarity.Uncommon => "#4caf50",
        PlayerRarity.Rare => "#2196f3",
        PlayerRarity.Epic => "#9c27b0",
        PlayerRarity.Legendary => "#ff9800",
        _ => "#9e9e9e"
    };
}
