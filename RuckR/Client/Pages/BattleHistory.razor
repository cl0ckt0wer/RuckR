@page "/battles/history"
@using RuckR.Shared.Models
@inject ApiClientService ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Battle History</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="game-page history-page">
    @if (_requiresAuth)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2">Checking session...</MudText>
        </MudStack>
    }
    else if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8" data-testid="history-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2">Loading battle history...</MudText>
        </MudStack>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" data-testid="history-error">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText>@_errorMessage</MudText>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="LoadHistoryAsync" data-testid="history-retry-btn">Retry</MudButton>
            </MudStack>
        </MudAlert>
    }
    else if (_battles is null || _battles.Count == 0)
    {
        <MudPaper Elevation="0" Class="game-panel empty-panel" data-testid="history-empty">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Color="Color.Secondary" />
                <MudText Typo="Typo.h5">No battles yet</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Find opponents nearby and start your record.</MudText>
                <MudButton Href="/players/nearby" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Groups">
                    Find Opponents
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else
    {
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="game-page__header">
                <div>
                    <MudText Typo="Typo.overline">Record</MudText>
                    <MudText Typo="Typo.h4">Battle History</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Recent completed, declined, and expired challenges.
                    </MudText>
                </div>
                <MudButton Href="/battle" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Bolt">
                    Battle Arena
                </MudButton>
            </MudStack>

            <MudStack Spacing="2" data-testid="history-list">
                @foreach (var battle in _battles)
                {
                    var isExpanded = _expandedId == battle.Id;
                    var isUserChallenger = string.Equals(battle.ChallengerUsername, _currentUsername, StringComparison.OrdinalIgnoreCase);
                    var opponentDisplay = isUserChallenger ? battle.OpponentUsername : battle.ChallengerUsername;
                    var userPlayerDisplay = isUserChallenger ? PlayerDisplay(battle.ChallengerPlayer) : PlayerDisplay(battle.OpponentPlayer);
                    var opponentPlayerDisplay = isUserChallenger ? PlayerDisplay(battle.OpponentPlayer) : PlayerDisplay(battle.ChallengerPlayer);
                    var result = GetBattleResult(battle);

                    <MudPaper Elevation="1" Class="@HistoryCardClass(isExpanded)" data-testid="history-item">
                        <MudStack Spacing="2">
                            <MudStack Row="true" AlignItems="AlignItems.Start" Justify="Justify.SpaceBetween">
                                <button type="button" @onclick="() => ToggleExpand(battle.Id)" class="history-card__summary">
                                    <span class="history-card__summary-head">
                                        <span class="@ResultBadgeClass(result)" data-testid="result-badge">@ResultLabel(result)</span>
                                        <span class="history-card__opponent">vs @opponentDisplay</span>
                                    </span>
                                    <span class="history-card__meta">
                                        @userPlayerDisplay vs @opponentPlayerDisplay
                                    </span>
                                    <span class="history-card__time">
                                        @GetRelativeTime(battle.ResolvedAt ?? battle.CreatedAt)
                                    </span>
                                </button>
                                <MudIconButton Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                               OnClick="() => ToggleExpand(battle.Id)"
                                               data-testid="expand-indicator" />
                            </MudStack>

                            @if (battle.Result is not null)
                            {
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                    @battle.Result.WinnerUsername won with @battle.Result.WinnerPlayerName. @MoveScoreDisplay(battle.Result.WinnerMove, battle.Result.WinnerScore) beat @MoveScoreDisplay(battle.Result.LoserMove, battle.Result.LoserScore). Method: @battle.Result.Method.
                                </MudAlert>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">@GetOutcomeDescription(battle, isUserChallenger)</MudText>
                            }

                            @if (isExpanded)
                            {
                                <div class="history-card__detail" data-testid="battle-detail">
                                    <MudGrid Spacing="2">
                                        <MudItem xs="12" md="6">
                                            <MudText Typo="Typo.subtitle2">Your side</MudText>
                                            <MudText Typo="Typo.body2">Role: @(isUserChallenger ? "Challenger" : "Opponent")</MudText>
                                            <MudText Typo="Typo.body2">Recruit: @userPlayerDisplay</MudText>
                                            <MudText Typo="Typo.body2">Play: @MoveDisplay(isUserChallenger ? battle.ChallengerMove : battle.OpponentMove)</MudText>
                                            @if ((isUserChallenger ? battle.ChallengerScore : battle.OpponentScore) is { } userScore)
                                            {
                                                <MudText Typo="Typo.body2">Score: @userScore.ToString("0.##")</MudText>
                                            }
                                        </MudItem>
                                        <MudItem xs="12" md="6">
                                            <MudText Typo="Typo.subtitle2">Opponent</MudText>
                                            <MudText Typo="Typo.body2">User: @opponentDisplay</MudText>
                                            <MudText Typo="Typo.body2">Recruit: @opponentPlayerDisplay</MudText>
                                            <MudText Typo="Typo.body2">Play: @MoveDisplay(isUserChallenger ? battle.OpponentMove : battle.ChallengerMove)</MudText>
                                            @if ((isUserChallenger ? battle.OpponentScore : battle.ChallengerScore) is { } opponentScore)
                                            {
                                                <MudText Typo="Typo.body2">Score: @opponentScore.ToString("0.##")</MudText>
                                            }
                                        </MudItem>
                                    </MudGrid>
                                    <MudDivider />
                                    <MudText Typo="Typo.caption">Status: @StatusLabel(battle.Status)</MudText>
                                    <MudText Typo="Typo.caption">Created: @battle.CreatedAt.ToString("MMM dd, yyyy HH:mm") UTC</MudText>
                                    @if (battle.ResolvedAt.HasValue)
                                    {
                                        <MudText Typo="Typo.caption">Resolved: @battle.ResolvedAt.Value.ToString("MMM dd, yyyy HH:mm") UTC</MudText>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(battle.WinnerUsername))
                                    {
                                        <MudText Typo="Typo.caption">Winner: @battle.WinnerUsername</MudText>
                                    }
                                </div>
                            }
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        </MudStack>
    }
</MudContainer>

@code {
    private bool _requiresAuth = true;
    private bool _isLoading = true;
    private string? _errorMessage;
    private string _currentUsername = string.Empty;
    private IReadOnlyList<BattleSummaryDto>? _battles;
    private int? _expandedId;

    private enum BattleResultDisplay
    {
        Victory,
        Defeat,
        Expired,
        Declined,
        Unknown
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity is null || !user.Identity.IsAuthenticated)
        {
            var returnUrl = Uri.EscapeDataString("/" + Navigation.ToBaseRelativePath(Navigation.Uri));
            Navigation.NavigateTo($"/Identity/Account/Login?returnUrl={returnUrl}", forceLoad: true);
            return;
        }

        _requiresAuth = false;
        _currentUsername = user.Identity.Name ?? string.Empty;
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var history = await ApiClient.GetBattleHistoryAsync();
            _battles = history.AsReadOnly();
        }
        catch (HttpRequestException ex)
        {
            _errorMessage = $"Failed to load battle history: {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleExpand(int battleId)
    {
        _expandedId = _expandedId == battleId ? null : battleId;
    }

    private BattleResultDisplay GetBattleResult(BattleSummaryDto battle)
    {
        if (battle.Status == BattleStatus.Expired)
            return BattleResultDisplay.Expired;
        if (battle.Status == BattleStatus.Declined)
            return BattleResultDisplay.Declined;
        if (battle.Status == BattleStatus.Completed)
        {
            if (!string.IsNullOrWhiteSpace(battle.WinnerUsername)
                && string.Equals(battle.WinnerUsername, _currentUsername, StringComparison.OrdinalIgnoreCase))
                return BattleResultDisplay.Victory;
            if (!string.IsNullOrWhiteSpace(battle.WinnerUsername))
                return BattleResultDisplay.Defeat;
        }
        return BattleResultDisplay.Unknown;
    }

    private string GetOutcomeDescription(BattleSummaryDto battle, bool isUserChallenger)
    {
        if (battle.Status == BattleStatus.Completed)
        {
            if (!string.IsNullOrWhiteSpace(battle.WinnerUsername)
                && string.Equals(battle.WinnerUsername, _currentUsername, StringComparison.OrdinalIgnoreCase))
                return "Won. Your selected recruit prevailed.";
            if (!string.IsNullOrWhiteSpace(battle.WinnerUsername))
                return "Lost. The opponent's selected recruit prevailed.";
            return "Completed.";
        }

        if (battle.Status == BattleStatus.Declined)
            return isUserChallenger ? "Opponent declined your challenge." : "You declined this challenge.";
        if (battle.Status == BattleStatus.Expired)
            return "Challenge expired before resolution.";
        return battle.Status.ToString();
    }

    private static string PlayerDisplay(BattlePlayerSummaryDto? player) =>
        player is null ? "No recruit selected" : $"{player.Name} ({player.Position}, {player.Rarity})";

    private static string MoveScoreDisplay(BattleMove? move, double? score)
    {
        if (move is null && score is null) return "selection";
        if (score is null) return BattleMoveDisplay.Score(move, score);
        return $"{BattleMoveDisplay.Score(move, null)} ({score:0.##})";
    }

    private static string MoveDisplay(BattleMove? move) =>
        move.HasValue ? BattleMoveDisplay.Name(move.Value) : "Not submitted";

    private static string HistoryCardClass(bool expanded) => expanded
        ? "game-panel history-card history-card--expanded"
        : "game-panel history-card";

    private static string ResultBadgeClass(BattleResultDisplay result) => result switch
    {
        BattleResultDisplay.Victory => "history-card__result-badge history-card__result-badge--victory",
        BattleResultDisplay.Defeat => "history-card__result-badge history-card__result-badge--defeat",
        BattleResultDisplay.Expired => "history-card__result-badge history-card__result-badge--muted",
        BattleResultDisplay.Declined => "history-card__result-badge history-card__result-badge--muted",
        _ => "history-card__result-badge"
    };

    private static string ResultLabel(BattleResultDisplay result) => result switch
    {
        BattleResultDisplay.Victory => "Victory",
        BattleResultDisplay.Defeat => "Defeat",
        BattleResultDisplay.Expired => "Expired",
        BattleResultDisplay.Declined => "Declined",
        _ => "Unknown"
    };

    private static string GetRelativeTime(DateTime utcTime)
    {
        var elapsed = DateTime.UtcNow - utcTime;
        if (elapsed.TotalSeconds < 60) return "just now";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes} min ago";
        if (elapsed.TotalHours < 24) return $"{(int)elapsed.TotalHours}h ago";
        if (elapsed.TotalDays < 2) return "Yesterday";
        if (elapsed.TotalDays < 7) return $"{(int)elapsed.TotalDays} days ago";
        return utcTime.ToString("MMM d");
    }

    private static string StatusLabel(BattleStatus status) => status switch
    {
        BattleStatus.Pending => "Pending",
        BattleStatus.Accepted => "Accepted",
        BattleStatus.Completed => "Completed",
        BattleStatus.Declined => "Declined",
        BattleStatus.Expired => "Expired",
        _ => status.ToString()
    };
}

<style>
    .game-page {
        padding: 1rem;
    }

    .game-page__header {
        gap: 1rem;
        flex-wrap: wrap;
    }

    .game-panel {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 8px;
        padding: 1rem;
        background: #fff;
    }

    .empty-panel {
        min-height: 18rem;
        display: grid;
        place-items: center;
        text-align: center;
    }

    .history-card--expanded {
        border-color: rgba(15, 118, 110, 0.4);
    }

    .history-card__summary {
        min-width: 0;
        border: 0;
        padding: 0;
        background: transparent;
        color: inherit;
        cursor: pointer;
        text-align: left;
    }

    .history-card__summary-head {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .history-card__result-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 0.25rem 0.65rem;
        background: #374151;
        color: #fff;
        font-size: 0.8125rem;
        font-weight: 600;
        line-height: 1.5;
    }

    .history-card__result-badge--victory {
        background: #2e7d32;
    }

    .history-card__result-badge--defeat {
        background: #c62828;
    }

    .history-card__result-badge--muted {
        background: #64748b;
    }

    .history-card__opponent {
        font-size: 1.25rem;
        font-weight: 500;
        line-height: 1.6;
    }

    .history-card__meta,
    .history-card__time {
        display: block;
        color: var(--mud-palette-text-secondary);
    }

    .history-card__meta {
        font-size: 0.875rem;
        line-height: 1.43;
    }

    .history-card__time {
        font-size: 0.75rem;
        line-height: 1.66;
    }

    .history-card__detail {
        display: grid;
        gap: 0.65rem;
        border-top: 1px solid rgba(15, 23, 42, 0.08);
        padding-top: 0.75rem;
    }

    @@media (max-width: 720px) {
        .game-page {
            padding: 0.75rem;
        }

        .game-panel {
            padding: 0.85rem;
        }
    }
</style>
