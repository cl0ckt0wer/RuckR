@page "/profile"
@using Microsoft.AspNetCore.Authorization
@using RuckR.Shared.Models
@attribute [Authorize]
@inject ApiClientService ApiClient
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Profile</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="profile-page">
    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Class="py-8" data-testid="profile-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2">Loading profile...</MudText>
        </MudStack>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" data-testid="profile-error">
            @_errorMessage
        </MudAlert>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadProfileAsync" Class="mt-3" data-testid="profile-retry-btn">
            Retry
        </MudButton>
    }
    else if (_profile is not null)
    {
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="profile-page__header">
                <div>
                    <MudText Typo="Typo.overline">Account</MudText>
                    <MudText Typo="Typo.h4">Profile</MudText>
                </div>
                @if (!_isEditing)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="BeginEdit" data-testid="profile-edit-btn">
                        Edit
                    </MudButton>
                }
            </MudStack>

            @if (!_isEditing)
            {
                <MudPaper Elevation="0" Class="profile-panel" data-testid="profile-view">
                    <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="3" Class="profile-summary">
                        @if (!string.IsNullOrWhiteSpace(_profile.AvatarUrl))
                        {
                            <img class="profile-avatar" src="@_profile.AvatarUrl" alt="" data-testid="profile-avatar" />
                        }
                        else
                        {
                            <MudAvatar Size="Size.Large" Color="Color.Primary" Class="profile-avatar" data-testid="profile-avatar">
                                <MudIcon Icon="@Icons.Material.Filled.Person" />
                            </MudAvatar>
                        }
                        <MudStack Spacing="1" Class="profile-summary__body">
                            <MudText Typo="Typo.h5" data-testid="profile-display-name">@DisplayName</MudText>
                            @if (!string.IsNullOrWhiteSpace(_profile.Location))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" data-testid="profile-location">@_profile.Location</MudText>
                            }
                            <MudText Typo="Typo.body1" data-testid="profile-bio">@BioText</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Joined @_profile.JoinedDate.ToString("MMMM yyyy")</MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }
            else
            {
                <MudPaper Elevation="0" Class="profile-panel" data-testid="profile-edit">
                    <EditForm Model="_editModel" OnValidSubmit="SaveProfileAsync">
                        <DataAnnotationsValidator />
                        <MudStack Spacing="3">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="profile-summary">
                                @if (!string.IsNullOrWhiteSpace(AvatarPreviewSource))
                                {
                                    <img class="profile-avatar" src="@AvatarPreviewSource" alt="" data-testid="profile-avatar-preview" />
                                }
                                else
                                {
                                    <MudAvatar Size="Size.Large" Color="Color.Primary" Class="profile-avatar" data-testid="profile-avatar-preview">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                                    </MudAvatar>
                                }
                                <div class="profile-summary__body">
                                    <label class="form-label" for="profile-display-name-input">Display name</label>
                                    <InputText id="profile-display-name-input" class="form-control" @bind-Value="_editModel.Name" data-testid="profile-display-name-input" />
                                    <ValidationMessage For="() => _editModel.Name" />
                                </div>
                            </MudStack>

                            <MudPaper Elevation="0" Class="profile-upload-panel" data-testid="profile-avatar-upload-panel">
                                <MudStack Spacing="2">
                                    <div>
                                        <label class="form-label" for="profile-avatar-file-input">Profile picture</label>
                                        <InputFile id="profile-avatar-file-input"
                                                   OnChange="OnAvatarFileSelectedAsync"
                                                   accept="image/jpeg,image/png,image/webp"
                                                   class="form-control"
                                                   data-testid="profile-avatar-file-input" />
                                        <div class="field-hint">JPEG, PNG, or WebP. Max 10 MB.</div>
                                    </div>

                                    @if (_isProcessingAvatar)
                                    {
                                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" data-testid="profile-avatar-processing" />
                                    }

                                    @if (!string.IsNullOrWhiteSpace(_avatarUploadError))
                                    {
                                        <MudAlert Severity="Severity.Error" Dense="true" data-testid="profile-avatar-error">@_avatarUploadError</MudAlert>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(_selectedAvatarSummary))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" data-testid="profile-avatar-processing-summary">@_selectedAvatarSummary</MudText>
                                    }

                                    @if (_selectedAvatarBytes is not null)
                                    {
                                        <MudButton ButtonType="ButtonType.Button"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                                   Disabled="@(_isUploadingAvatar || _isProcessingAvatar)"
                                                   OnClick="UploadSelectedAvatarAsync"
                                                   data-testid="profile-avatar-upload-btn">
                                            @(_isUploadingAvatar ? "Uploading" : "Upload photo")
                                        </MudButton>
                                    }

                                    @if (CanEditExternalAvatarUrl)
                                    {
                                        <div>
                                            <label class="form-label" for="profile-avatar-url-input">External image URL</label>
                                            <InputText id="profile-avatar-url-input" class="form-control" @bind-Value="_editModel.AvatarUrl" data-testid="profile-avatar-url-input" />
                                            <ValidationMessage For="() => _editModel.AvatarUrl" />
                                        </div>
                                    }
                                </MudStack>
                            </MudPaper>

                            <div>
                                <label class="form-label" for="profile-location-input">Location</label>
                                <InputText id="profile-location-input" class="form-control" @bind-Value="_editModel.Location" data-testid="profile-location-input" />
                                <ValidationMessage For="() => _editModel.Location" />
                            </div>

                            <div>
                                <label class="form-label" for="profile-bio-input">Bio</label>
                                <InputTextArea id="profile-bio-input" class="form-control" rows="5" @bind-Value="_editModel.Biography" data-testid="profile-bio-input" />
                                <ValidationMessage For="() => _editModel.Biography" />
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_saveMessage))
                            {
                                <MudAlert Severity="Severity.Success" Dense="true" data-testid="profile-save-message">@_saveMessage</MudAlert>
                            }

                            <MudStack Row="true" Spacing="1">
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isSaving" StartIcon="@Icons.Material.Filled.Save" data-testid="profile-save-btn">
                                    @(_isSaving ? "Saving" : "Save")
                                </MudButton>
                                <MudButton ButtonType="ButtonType.Button" Variant="Variant.Outlined" Color="Color.Secondary" Disabled="@_isSaving" OnClick="CancelEdit" data-testid="profile-cancel-btn">
                                    Cancel
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </EditForm>
                </MudPaper>
            }
        </MudStack>
    }
</MudContainer>

@code {
    private const string AvatarInputId = "profile-avatar-file-input";
    private const long MaxAvatarUploadBytes = 2 * 1024 * 1024;
    private const long MaxAvatarSourceBytes = 10 * 1024 * 1024;
    private const int AvatarMaxEdgePixels = 768;
    private const double AvatarQuality = 0.82;
    private static readonly HashSet<string> AllowedAvatarContentTypes = new(StringComparer.OrdinalIgnoreCase)
    {
        "image/jpeg",
        "image/png",
        "image/webp"
    };

    private UserProfileModel? _profile;
    private UserProfileUpdateRequest _editModel = new();
    private bool _isLoading = true;
    private bool _isEditing;
    private bool _isSaving;
    private bool _isUploadingAvatar;
    private bool _isProcessingAvatar;
    private byte[]? _selectedAvatarBytes;
    private string? _selectedAvatarFileName;
    private string? _selectedAvatarContentType;
    private string? _selectedAvatarPreviewDataUrl;
    private string? _selectedAvatarSummary;
    private string? _avatarUploadError;
    private string? _errorMessage;
    private string? _saveMessage;
    private IJSObjectReference? _avatarModule;

    private string DisplayName => string.IsNullOrWhiteSpace(_profile?.Name) ? "RuckR Player" : _profile!.Name!;

    private string BioText => string.IsNullOrWhiteSpace(_profile?.Biography) ? "No bio yet." : _profile!.Biography!;

    private string? AvatarPreviewSource => _selectedAvatarPreviewDataUrl ?? _editModel.AvatarUrl;

    private bool CanEditExternalAvatarUrl =>
        Uri.TryCreate(_profile?.AvatarUrl, UriKind.Absolute, out var uri)
        && uri.Scheme is "http" or "https";

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _saveMessage = null;

        try
        {
            _profile = await ApiClient.GetUserProfileAsync();
            if (_profile is null)
            {
                _errorMessage = "Profile could not be loaded.";
                return;
            }

            ResetEditModel();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Profile could not be loaded: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BeginEdit()
    {
        ResetEditModel();
        ClearSelectedAvatar();
        _saveMessage = null;
        _isEditing = true;
    }

    private async Task SaveProfileAsync()
    {
        _isSaving = true;
        _errorMessage = null;
        _saveMessage = null;

        try
        {
            var saved = await ApiClient.SaveUserProfileAsync(_editModel);
            if (saved is null)
            {
                _errorMessage = "Profile could not be saved.";
                return;
            }

            _profile = saved;
            ResetEditModel();
            ClearSelectedAvatar();
            _isEditing = false;
            _saveMessage = "Profile saved.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Profile could not be saved: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void CancelEdit()
    {
        ResetEditModel();
        ClearSelectedAvatar();
        _isEditing = false;
        _errorMessage = null;
        _saveMessage = null;
    }

    private async Task OnAvatarFileSelectedAsync(InputFileChangeEventArgs args)
    {
        ClearSelectedAvatar();
        var file = args.File;

        if (file.Size <= 0)
        {
            _avatarUploadError = "Choose a non-empty image file.";
            return;
        }

        if (file.Size > MaxAvatarSourceBytes)
        {
            _avatarUploadError = "Profile picture source must be 10 MB or smaller.";
            return;
        }

        if (!AllowedAvatarContentTypes.Contains(file.ContentType))
        {
            _avatarUploadError = "Profile picture must be a JPEG, PNG, or WebP image.";
            return;
        }

        try
        {
            _isProcessingAvatar = true;
            var module = await GetAvatarModuleAsync();
            var processed = await module.InvokeAsync<ProcessedProfileAvatar>(
                "resizeSelectedProfileAvatar",
                AvatarInputId,
                new
                {
                    maxSourceBytes = MaxAvatarSourceBytes,
                    maxOutputBytes = MaxAvatarUploadBytes,
                    maxEdgePixels = AvatarMaxEdgePixels,
                    quality = AvatarQuality
                });

            if (processed is null
                || string.IsNullOrWhiteSpace(processed.DataUrl)
                || string.IsNullOrWhiteSpace(processed.ContentType)
                || string.IsNullOrWhiteSpace(processed.FileName))
            {
                _avatarUploadError = "Profile picture could not be processed.";
                return;
            }

            if (!AllowedAvatarContentTypes.Contains(processed.ContentType))
            {
                _avatarUploadError = "Processed profile picture must be a JPEG, PNG, or WebP image.";
                return;
            }

            var processedBytes = DecodeDataUrl(processed.DataUrl);
            if (processedBytes.Length > MaxAvatarUploadBytes)
            {
                _avatarUploadError = "Profile picture must be 2 MB or smaller after processing.";
                return;
            }

            _selectedAvatarBytes = processedBytes;
            _selectedAvatarFileName = processed.FileName;
            _selectedAvatarContentType = processed.ContentType;
            _selectedAvatarPreviewDataUrl = processed.DataUrl;
            _selectedAvatarSummary = $"{processed.Width} x {processed.Height}, {FormatBytes(processed.OutputSize)}";
        }
        catch (Exception ex)
        {
            _avatarUploadError = $"Profile picture could not be processed: {ex.Message}";
        }
        finally
        {
            _isProcessingAvatar = false;
        }
    }

    private async Task UploadSelectedAvatarAsync()
    {
        if (_selectedAvatarBytes is null
            || string.IsNullOrWhiteSpace(_selectedAvatarFileName)
            || string.IsNullOrWhiteSpace(_selectedAvatarContentType))
        {
            _avatarUploadError = "Choose an image before uploading.";
            return;
        }

        _isUploadingAvatar = true;
        _avatarUploadError = null;
        _saveMessage = null;

        try
        {
            using var stream = new MemoryStream(_selectedAvatarBytes);
            var saved = await ApiClient.UploadProfileAvatarAsync(stream, _selectedAvatarFileName, _selectedAvatarContentType);
            if (saved is null)
            {
                _avatarUploadError = "Profile picture could not be uploaded.";
                return;
            }

            _profile = saved;
            ResetEditModel();
            ClearSelectedAvatar();
            _saveMessage = "Profile picture uploaded.";
        }
        catch (Exception ex)
        {
            _avatarUploadError = $"Profile picture could not be uploaded: {ex.Message}";
        }
        finally
        {
            _isUploadingAvatar = false;
        }
    }

    private void ClearSelectedAvatar()
    {
        _selectedAvatarBytes = null;
        _selectedAvatarFileName = null;
        _selectedAvatarContentType = null;
        _selectedAvatarPreviewDataUrl = null;
        _selectedAvatarSummary = null;
        _avatarUploadError = null;
    }

    private void ResetEditModel()
    {
        _editModel = new UserProfileUpdateRequest
        {
            Name = _profile?.Name,
            Biography = _profile?.Biography,
            Location = _profile?.Location,
            AvatarUrl = _profile?.AvatarUrl
        };
    }

    private async Task<IJSObjectReference> GetAvatarModuleAsync()
    {
        _avatarModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/profile-avatar.module.js");
        return _avatarModule;
    }

    private static byte[] DecodeDataUrl(string dataUrl)
    {
        var separatorIndex = dataUrl.IndexOf(',', StringComparison.Ordinal);
        if (separatorIndex < 0 || !dataUrl[..separatorIndex].Contains(";base64", StringComparison.OrdinalIgnoreCase))
            throw new InvalidOperationException("Processed profile picture data is invalid.");

        return Convert.FromBase64String(dataUrl[(separatorIndex + 1)..]);
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes >= 1024 * 1024)
            return $"{Math.Round(bytes / 1024d / 1024d, 1)} MB";

        return $"{Math.Max(1, (int)Math.Ceiling(bytes / 1024d))} KB";
    }

    public async ValueTask DisposeAsync()
    {
        if (_avatarModule is not null)
        {
            await _avatarModule.DisposeAsync();
        }
    }
}

<style>
    .profile-page {
        padding: 1rem;
    }

    .profile-page__header {
        gap: 1rem;
        flex-wrap: wrap;
    }

    .profile-panel {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 8px;
        padding: 1rem;
        background: #fff;
    }

    .profile-upload-panel {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 8px;
        padding: 0.85rem;
        background: #f8fafc;
    }

    .field-hint {
        margin-top: 0.25rem;
        color: #64748b;
        font-size: 0.82rem;
    }

    .profile-summary {
        min-width: 0;
        flex-wrap: wrap;
    }

    .profile-summary__body {
        min-width: min(100%, 18rem);
        flex: 1;
    }

    .profile-avatar {
        width: 5.5rem;
        height: 5.5rem;
        flex: 0 0 auto;
        border-radius: 8px;
        object-fit: cover;
    }
</style>
