# Environment variables needed by RuckR.
# Copy this to .env (gitignored) or set these in Windows env vars
# and run:  source scripts/sync-windows-env.sh
#
# See ADR-010 and AGENTS.md for the layered secret management policy.

# Docker SQL Server password (only needed if not using LocalDB)
RUCKR_DB_PASSWORD=YourStrong!Pass123

# Test database password (falls back to auto-generated GUID if unset)
RUCKR_TEST_DB_PASSWORD=

# ASP.NET Core hosting (optional overrides)
ASPNETCORE_ENVIRONMENT=Development
